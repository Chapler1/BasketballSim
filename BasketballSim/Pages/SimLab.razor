    // ── Factory ─────────────────────────────────────────────────────────────
    private static List<PlayerConfig> MakeDefaultTeam(string teamName)
    {
        var positions = new[] { Position.PG, Position.SG, Position.SF, Position.PF, Position.C };
        string suffix = teamName == "Home" ? "H" : "A";
        return positions.Select((pos, i) => new PlayerConfig
        {
            Name = $"Player {i + 1}{suffix}",
            Team = teamName,
            Position = pos
        }).ToList();
    }

    // ── Event handlers ──────────────────────────────────────────────────────
    private void OnAttrChange(ChangeEventArgs e, AttrSpec attr, PlayerConfig player)
    {
        if (int.TryParse(e.Value?.ToString(), out var v))
            attr.Set(player, Math.Clamp(v, 1, 100));
    }

    private static void BulkAdjust(List<PlayerConfig> team, AttrSpec attr, int delta)
    {
        foreach (var p in team)
            attr.Set(p, Math.Clamp(attr.Get(p) + delta, 1, 100));
    }

    // ── Actions ─────────────────────────────────────────────────────────────
    private void ResetDefaults()
    {
        _homeConfigs = MakeDefaultTeam("Home");
        _awayConfigs = MakeDefaultTeam("Away");
        _homePace = 100;
        _awayPace = 100;
        _saved = false;
        _results = null;
    }

    private void SaveConfig()
    {
        _saved = true;
        _ = Task.Delay(3000).ContinueWith(_ =>
        {
            _saved = false;
            InvokeAsync(StateHasChanged);
        });
    }

    private async Task RunSimulation()
    {
        _simulating = true;
        _simProgress = 0;
        _results = null;
        StateHasChanged();

        var accum  = new BatchAccumulator();
        var engine = new GameEngine();
        var home   = BuildTeam(_homeConfigs, "Home", "HME", "#4a9eff", _homePace);
        var away   = BuildTeam(_awayConfigs, "Away", "AWY", "#ef5b40", _awayPace);

        int totalGames = Math.Max(1, _totalGames);
        const int batchSize = 500;
        int gamesRun = 0;

        while (gamesRun < totalGames)
        {
            int thisBatch = Math.Min(batchSize, totalGames - gamesRun);
            await Task.Run(() =>
            {
                for (int i = 0; i < thisBatch; i++)
                {
                    var result = engine.SimulateGame(home, away);
                    accum.Add(result, "Home");
                }
            });
            gamesRun += thisBatch;
            _simProgress = gamesRun;
            StateHasChanged();
        }

        _results   = accum;
        _simulating = false;
        StateHasChanged();
    }

    private static Team BuildTeam(List<PlayerConfig> configs, string name, string abbr,
                                   string color, int pace) => new()
    {
        Name = name, Abbreviation = abbr,
        PrimaryColor = color, SecondaryColor = "#888888",
        Pace = pace,
        Roster = configs.Select(c => c.ToPlayer()).ToList()
    };

    // ── Styling helpers ─────────────────────────────────────────────────────
    private static string InputStyle(int v) =>
        $"width:54px;text-align:center;background:#252525;border:1px solid #333;color:{ValColor(v)};padding:2px;border-radius:3px;font-size:0.77rem;font-family:monospace;";

    private static string ValColor(int v) => v switch
    {
        >= 80 => "#7be",
        >= 65 => "#8e8",
        >= 50 => "#d4d4d4",
        >= 35 => "#eb8",
        _     => "#e66"
    };

    // Compact shooting display for box score: "5.1/12.0 (42%)"
    private static string BxShoot(long made, long att, double games) =>
        att == 0 ? "-"
        : $"{made / games:F1}/{att / games:F1} ({(double)made / att * 100:F0}%)";

    private string ShootStr(long made, long att) =>
        att == 0 ? "-"
        : $"{(double)made / _results!.Games:F1}/{(double)att / _results.Games:F1} ({(double)made / att * 100:F1}%)";

    private RenderFragment ResultRow(string label, string home, string away,
                                     bool homeWins, bool awayWins, bool isSection = false)
    {
        string hc  = homeWins ? "#7be" : "#d4d4d4";
        string ac  = awayWins ? "#7be" : "#d4d4d4";
        string hfw = homeWins ? "700" : "400";
        string afw = awayWins ? "700" : "400";
        string bg  = isSection ? "#252525" : "#1e1e1e";
        return @<tr style="border-bottom:1px solid #252525;background:@bg;">
            <td style="padding:4px 0;color:#666;font-size:0.74rem;">@label</td>
            <td style="text-align:center;padding:4px 12px;color:@hc;font-weight:@hfw;font-size:0.82rem;">@home</td>
            <td style="text-align:center;padding:4px 12px;color:@ac;font-weight:@afw;font-size:0.82rem;">@away</td>
        </tr>;
    }

    private RenderFragment SectionHeader(string label) =>
        @<tr style="background:#222;border-top:1px solid #2a2a2a;">
            <td colspan="3" style="padding:4px 0;font-size:0.62rem;letter-spacing:2px;color:#444;text-transform:uppercase;">@label</td>
        </tr>;

    // ── Batch accumulator ───────────────────────────────────────────────────
    private class BatchAccumulator
    {
        public int  Games, HomeWins;
        public long HomePts,  AwayPts;
        public long HomeFGM,  HomeFGA,  AwayFGM,  AwayFGA;
        public long Home3M,   Home3A,   Away3M,   Away3A;
        public long HomeFTM,  HomeFTA,  AwayFTM,  AwayFTA;
        public long HomeReb,  AwayReb;
        public long HomeOReb, AwayOReb;
        public long HomeDReb, AwayDReb;
        public long HomeAst,  AwayAst;
        public long HomeStl,  AwayStl;
        public long HomeBlk,  AwayBlk;
        public long HomeTo,   AwayTo;

        // ── Per-player accumulator ───────────────────────────────────────────
        public class PlayerAccum
        {
            public required string   Name;
            public required string   Team;
            public required Position Position;
            public long Pts, Reb, Ast, Stl, Blk, To;
            public long FGM, FGA, ThreeM, ThreeA, FTM, FTA;
        }

        public Dictionary<string, PlayerAccum> PlayerStats = new();

        // Per-shot-type and per-context breakdowns (tracked from possession log)
        public Dictionary<ShotType,    long> HomeShotMade = new();
        public Dictionary<ShotType,    long> HomeShotAtt  = new();
        public Dictionary<ShotType,    long> AwayShotMade = new();
        public Dictionary<ShotType,    long> AwayShotAtt  = new();
        public Dictionary<ShotContext, long> HomeCtxMade  = new();
        public Dictionary<ShotContext, long> HomeCtxAtt   = new();
        public Dictionary<ShotContext, long> AwayCtxMade  = new();
        public Dictionary<ShotContext, long> AwayCtxAtt   = new();

        public void Add(GameResult r, string homeTeamName)
        {
            Games++;
            if (r.FinalHomeScore > r.FinalAwayScore) HomeWins++;
            HomePts += r.FinalHomeScore;
            AwayPts += r.FinalAwayScore;

            foreach (var s in r.Stats.Values)
            {
                if (!PlayerStats.TryGetValue(s.Name, out var pa))
                {
                    pa = new PlayerAccum { Name = s.Name, Team = s.Team, Position = s.Position };
                    PlayerStats[s.Name] = pa;
                }
                pa.Pts    += s.Points;      pa.Reb  += s.Rebounds;
                pa.Ast    += s.Assists;     pa.Stl  += s.Steals;
                pa.Blk    += s.Blocks;      pa.To   += s.Turnovers;
                pa.FGM    += s.FGMade;      pa.FGA  += s.FGAttempts;
                pa.ThreeM += s.ThreeMade;   pa.ThreeA += s.ThreeAttempts;
                pa.FTM    += s.FTMade;      pa.FTA  += s.FTAttempts;

                if (s.Team == homeTeamName)
                {
                    HomeFGM  += s.FGMade;    HomeFGA  += s.FGAttempts;
                    Home3M   += s.ThreeMade; Home3A   += s.ThreeAttempts;
                    HomeFTM  += s.FTMade;    HomeFTA  += s.FTAttempts;
                    HomeReb  += s.Rebounds;  HomeOReb += s.OffRebounds; HomeDReb += s.DefRebounds;
                    HomeAst  += s.Assists;   HomeStl  += s.Steals;
                    HomeBlk  += s.Blocks;    HomeTo   += s.Turnovers;
                }
                else
                {
                    AwayFGM  += s.FGMade;    AwayFGA  += s.FGAttempts;
                    Away3M   += s.ThreeMade; Away3A   += s.ThreeAttempts;
                    AwayFTM  += s.FTMade;    AwayFTA  += s.FTAttempts;
                    AwayReb  += s.Rebounds;  AwayOReb += s.OffRebounds; AwayDReb += s.DefRebounds;
                    AwayAst  += s.Assists;   AwayStl  += s.Steals;
                    AwayBlk  += s.Blocks;    AwayTo   += s.Turnovers;
                }
            }

            // Per-shot-type and per-context tracking from possession log
            foreach (var pos in r.Possessions)
            {
                if (pos.Shot is not { } st || pos.Context is not { } ctx) continue;
                if (pos.Event is not (PossessionEvent.ShotMade or PossessionEvent.ShotMissed
                                   or PossessionEvent.Blocked  or PossessionEvent.GameWinnerMade)) continue;

                bool isMade = pos.Event is PossessionEvent.ShotMade or PossessionEvent.GameWinnerMade;
                bool isHome = pos.Team == homeTeamName;

                var shotMade = isHome ? HomeShotMade : AwayShotMade;
                var shotAtt  = isHome ? HomeShotAtt  : AwayShotAtt;
                var ctxMade  = isHome ? HomeCtxMade  : AwayCtxMade;
                var ctxAtt   = isHome ? HomeCtxAtt   : AwayCtxAtt;

                shotMade[st]  = shotMade.GetValueOrDefault(st,  0L) + (isMade ? 1L : 0L);
                shotAtt[st]   = shotAtt.GetValueOrDefault(st,   0L) + 1L;
                ctxMade[ctx]  = ctxMade.GetValueOrDefault(ctx,  0L) + (isMade ? 1L : 0L);
                ctxAtt[ctx]   = ctxAtt.GetValueOrDefault(ctx,   0L) + 1L;
            }
        }

        public int    AwayWins    => Games - HomeWins;
        public double HomeWinPct  => (double)HomeWins / Games * 100;
        public double AwayWinPct  => (double)AwayWins / Games * 100;
        public double AvgHomePts  => (double)HomePts  / Games;
        public double AvgAwayPts  => (double)AwayPts  / Games;
        public double HomeFGPct   => HomeFGA > 0 ? (double)HomeFGM / HomeFGA : 0;
        public double AwayFGPct   => AwayFGA > 0 ? (double)AwayFGM / AwayFGA : 0;
        public double Home3Pct    => Home3A  > 0 ? (double)Home3M  / Home3A  : 0;
        public double Away3Pct    => Away3A  > 0 ? (double)Away3M  / Away3A  : 0;
        public double HomeFTPct   => HomeFTA > 0 ? (double)HomeFTM / HomeFTA : 0;
        public double AwayFTPct   => AwayFTA > 0 ? (double)AwayFTM / AwayFTA : 0;
        public double AvgHomeReb  => (double)HomeReb  / Games;
        public double AvgAwayReb  => (double)AwayReb  / Games;
        public double AvgHomeOReb => (double)HomeOReb / Games;
        public double AvgAwayOReb => (double)AwayOReb / Games;
        public double AvgHomeDReb => (double)HomeDReb / Games;
        public double AvgAwayDReb => (double)AwayDReb / Games;
        public double AvgHomeAst  => (double)HomeAst  / Games;
        public double AvgAwayAst  => (double)AwayAst  / Games;
        public double AvgHomeStl  => (double)HomeStl  / Games;
        public double AvgAwayStl  => (double)AwayStl  / Games;
        public double AvgHomeBlk  => (double)HomeBlk  / Games;
        public double AvgAwayBlk  => (double)AwayBlk  / Games;
        public double AvgHomeTo   => (double)HomeTo   / Games;
        public double AvgAwayTo   => (double)AwayTo   / Games;
    }
}
