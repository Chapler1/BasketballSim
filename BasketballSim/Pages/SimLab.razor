    protected override async Task OnInitializedAsync()
    {
        _espnTeams    = await EspnSvc.GetTeamsAsync();
        _teamsLoading = false;
    }

    private async Task OnTeamSelected(ChangeEventArgs e, string side)
    {
        var id = e.Value?.ToString();
        if (string.IsNullOrEmpty(id)) return;

        var team = _espnTeams.FirstOrDefault(t => t.Id == id);
        if (team == null) return;

        bool isHome = side == "home";
        if (isHome) { _homeRosterLoading = true; _homeLoadedTeam = null; }
        else        { _awayRosterLoading = true; _awayLoadedTeam = null; }
        StateHasChanged();

        var cache2k     = Nba2kSvc.GetPlayers();
        var lookup      = cache2k.ToDictionary(p => EspnTeamFactory.NormalizeName(p.Name), p => p);
        var espnPlayers = await EspnSvc.GetRosterAsync(id);
        string slot     = isHome ? "Home" : "Away";

        var configs = EspnTeamFactory.BuildRoster(espnPlayers, lookup, slot);

        if (isHome)
        {
            _homeConfigs         = configs;
            _homePace            = 100;
            _homeRotationDepth   = Math.Min(8, configs.Count);
            _homeLoadedTeam      = team;
            _homeRosterLoading   = false;
            if (team != null) _homeColor = team.PrimaryColor;
        }
        else
        {
            _awayConfigs         = configs;
            _awayPace            = 100;
            _awayRotationDepth   = Math.Min(8, configs.Count);
            _awayLoadedTeam      = team;
            _awayRosterLoading   = false;
            if (team != null) _awayColor = team.PrimaryColor;
        }

        _results = null;
    }

