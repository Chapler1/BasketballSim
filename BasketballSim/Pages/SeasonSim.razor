                                            <div style="font-size:0.68rem;color:#444;letter-spacing:1px;margin-bottom:3px;">1ST ROUND &#x2014; EAST</div>
                                            @foreach (var s in playoffResult.EastFirstRound) { @SeriesRow(s) }
                                        </div>
                                        <div>
                                            <div style="font-size:0.68rem;color:#444;letter-spacing:1px;margin-bottom:3px;">1ST ROUND &#x2014; WEST</div>
                                            @foreach (var s in playoffResult.WestFirstRound) { @SeriesRow(s) }
                                        </div>
                                    </div>
                                }
                                @if (playoffResult.EastSecondRound.Count > 0 || playoffResult.WestSecondRound.Count > 0)
                                {
                                    <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;margin-bottom:8px;">
                                        <div>
                                            <div style="font-size:0.68rem;color:#444;letter-spacing:1px;margin-bottom:3px;">2ND ROUND &#x2014; EAST</div>
                                            @foreach (var s in playoffResult.EastSecondRound) { @SeriesRow(s) }
                                        </div>
                                        <div>
                                            <div style="font-size:0.68rem;color:#444;letter-spacing:1px;margin-bottom:3px;">2ND ROUND &#x2014; WEST</div>
                                            @foreach (var s in playoffResult.WestSecondRound) { @SeriesRow(s) }
                                        </div>
                                    </div>
                                }
                                @if (playoffResult.EastConfFinals is not null || playoffResult.WestConfFinals is not null)
                                {
                                    <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;margin-bottom:8px;">
                                        <div>
                                            <div style="font-size:0.68rem;color:#444;letter-spacing:1px;margin-bottom:3px;">CONF FINALS &#x2014; EAST</div>
                                            @if (playoffResult.EastConfFinals is not null) { @SeriesRow(playoffResult.EastConfFinals) }
                                        </div>
                                        <div>
                                            <div style="font-size:0.68rem;color:#444;letter-spacing:1px;margin-bottom:3px;">CONF FINALS &#x2014; WEST</div>
                                            @if (playoffResult.WestConfFinals is not null) { @SeriesRow(playoffResult.WestConfFinals) }
                                        </div>
                                    </div>
                                }
                                @if (playoffResult.Finals is not null)
                                {
                                    <div>
                                        <div style="font-size:0.68rem;color:#fca;letter-spacing:1px;margin-bottom:3px;">NBA FINALS</div>
                                        @SeriesRow(playoffResult.Finals)
                                    </div>
                                }
                            </div>
                            }
                            @if (_awards is not null)
                            {
                                <div>
                                    <div class="section-title" style="margin-bottom:5px;">SEASON AWARDS</div>
                                    <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:1rem;margin-bottom:1rem;">
                                        @if (_awards.MVP    is not null) { @AwardCard("MOST VALUABLE PLAYER",    _awards.MVP,    "#fca",    "#0d0900", "#2a1800") }
                                        @if (_awards.DPOY   is not null) { @AwardCard("DEF. PLAYER OF THE YEAR", _awards.DPOY,   "#4af0c0", "#000d0d", "#001e1e") }
                                        @if (_awards.SixMOY is not null) { @AwardCard("6TH MAN OF THE YEAR",     _awards.SixMOY, "#b080ff", "#0a000d", "#1e0030") }
                                    </div>
                                    @{
                                        var allNbaRows = new (string Label, List<AwardWinner> Players)[]
                                        {
                                            ("ALL-NBA 1ST TEAM", _awards.AllNba1),
                                            ("ALL-NBA 2ND TEAM", _awards.AllNba2),
                                            ("ALL-NBA 3RD TEAM", _awards.AllNba3),
                                        };
                                        var allDefRows = new (string Label, List<AwardWinner> Players)[]
                                        {
                                            ("ALL-DEFENSE 1ST TEAM", _awards.AllDef1),
                                            ("ALL-DEFENSE 2ND TEAM", _awards.AllDef2),
                                        };
                                    }
                                    <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:1rem;margin-bottom:1rem;">
                                        @foreach (var (teamLabel, players) in allNbaRows)
                                        {
                                            <div>
                                                <div style="font-size:0.7rem;color:#445;letter-spacing:1px;margin-bottom:5px;border-bottom:1px solid #1a1a1a;padding-bottom:3px;">@teamLabel</div>
                                                @foreach (var p in players)
                                                {
                                                    <div style="display:flex;justify-content:space-between;padding:2px 0;font-size:0.84rem;">
                                                        <span style="color:#b8b8b8;">@p.Name</span>
                                                        <span style="color:#444;font-size:0.76rem;">@p.TeamAbbr</span>
                                                    </div>
                                                }
                                            </div>
                                        }
                                    </div>
                                    <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;">
                                        @foreach (var (teamLabel, players) in allDefRows)
                                        {
                                            <div>
                                                <div style="font-size:0.7rem;color:#345;letter-spacing:1px;margin-bottom:5px;border-bottom:1px solid #1a1a1a;padding-bottom:3px;">@teamLabel</div>
                                                @foreach (var p in players)
                                                {
                                                    <div style="display:flex;justify-content:space-between;padding:2px 0;font-size:0.84rem;">
                                                        <span style="color:#b0b8b0;">@p.Name</span>
                                                        <span style="color:#444;font-size:0.76rem;">@p.TeamAbbr</span>
                                                    </div>
                                                }
                                            </div>
                                        }
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>

        </div><!-- end main area -->

    </div><!-- end body -->

}
<!-- ═══ GAME LOG MODAL ═══ -->
@if (_gameLogTeam is not null && (_season is not null || _liveState is not null))
{
    var glTeam  = _gameLogTeam;
    var glGames = (_season?.Games ?? _liveState!.CompletedGames)
        .Where(g => g.HomeTeam == glTeam.TeamName || g.AwayTeam == glTeam.TeamName)
        .OrderBy(g => g.Date)
        .ToList();

    <div style="position:fixed;inset:0;background:rgba(0,0,0,0.82);z-index:1000;display:flex;align-items:center;justify-content:center;padding:1rem;"
         @onclick="() => _gameLogTeam = null">
        <div style="background:#141414;border:1px solid #2a2a2a;border-radius:6px;width:min(560px,95vw);max-height:90vh;display:flex;flex-direction:column;font-family:monospace;color:#d4d4d4;"
             @onclick:stopPropagation="true">

            <!-- Header -->
            <div style="display:flex;justify-content:space-between;align-items:center;padding:0.85rem 1.25rem;border-bottom:1px solid #1e1e1e;flex-shrink:0;">
                <div>
                    <span style="display:inline-block;width:9px;height:9px;border-radius:50%;background:@glTeam.PrimaryColor;margin-right:6px;vertical-align:middle;"></span>
                    <span style="font-size:1.1rem;font-weight:800;color:#e8e8e8;letter-spacing:1px;">@glTeam.TeamName</span>
                    <span style="color:#333;margin-left:8px;font-size:0.88rem;">@glTeam.Wins–@glTeam.Losses</span>
                </div>
                <button @onclick="() => _gameLogTeam = null" style="background:none;border:none;color:#444;font-size:1.3rem;cursor:pointer;line-height:1;padding:0;">✕</button>
            </div>

            <!-- Column headers -->
            <div style="display:grid;grid-template-columns:72px 22px 44px 1fr 36px;gap:0 6px;padding:5px 1.25rem 3px;border-bottom:1px solid #1e1e1e;flex-shrink:0;">
                <span style="font-size:0.75rem;color:#3a3a3a;letter-spacing:0.5px;">DATE</span>
                <span style="font-size:0.75rem;color:#3a3a3a;text-align:center;">H/A</span>
                <span style="font-size:0.75rem;color:#3a3a3a;text-align:center;">OPP</span>
                <span style="font-size:0.75rem;color:#3a3a3a;text-align:right;padding-right:4px;">SCORE</span>
                <span style="font-size:0.75rem;color:#3a3a3a;text-align:center;">W/L</span>
            </div>

            <!-- Scrollable game list -->
            <div style="overflow-y:auto;flex:1;padding:0 1.25rem 0.75rem;">
                @foreach (var g in glGames)
                {
                    bool isHome = g.HomeTeam == glTeam.TeamName;
                    bool won    = isHome ? g.HomeScore > g.AwayScore : g.AwayScore > g.HomeScore;
                    string oppAbbr = isHome ? g.AwayAbbr : g.HomeAbbr;
                    string scoreStr = isHome
                        ? $"{g.HomeScore}–{g.AwayScore}"
                        : $"{g.AwayScore}–{g.HomeScore}";

                    <div class="glog-row">
                        <span style="color:#555;font-size:0.82rem;">@g.Date.ToString("MMM d")</span>
                        <span style="text-align:center;font-size:0.78rem;color:@(isHome?"#60c8e8":"#888");">@(isHome?"H":"A")</span>
                        <span style="text-align:center;color:#888;font-size:0.85rem;">@oppAbbr</span>
                        <span style="text-align:right;padding-right:4px;color:@(won?"#c8c8c8":"#666");">@scoreStr</span>
                        <span style="text-align:center;" class="@(won?"glog-w":"glog-l")">@(won?"W":"L")</span>
                    </div>
                }
                @if (glGames.Count == 0)
                {
                    <div style="color:#333;text-align:center;padding:2rem 0;">No games recorded.</div>
                }
            </div>

            <!-- Footer -->
            <div style="padding:0.5rem 1.25rem;border-top:1px solid #1a1a1a;flex-shrink:0;display:flex;gap:1.5rem;font-size:0.8rem;color:#3a3a3a;">
                <span>Home: <span style="color:#555;">@glTeam.HomeWins–@glTeam.HomeLosses</span></span>
                <span>Away: <span style="color:#555;">@glTeam.AwayWins–@glTeam.AwayLosses</span></span>
                <span>Conf: <span style="color:#555;">@glTeam.ConfWins–@glTeam.ConfLosses</span></span>
                <span style="margin-left:auto;">@glGames.Count games</span>
            </div>
        </div>
    </div>
}

<!-- ═══ TICKER BOX SCORE MODAL ═══ -->
@if (_tickerBoxScore is not null)
{
    var tbs = _tickerBoxScore;
    bool thw = tbs.HomeScore > tbs.AwayScore;
    <div style="position:fixed;inset:0;background:rgba(0,0,0,0.82);z-index:1001;display:flex;align-items:center;justify-content:center;padding:1rem;"
         @onclick="() => _tickerBoxScore = null">
        <div style="background:#141414;border:1px solid #2a2a2a;border-radius:6px;width:min(380px,90vw);font-family:monospace;color:#d4d4d4;"
             @onclick:stopPropagation="true">
            <div style="display:flex;justify-content:space-between;align-items:center;padding:0.75rem 1rem;border-bottom:1px solid #1e1e1e;">
                <span style="font-size:0.7rem;color:#444;letter-spacing:1px;">@tbs.Date.ToString("dddd, MMMM d").ToUpper()</span>
                <button @onclick="() => _tickerBoxScore = null" style="background:none;border:none;color:#444;font-size:1.1rem;cursor:pointer;">✕</button>
            </div>
            <div style="padding:1.25rem 1.5rem;text-align:center;">
                <div style="display:flex;align-items:center;justify-content:center;gap:1.5rem;">
                    <div style="text-align:center;">
                        <img src="/logos/teams/@(LogoSlug(tbs.HomeTeam)).svg" style="width:48px;height:48px;object-fit:contain;display:block;margin:0 auto 4px;" onerror="this.style.display='none'" />
                        <div style="font-size:0.8rem;color:@(thw?"#e8e8e8":"#555");">@tbs.HomeAbbr</div>
                    </div>
                    <div>
                        <div style="font-size:2rem;font-weight:800;color:#e8e8e8;letter-spacing:2px;">
                            <span style="color:@(thw?"#4af080":"#888");">@tbs.HomeScore</span>
                            <span style="color:#222;font-size:1.2rem;"> – </span>
                            <span style="color:@(!thw?"#4af080":"#888");">@tbs.AwayScore</span>
                        </div>
                        <div style="font-size:0.68rem;color:#333;text-align:center;margin-top:2px;">FINAL</div>
                    </div>
                    <div style="text-align:center;">
                        <img src="/logos/teams/@(LogoSlug(tbs.AwayTeam)).svg" style="width:48px;height:48px;object-fit:contain;display:block;margin:0 auto 4px;" onerror="this.style.display='none'" />
                        <div style="font-size:0.8rem;color:@(!thw?"#e8e8e8":"#555");">@tbs.AwayAbbr</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

<!-- ═══ PLAYER DETAIL MODAL ═══ -->
@if (_detailPlayer is not null)
{
    <div style="position:fixed;inset:0;background:rgba(0,0,0,0.82);z-index:1000;display:flex;align-items:center;justify-content:center;padding:1rem;"
         @onclick="CloseModal">
        <div style="background:#141414;border:1px solid #2a2a2a;border-radius:6px;width:min(1060px,95vw);max-height:94vh;overflow-y:auto;font-family:monospace;color:#d4d4d4;"
             @onclick:stopPropagation="true">

            <!-- Header -->
            <div style="display:flex;justify-content:space-between;align-items:center;padding:0.85rem 1.25rem;border-bottom:1px solid #1e1e1e;gap:1rem;">
                <div style="flex:1;">
                    <div style="font-size:1.3rem;font-weight:800;color:#e8e8e8;letter-spacing:1px;">@_detailPlayer.Name</div>
                    <div style="font-size:0.88rem;color:#555;margin-top:2px;">
                        @_detailPlayer.Team
                        <span style="color:#2a2a2a;">&nbsp;·&nbsp;</span>@_detailPlayer.Position
                        @if (_detailRecord is not null)
                        {
                            <span style="color:#2a2a2a;">&nbsp;·&nbsp;</span><span>@_detailRecord.Height</span>
                            @if (_detailRecord.Positions.Count > 1)
                            {
                                <span style="color:#3a3a3a;">&nbsp;(@string.Join("/", _detailRecord.Positions))</span>
                            }
                        }
                    </div>
                </div>
                <button @onclick="CloseModal" style="background:none;border:none;color:#444;font-size:1.3rem;cursor:pointer;line-height:1;padding:0;">✕</button>
            </div>

            <!-- Tab bar -->
            <div style="display:flex;border-bottom:1px solid #1e1e1e;padding:0 1rem;">
                <button class="pdlg-tab @(_detailTab=="career"?"active":"")"   @onclick='() => _detailTab = "career"'>CAREER STATS</button>
                <button class="pdlg-tab @(_detailTab=="advanced"?"active":"")" @onclick='() => _detailTab = "advanced"'>ADVANCED STATS</button>
                @if (_detailRecord is not null)
                {
                    <button class="pdlg-tab @(_detailTab=="attrs"?"active":"")"  @onclick='() => _detailTab = "attrs"'>ATTRIBUTES</button>
                    <button class="pdlg-tab @(_detailTab=="tends"?"active":"")"  @onclick='() => _detailTab = "tends"'>TENDENCIES</button>
                }
                <button class="pdlg-tab @(_detailTab=="injuries"?"active":"")" @onclick='() => _detailTab = "injuries"'>INJURIES</button>
            </div>

            <div style="padding:0.85rem 1.25rem;">

            @if (_detailTab == "attrs" && _detailRecord is not null)
            {
                <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:0.75rem 1rem;">
                    @AttrGroup("PHYSICAL",  new[]{("Height","Height"),("Strength","Strength"),("Speed","Speed"),("Jumping","Jumping"),("Endurance","Endurance")})
                    @AttrGroup("SHOOTING",  new[]{("Inside","Inside"),("Dunks","Dunks"),("Free Throw","FreeThrow"),("Mid-Range","MidRange"),("3-Point","ThreePoint")})
                    @AttrGroup("SKILL",     new[]{("Off IQ","oBBIQ"),("Def IQ","dBBIQ"),("Hustle","Hustle"),("Dribbling","Dribbling"),("Passing","Passing"),("Off Reb","RebOff"),("Def Reb","RebDef")})
                    @AttrGroup("DEFENSE",   new[]{("Perim Def","PerimDef"),("Int Def","IntDef"),("Foul Tend","FoulTend")})
                </div>
            }
            else if (_detailTab == "tends" && _detailRecord is not null)
            {
                <div style="display:grid;grid-template-columns:1fr 1fr;gap:0.5rem 2rem;">
                    @TendGroup("OFFENSIVE", new[]{("Touches","Touches"),("Drive","Drive"),("3-Point","ThreePt"),("Mid-Range","MidRange"),("Post-Up","PostUp"),("Isolation","Iso"),("Pull-Up","PullUp"),("Cut","Cut"),("Off Rebound","OffReb")})
                    @TendGroup("DEFENSIVE", new[]{("Steal","Steal"),("Block","Block")})
                </div>
            }
            else if (_detailTab == "injuries")
            {
                var hist = _detailInjuryHistory;
                if (hist.Count == 0)
                {
                    <div style="color:#444;padding:1.5rem 0;font-size:0.9rem;">No injuries this season.</div>
                }
                else
                {
                    int totalMissed = hist.Sum(r => r.GamesMissed);
                    int permCount   = hist.Count(r => r.HadPermanentDebuff);
                    <div style="font-size:0.82rem;color:#555;margin-bottom:0.75rem;">
                        @hist.Count injur@(hist.Count == 1 ? "y" : "ies") &nbsp;·&nbsp; @totalMissed games missed
                        @if (permCount > 0) { <span style="color:#f06060;">&nbsp;·&nbsp; @permCount with permanent effects</span> }
                    </div>
                    <div class="scroll-x">
                    <table style="width:100%;font-size:0.85rem;border-collapse:collapse;">
                        <thead>
                            <tr style="border-bottom:1px solid #252525;">
                                <th style="color:#444;font-weight:600;text-align:left;padding:3px 8px 3px 0;white-space:nowrap;">DATE</th>
                                <th style="color:#444;font-weight:600;text-align:left;padding:3px 6px;">INJURY</th>
                                <th style="color:#444;font-weight:600;text-align:left;padding:3px 6px;">BODY PART</th>
                                <th style="color:#444;font-weight:600;text-align:center;padding:3px 6px;">GRD</th>
                                <th style="color:#444;font-weight:600;text-align:right;padding:3px 6px;">EST.</th>
                                <th style="color:#444;font-weight:600;text-align:right;padding:3px 6px;">ACTUAL</th>
                                <th style="color:#444;font-weight:600;text-align:right;padding:3px 6px;">MISSED</th>
                                <th style="color:#444;font-weight:600;text-align:left;padding:3px 6px;">PERM LOSS</th>
                            </tr>
                        </thead>
                        <tbody>
                        @foreach (var rec in hist.OrderByDescending(r => r.InjuredDate))
                        {
                            var gc = rec.Grade == 3 ? "#f06060" : rec.Grade == 2 ? "#fca" : "#88dd88";
                            var permStr = rec.PermanentPenalties?.Count > 0
                                ? string.Join(", ", rec.PermanentPenalties.Select(kv => $"{kv.Key} –{kv.Value}"))
                                : "—";
                            var actualStr = rec.ReturnedDate.HasValue ? $"{rec.ActualDays}d" : $"{rec.ActualDays}d*";
                            <tr style="border-bottom:1px solid #1a1a1a;">
                                <td style="color:#555;padding:3px 8px 3px 0;white-space:nowrap;">@rec.InjuredDate.ToString("MMM d")</td>
                                <td style="padding:3px 6px;">@rec.InjuryName</td>
                                <td style="color:#888;padding:3px 6px;">@rec.BodyPart</td>
                                <td style="text-align:center;color:@gc;font-weight:700;padding:3px 6px;">G@(rec.Grade)</td>
                                <td style="text-align:right;color:#666;padding:3px 6px;">@(rec.EstimatedDays)d</td>
                                <td style="text-align:right;color:#888;padding:3px 6px;">@actualStr</td>
                                <td style="text-align:right;color:#888;padding:3px 6px;">@rec.GamesMissed</td>
                                <td style="color:@(rec.HadPermanentDebuff?"#f06060":"#555");padding:3px 6px;">@permStr</td>
                            </tr>
                        }
                        </tbody>
                    </table>
                    @if (hist.Any(r => !r.ReturnedDate.HasValue))
                    {
                        <div style="font-size:0.75rem;color:#333;margin-top:4px;">* still injured at season end</div>
                    }
                    </div>
                }
            }
            else if (_detailTab == "career")
            {
                <div class="scroll-x">
                <table style="width:100%;font-size:0.88rem;border-collapse:collapse;">
                    <thead>
                        <tr style="border-bottom:1px solid #252525;">
                            <th style="color:#444;font-weight:600;text-align:left;padding:3px 8px 3px 0;white-space:nowrap;min-width:60px;">SEASON</th>
                            <th style="color:#3a3a3a;font-weight:400;text-align:left;padding:3px 6px;white-space:nowrap;">TEAM</th>
                            <th style="color:#555;font-weight:400;text-align:center;padding:3px 6px;">GP</th>
                            <th style="color:#555;font-weight:400;text-align:center;padding:3px 6px;">MIN</th>
                            <th style="color:#c8a840;font-weight:600;text-align:center;padding:3px 6px;">PTS</th>
                            <th style="color:#555;font-weight:400;text-align:center;padding:3px 6px;">REB</th>
                            <th style="color:#4aa8c0;font-weight:400;text-align:center;padding:3px 6px;">AST</th>
                            <th style="color:#70a860;font-weight:400;text-align:center;padding:3px 6px;">STL</th>
                            <th style="color:#b06040;font-weight:400;text-align:center;padding:3px 6px;">BLK</th>
                            <th style="color:#c04040;font-weight:400;text-align:center;padding:3px 6px;">TOV</th>
                            <th style="color:#555;font-weight:400;text-align:center;padding:3px 6px;">FGM</th>
                            <th style="color:#444;font-weight:400;text-align:center;padding:3px 6px;">FGA</th>
                            <th style="color:#555;font-weight:400;text-align:center;padding:3px 6px;">FG%</th>
                            <th style="color:#555;font-weight:400;text-align:center;padding:3px 6px;">3PM</th>
                            <th style="color:#444;font-weight:400;text-align:center;padding:3px 6px;">3PA</th>
                            <th style="color:#555;font-weight:400;text-align:center;padding:3px 6px;">3P%</th>
                            <th style="color:#555;font-weight:400;text-align:center;padding:3px 6px;">FTM</th>
                            <th style="color:#444;font-weight:400;text-align:center;padding:3px 6px;">FTA</th>
                            <th style="color:#555;font-weight:400;text-align:center;padding:3px 6px;">FT%</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var s in _careerHistory.OrderBy(s => s.Season))
                        {
                            <tr style="border-bottom:1px solid #181818;">
                                <td style="color:#777;padding:3px 8px 3px 0;font-size:0.83rem;">@s.Season</td>
                                <td style="color:#444;padding:3px 6px;font-size:0.82rem;">@s.Team</td>
                                <td style="text-align:center;padding:3px 6px;color:#555;">@s.Gp</td>
                                <td style="text-align:center;padding:3px 6px;color:#666;">@s.Min.ToString("F1")</td>
                                <td style="text-align:center;padding:3px 6px;color:#b89840;">@s.Pts.ToString("F1")</td>
                                <td style="text-align:center;padding:3px 6px;color:#999;">@s.Reb.ToString("F1")</td>
                                <td style="text-align:center;padding:3px 6px;color:#3a88a0;">@s.Ast.ToString("F1")</td>
                                <td style="text-align:center;padding:3px 6px;color:#608850;">@s.Stl.ToString("F1")</td>
                                <td style="text-align:center;padding:3px 6px;color:#905030;">@s.Blk.ToString("F1")</td>
                                <td style="text-align:center;padding:3px 6px;color:#a03030;">@s.Tov.ToString("F1")</td>
                                <td style="text-align:center;padding:3px 6px;color:#777;">@s.Fgm.ToString("F1")</td>
                                <td style="text-align:center;padding:3px 6px;color:#555;">@s.Fga.ToString("F1")</td>
                                <td style="text-align:center;padding:3px 6px;color:@FgPctColor(s.FgPct);">@s.FgPct.ToString("P1")</td>
                                <td style="text-align:center;padding:3px 6px;color:#777;">@s.Fg3m.ToString("F1")</td>
                                <td style="text-align:center;padding:3px 6px;color:#555;">@s.Fg3a.ToString("F1")</td>
                                <td style="text-align:center;padding:3px 6px;color:@TpPctColor(s.Fg3Pct);">@(s.Fg3a > 0 ? s.Fg3Pct.ToString("P1") : "—")</td>
                                <td style="text-align:center;padding:3px 6px;color:#777;">@s.Ftm.ToString("F1")</td>
                                <td style="text-align:center;padding:3px 6px;color:#555;">@s.Fta.ToString("F1")</td>
                                <td style="text-align:center;padding:3px 6px;color:@FtPctColor(s.FtPct);">@(s.Fta > 0 ? s.FtPct.ToString("P1") : "—")</td>
                            </tr>
                        }
                        <!-- Current sim season row -->
                        <tr style="background:#0d1218;border-top:1px solid #252525;">
                            <td style="color:#b8b8b8;padding:3px 8px 3px 0;font-size:0.83rem;font-weight:600;">2025-26</td>
                            <td style="color:#444;padding:3px 6px;font-size:0.82rem;">@_detailPlayer.TeamAbbr</td>
                            <td style="text-align:center;padding:3px 6px;color:#555;">@_detailPlayer.GP</td>
                            <td style="text-align:center;padding:3px 6px;color:#666;">@_detailPlayer.Mpg.ToString("F1")</td>
                            <td style="text-align:center;padding:3px 6px;color:#b89840;">@_detailPlayer.Ppg.ToString("F1")</td>
                            <td style="text-align:center;padding:3px 6px;color:#999;">@_detailPlayer.Rpg.ToString("F1")</td>
                            <td style="text-align:center;padding:3px 6px;color:#3a88a0;">@_detailPlayer.Apg.ToString("F1")</td>
                            <td style="text-align:center;padding:3px 6px;color:#608850;">@_detailPlayer.Spg.ToString("F1")</td>
                            <td style="text-align:center;padding:3px 6px;color:#905030;">@_detailPlayer.Bpg.ToString("F1")</td>
                            <td style="text-align:center;padding:3px 6px;color:#a03030;">@_detailPlayer.Topg.ToString("F1")</td>
                            <td style="text-align:center;padding:3px 6px;color:#777;">@_detailPlayer.Fgm.ToString("F1")</td>
                            <td style="text-align:center;padding:3px 6px;color:#555;">@_detailPlayer.Fga.ToString("F1")</td>
                            <td style="text-align:center;padding:3px 6px;color:@FgPctColor(_detailPlayer.FgPct);">@_detailPlayer.FgPct.ToString("P1")</td>
                            <td style="text-align:center;padding:3px 6px;color:#777;">@_detailPlayer.Tpm.ToString("F1")</td>
                            <td style="text-align:center;padding:3px 6px;color:#555;">@_detailPlayer.Tpa.ToString("F1")</td>
                            <td style="text-align:center;padding:3px 6px;color:@TpPctColor(_detailPlayer.TpPct);">@(_detailPlayer.TotalThreeAtt > 0 ? _detailPlayer.TpPct.ToString("P1") : "—")</td>
                            <td style="text-align:center;padding:3px 6px;color:#777;">@_detailPlayer.Ftm.ToString("F1")</td>
                            <td style="text-align:center;padding:3px 6px;color:#555;">@_detailPlayer.Fta.ToString("F1")</td>
                            <td style="text-align:center;padding:3px 6px;color:@FtPctColor(_detailPlayer.FtPct);">@(_detailPlayer.TotalFTA > 0 ? _detailPlayer.FtPct.ToString("P1") : "—")</td>
                        </tr>
                    </tbody>
                </table>
                </div>
                @if (_careerHistory.Count == 0)
                {
                    <div style="color:#2a2a2a;font-size:0.82rem;margin-top:6px;">No historical data · run <span style="color:#444;">BasketballSim/Scripts/pull_nba_stats.py</span> to populate</div>
                }
            }
            else if (_detailTab == "advanced")
            {
                <div class="scroll-x">
                <table style="width:100%;font-size:0.88rem;border-collapse:collapse;">
                    <thead>
                        <tr style="border-bottom:1px solid #252525;">
                            <th style="color:#444;font-weight:600;text-align:left;padding:3px 8px 3px 0;white-space:nowrap;min-width:60px;">SEASON</th>
                            <th style="color:#3a3a3a;font-weight:400;text-align:left;padding:3px 6px;white-space:nowrap;">TEAM</th>
                            <th style="color:#555;font-weight:400;text-align:center;padding:3px 6px;">TS%</th>
                            <th style="color:#555;font-weight:400;text-align:center;padding:3px 6px;">EFG%</th>
                            <th style="color:#555;font-weight:400;text-align:center;padding:3px 6px;">USG%</th>
                            <th style="color:#4aa8c0;font-weight:400;text-align:center;padding:3px 6px;">AST%</th>
                            <th style="color:#555;font-weight:400;text-align:center;padding:3px 6px;">OREB%</th>
                            <th style="color:#555;font-weight:400;text-align:center;padding:3px 6px;">DREB%</th>
                            <th style="color:#555;font-weight:400;text-align:center;padding:3px 6px;">REB%</th>
                            <th style="color:#70a860;font-weight:400;text-align:center;padding:3px 6px;">OFF RTG</th>
                            <th style="color:#c04040;font-weight:400;text-align:center;padding:3px 6px;">DEF RTG</th>
                            <th style="color:#c8a840;font-weight:600;text-align:center;padding:3px 6px;">NET RTG</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var s in _careerHistory.OrderBy(s => s.Season))
                        {
                            <tr style="border-bottom:1px solid #181818;">
                                <td style="color:#777;padding:3px 8px 3px 0;font-size:0.83rem;">@s.Season</td>
                                <td style="color:#444;padding:3px 6px;font-size:0.82rem;">@s.Team</td>
                                <td style="text-align:center;padding:3px 6px;color:#888;">@(s.TsPct.HasValue    ? s.TsPct.Value.ToString("P1")    : "—")</td>
                                <td style="text-align:center;padding:3px 6px;color:#888;">@(s.EfgPct.HasValue   ? s.EfgPct.Value.ToString("P1")   : "—")</td>
                                <td style="text-align:center;padding:3px 6px;color:#888;">@(s.UsgPct.HasValue   ? s.UsgPct.Value.ToString("P1")   : "—")</td>
                                <td style="text-align:center;padding:3px 6px;color:#3a88a0;">@(s.AstPct.HasValue   ? s.AstPct.Value.ToString("P1")   : "—")</td>
                                <td style="text-align:center;padding:3px 6px;color:#777;">@(s.OrebPct.HasValue  ? s.OrebPct.Value.ToString("P1")  : "—")</td>
                                <td style="text-align:center;padding:3px 6px;color:#777;">@(s.DrebPct.HasValue  ? s.DrebPct.Value.ToString("P1")  : "—")</td>
                                <td style="text-align:center;padding:3px 6px;color:#888;">@(s.RebPct.HasValue   ? s.RebPct.Value.ToString("P1")   : "—")</td>
                                <td style="text-align:center;padding:3px 6px;color:#608850;">@(s.OffRating.HasValue ? s.OffRating.Value.ToString("F1") : "—")</td>
                                <td style="text-align:center;padding:3px 6px;color:#a03030;">@(s.DefRating.HasValue ? s.DefRating.Value.ToString("F1") : "—")</td>
                                <td style="text-align:center;padding:3px 6px;color:@PmColor(s.NetRating ?? 0);">@(s.NetRating.HasValue ? s.NetRating.Value.ToString("+0.0;-0.0;0.0") : "—")</td>
                            </tr>
                        }
                        <!-- Sim season row -->
                        <tr style="background:#0d1218;border-top:1px solid #252525;">
                            <td style="color:#b8b8b8;padding:3px 8px 3px 0;font-size:0.83rem;font-weight:600;">2025-26</td>
                            <td style="color:#444;padding:3px 6px;font-size:0.82rem;">@_detailPlayer.TeamAbbr</td>
                            <td style="text-align:center;padding:3px 6px;color:#888;">@_detailPlayer.TsPct.ToString("P1")</td>
                            <td style="text-align:center;padding:3px 6px;color:#888;">@_detailPlayer.EfgPct.ToString("P1")</td>
                            <td style="text-align:center;padding:3px 6px;color:#888;">@_detailPlayer.UsgPct.ToString("P1")</td>
                            <td style="text-align:center;padding:3px 6px;color:#3a88a0;">@_detailPlayer.AstPct.ToString("P1")</td>
                            <td style="text-align:center;padding:3px 6px;color:#777;">@_detailPlayer.OrebPct.ToString("P1")</td>
                            <td style="text-align:center;padding:3px 6px;color:#777;">@_detailPlayer.DrebPct.ToString("P1")</td>
                            <td style="text-align:center;padding:3px 6px;color:#888;">@_detailPlayer.RebPct.ToString("P1")</td>
                            <td style="text-align:center;padding:3px 6px;color:#608850;">@_detailPlayer.OffRating.ToString("F1")</td>
                            <td style="text-align:center;padding:3px 6px;color:#a03030;">@_detailPlayer.DefRating.ToString("F1")</td>
                            <td style="text-align:center;padding:3px 6px;color:@PmColor(_detailPlayer.NetRating);">@_detailPlayer.NetRating.ToString("+0.0;-0.0;0.0")</td>
                        </tr>
                    </tbody>
                </table>
                </div>
                @if (_careerHistory.Count == 0)
                {
                    <div style="color:#2a2a2a;font-size:0.82rem;margin-top:6px;">No historical data · run <span style="color:#444;">BasketballSim/Scripts/pull_nba_stats.py</span> to populate</div>
                }
            }

            </div><!-- end padding div -->
        </div>
    </div>
}

<!-- ═══ SIM TO GAME POPUP ═══ -->
@if (_showWatchPopup && _simToGameTarget is not null && _liveState is not null)
{
    var sg  = _simToGameTarget;
    string sgHome     = _liveState.Teams.TryGetValue(sg.HomeTeamId, out var _sgh)  ? _sgh.Abbreviation  : "?";
    string sgAway     = _liveState.Teams.TryGetValue(sg.AwayTeamId, out var _sga)  ? _sga.Abbreviation  : "?";
    string sgHomeName = _liveState.Teams.TryGetValue(sg.HomeTeamId, out var _sghn) ? _sghn.Name : sg.HomeTeamId;
    string sgAwayName = _liveState.Teams.TryGetValue(sg.AwayTeamId, out var _sgan) ? _sgan.Name : sg.AwayTeamId;
    bool sgIsToday    = _liveState.CurrentDate.Date == sg.Date.Date;
    bool sgIsFuture   = _liveState.CurrentDate.Date < sg.Date.Date;
    <div style="position:fixed;inset:0;background:rgba(0,0,0,0.87);z-index:1500;display:flex;align-items:center;justify-content:center;padding:1rem;"
         @onclick="() => { _showWatchPopup = false; _simToGameTarget = null; }">
        <div style="background:#141414;border:1px solid #2a2a2a;border-radius:8px;width:min(400px,90vw);font-family:monospace;color:#d4d4d4;"
             @onclick:stopPropagation="true">
            <!-- Header -->
            <div style="display:flex;justify-content:space-between;align-items:center;padding:0.85rem 1.25rem 0.6rem;border-bottom:1px solid #1e1e1e;">
                <span style="font-size:0.7rem;color:#555;letter-spacing:2px;">@(sgIsToday ? "TODAY'S GAME" : "UPCOMING GAME")</span>
                <button @onclick="() => { _showWatchPopup = false; _simToGameTarget = null; }"
                        style="background:none;border:none;color:#444;font-size:1.1rem;cursor:pointer;padding:0;">✕</button>
            </div>
            <!-- Matchup -->
            <div style="padding:1.5rem;text-align:center;">
                <div style="font-size:0.68rem;color:#555;letter-spacing:1px;margin-bottom:1rem;">@sg.Date.ToString("dddd, MMMM d").ToUpper()</div>
                <div style="display:flex;align-items:center;justify-content:center;gap:2rem;margin-bottom:1.5rem;">
                    <div style="text-align:center;">
                        <img src="/logos/teams/@(LogoSlug(sgHomeName)).svg" style="width:54px;height:54px;object-fit:contain;display:block;margin:0 auto 6px;" onerror="this.style.display='none'" />
                        <div style="font-size:0.82rem;color:#888;letter-spacing:0.5px;">@sgHome</div>
                        <div style="font-size:0.6rem;color:#444;letter-spacing:1px;margin-top:2px;">HOME</div>
                    </div>
                    <div style="font-size:0.68rem;color:#333;letter-spacing:1px;">vs</div>
                    <div style="text-align:center;">
                        <img src="/logos/teams/@(LogoSlug(sgAwayName)).svg" style="width:54px;height:54px;object-fit:contain;display:block;margin:0 auto 6px;" onerror="this.style.display='none'" />
                        <div style="font-size:0.82rem;color:#888;letter-spacing:0.5px;">@sgAway</div>
                        <div style="font-size:0.6rem;color:#444;letter-spacing:1px;margin-top:2px;">AWAY</div>
                    </div>
                </div>
                <div style="display:flex;gap:0.75rem;justify-content:center;flex-wrap:wrap;">
                    @if (sgIsFuture)
                    {
                        <button @onclick="() => _ = SimToDayOnly(sg)"
                                disabled="@_simBusy"
                                style="background:#141414;color:@(_simBusy?"#333":"#888");border:1px solid #2a2a2a;padding:8px 20px;border-radius:5px;cursor:@(_simBusy?"default":"pointer");font-family:monospace;font-size:0.88rem;">
                            Sim to Day
                        </button>
                    }
                    <button @onclick="() => { _showWatchPopup = false; _ = SimToGame(sg); }"
                            disabled="@_simBusy"
                            style="background:#0d2a0d;color:@(_simBusy?"#333":"#4af080");border:1px solid #1a4a1a;padding:8px 28px;border-radius:5px;cursor:@(_simBusy?"default":"pointer");font-family:monospace;font-size:0.92rem;font-weight:700;">
                        ▶ Watch Game
                    </button>
                    <button @onclick="() => { _showWatchPopup = false; _simToGameTarget = null; }"
                            style="background:none;border:1px solid #1e1e1e;color:#555;padding:8px 18px;border-radius:5px;cursor:pointer;font-family:monospace;font-size:0.88rem;">
                        Cancel
                    </button>
                </div>
            </div>
        </div>
    </div>
}

<!-- ═══ BRACKET SERIES POPUP ═══ -->
@if (_bracketPopupSeries is not null && _livePlayoffs is not null)
{
    var bps = _bracketPopupSeries;
    int bGameNum = bps.Games.Count + 1;
    bool bHighHome = bGameNum is 1 or 2 or 5 or 7;
    string bHome = bHighHome ? bps.HighSeedAbbr : bps.LowSeedAbbr;
    string bAway = bHighHome ? bps.LowSeedAbbr  : bps.HighSeedAbbr;
    string bHomeName = bHighHome ? bps.HighSeedTeam : bps.LowSeedTeam;
    string bAwayName = bHighHome ? bps.LowSeedTeam  : bps.HighSeedTeam;
    <div style="position:fixed;inset:0;background:rgba(0,0,0,0.87);z-index:1500;display:flex;align-items:center;justify-content:center;padding:1rem;"
         @onclick="() => _bracketPopupSeries = null">
        <div style="background:#141414;border:1px solid #2a2a2a;border-radius:8px;width:min(380px,92vw);font-family:monospace;color:#d4d4d4;"
             @onclick:stopPropagation="true">
            <div style="display:flex;justify-content:space-between;align-items:center;padding:0.85rem 1.25rem 0.6rem;border-bottom:1px solid #1e1e1e;">
                @{
                    string bSeriesStatus = bps.HighSeedWins == bps.LowSeedWins
                        ? $"TIED {bps.HighSeedWins}-{bps.LowSeedWins}"
                        : bps.HighSeedWins > bps.LowSeedWins
                            ? $"{bps.HighSeedAbbr} LEADS {bps.HighSeedWins}-{bps.LowSeedWins}"
                            : $"{bps.LowSeedAbbr} LEADS {bps.LowSeedWins}-{bps.HighSeedWins}";
                }
                <span style="font-size:0.65rem;color:#555;letter-spacing:2px;">GAME @bGameNum · @bSeriesStatus</span>
                <button @onclick="() => _bracketPopupSeries = null" style="background:none;border:none;color:#444;font-size:1.1rem;cursor:pointer;padding:0;">✕</button>
            </div>
            <div style="padding:1.25rem;text-align:center;">
                <div style="display:flex;align-items:center;justify-content:center;gap:2rem;margin-bottom:1.5rem;">
                    <div style="text-align:center;">
                        <img src="/logos/teams/@(LogoSlug(bHomeName)).svg" style="width:48px;height:48px;object-fit:contain;display:block;margin:0 auto 5px;" onerror="this.style.display='none'" />
                        <div style="font-size:0.78rem;color:#888;">@bHome</div>
                        <div style="font-size:0.55rem;color:#444;letter-spacing:1px;">HOME</div>
                    </div>
                    <div style="font-size:0.65rem;color:#333;letter-spacing:1px;">vs</div>
                    <div style="text-align:center;">
                        <img src="/logos/teams/@(LogoSlug(bAwayName)).svg" style="width:48px;height:48px;object-fit:contain;display:block;margin:0 auto 5px;" onerror="this.style.display='none'" />
                        <div style="font-size:0.78rem;color:#888;">@bAway</div>
                        <div style="font-size:0.55rem;color:#444;letter-spacing:1px;">AWAY</div>
                    </div>
                </div>
                <div style="display:flex;gap:0.6rem;justify-content:center;flex-wrap:wrap;">
                    <button @onclick="() => _ = PlayoffWatchGame(bps)"
                            disabled="@_simBusy"
                            style="background:#0d2a0d;color:@(_simBusy?"#333":"#4af080");border:1px solid #1a4a1a;padding:7px 20px;border-radius:5px;cursor:@(_simBusy?"default":"pointer");font-family:monospace;font-size:0.88rem;font-weight:700;">
                        ▶ Watch Game
                    </button>
                    <button @onclick="() => _ = PlayoffSimNextGame(bps)"
                            disabled="@_simBusy"
                            style="background:#141414;color:@(_simBusy?"#333":"#888");border:1px solid #2a2a2a;padding:7px 16px;border-radius:5px;cursor:@(_simBusy?"default":"pointer");font-family:monospace;font-size:0.85rem;">
                        Sim Game
                    </button>
                    <button @onclick="() => _ = PlayoffSimRound(bps)"
                            disabled="@_simBusy"
                            style="background:#141414;color:@(_simBusy?"#333":"#666");border:1px solid #222;padding:7px 16px;border-radius:5px;cursor:@(_simBusy?"default":"pointer");font-family:monospace;font-size:0.85rem;">
                        Sim Round
                    </button>
                    <button @onclick="() => _bracketPopupSeries = null"
                            style="background:none;border:1px solid #1e1e1e;color:#444;padding:7px 14px;border-radius:5px;cursor:pointer;font-family:monospace;font-size:0.82rem;">
                        Cancel
                    </button>
                </div>
            </div>
        </div>
    </div>
}

<!-- ═══ WATCH GAME MODAL ═══ -->
@if (_watchGame is not null)
{
    var wg = _watchGame;
    string wHomeAbbr = _liveState?.Teams.TryGetValue(wg.HomeTeam.Name, out var _wht) == true ? _wht.Abbreviation : wg.HomeTeam.Abbreviation;
    string wAwayAbbr = _liveState?.Teams.TryGetValue(wg.AwayTeam.Name, out var _wat) == true ? _wat.Abbreviation : wg.AwayTeam.Abbreviation;
    bool wAwayWins   = _watchDone && wg.FinalAwayScore > wg.FinalHomeScore;
    bool wHomeWins   = _watchDone && wg.FinalHomeScore > wg.FinalAwayScore;

    <!-- backdrop -->
    <div style="position:fixed;inset:0;background:rgba(0,0,0,0.78);z-index:2000;display:flex;align-items:center;justify-content:center;" @onclick="CloseWatchModal">
    <!-- popup window -->
    <div style="width:min(1360px,97vw);height:min(760px,94vh);background:#111;border-radius:8px;border:1px solid #282828;display:flex;flex-direction:column;font-family:monospace;color:#c8c8c8;overflow:hidden;" @onclick:stopPropagation="true">

        <!-- ══ SCOREBOARD ══ -->
        <div style="background:#0d0d0d;border-bottom:2px solid #1e1e1e;flex-shrink:0;position:relative;padding:0.85rem 2.5rem 0.75rem;">

            <!-- Close -->
            <button @onclick="CloseWatchModal"
                    style="position:absolute;top:10px;right:14px;background:none;border:none;color:#555;font-size:1.3rem;cursor:pointer;line-height:1;padding:4px;">✕</button>

            <!-- Score row -->
            <div style="display:flex;align-items:center;justify-content:center;gap:0;">

                <!-- Away team -->
                <div style="flex:1;display:flex;flex-direction:column;align-items:center;gap:4px;opacity:@(_watchDone&&!wAwayWins?"0.30":"1");">
                    <img src="/logos/teams/@(LogoSlug(wg.AwayTeam.Name)).svg"
                         style="width:40px;height:40px;object-fit:contain;" onerror="this.style.display='none'" />
                    <div style="font-size:0.82rem;font-weight:700;color:@(wAwayWins?"#e8e8e8":"#888");letter-spacing:1px;">@wAwayAbbr</div>
                    <div style="font-size:2.8rem;font-weight:900;line-height:1;color:@(wAwayWins?"#4af080":"#c8c8c8");">@_watchAwayScore</div>
                    @if (wAwayWins) { <div style="font-size:0.6rem;color:#4af080;letter-spacing:2px;font-weight:700;">WINNER</div> }
                </div>

                <!-- Center: quarter + clock + controls -->
                <div style="min-width:160px;text-align:center;display:flex;flex-direction:column;align-items:center;gap:3px;">
                    <div style="font-size:0.68rem;color:#555;letter-spacing:2px;">@WatchQuarterLabel()</div>
                    <div style="font-size:1.5rem;font-weight:700;color:@(_watchDone?"#4af080":"#777");letter-spacing:1px;">@WatchClockLabel()</div>
                    @if (!_watchStarted)
                    {
                        <div style="margin-top:6px;">
                            <button @onclick="() => _ = StartWatchGame()"
                                    style="background:#0d2a0d;color:#4af080;border:1px solid #1a4a1a;padding:7px 22px;border-radius:4px;cursor:pointer;font-family:monospace;font-size:0.88rem;font-weight:700;letter-spacing:1px;">
                                ▶ START GAME
                            </button>
                        </div>
                    }
                    @if (_watchStarted && !_watchDone)
                    {
                        <div style="margin-top:4px;">
                            <button @onclick="ToggleWatchPause"
                                    style="background:none;border:1px solid #333;color:#aaa;padding:4px 16px;border-radius:4px;cursor:pointer;font-family:monospace;font-size:0.82rem;min-width:50px;">
                                @(_watchPaused ? "▶" : "⏸")
                            </button>
                        </div>
                    }
                    @if (!_watchDone)
                    {
                        <div style="display:flex;align-items:center;gap:5px;margin-top:4px;">
                            <span style="font-size:0.58rem;color:#3a3a3a;">SLOW</span>
                            <input type="range" min="0" max="800" step="50"
                                   value="@(800 - _watchDelayMs)"
                                   @oninput="@((e) => { _watchDelayMs = 800 - int.Parse(e.Value?.ToString() ?? "400"); })"
                                   style="width:110px;accent-color:#fca;cursor:pointer;" />
                            <span style="font-size:0.58rem;color:#3a3a3a;">FAST</span>
                        </div>
                    }
                </div>

                <!-- Home team -->
                <div style="flex:1;display:flex;flex-direction:column;align-items:center;gap:4px;opacity:@(_watchDone&&!wHomeWins?"0.30":"1");">
                    <img src="/logos/teams/@(LogoSlug(wg.HomeTeam.Name)).svg"
                         style="width:40px;height:40px;object-fit:contain;" onerror="this.style.display='none'" />
                    <div style="font-size:0.82rem;font-weight:700;color:@(wHomeWins?"#e8e8e8":"#888");letter-spacing:1px;">@wHomeAbbr</div>
                    <div style="font-size:2.8rem;font-weight:900;line-height:1;color:@(wHomeWins?"#4af080":"#c8c8c8");">@_watchHomeScore</div>
                    @if (wHomeWins) { <div style="font-size:0.6rem;color:#4af080;letter-spacing:2px;font-weight:700;">WINNER</div> }
                </div>

            </div>
        </div>

        <!-- ══ GAME LOG (small, auto-scroll) ══ -->
        <div style="background:#0e0e0e;border-bottom:1px solid #1a1a1a;height:154px;flex-shrink:0;display:flex;flex-direction:column;">
            <div style="font-size:0.6rem;color:#3a3a3a;letter-spacing:1.5px;padding:4px 1rem 3px;border-bottom:1px solid #141414;flex-shrink:0;">PLAY BY PLAY</div>
            <div style="flex:1;overflow-y:auto;display:flex;flex-direction:column-reverse;padding:0 0.5rem;">
                @if (!_watchStarted)
                {
                    <div style="color:#2a2a2a;font-size:0.8rem;padding:8px 8px;font-style:italic;">Press Start Game to begin.</div>
                }
                @foreach (var poss in ((IEnumerable<PossessionResult>)_watchPossessions).Reverse())
                {
                    bool wIsScore = poss.PointsScored > 0;
                    bool wIsTov   = poss.Event is PossessionEvent.TurnoverStolen or PossessionEvent.TurnoverDeadBall;
                    bool wIsFoul  = poss.Event == PossessionEvent.FreeThrows;
                    string wTextColor = wIsScore ? "#d4d4d4" : wIsTov ? "#d07070" : wIsFoul ? "#7090cc" : "#666";
                    string wScoreStr  = $"{poss.AwayScore}–{poss.HomeScore}";
                    <div style="display:flex;align-items:baseline;gap:0;padding:3px 6px;border-bottom:1px solid #111;font-size:0.8rem;">
                        <span style="color:#444;font-size:0.68rem;white-space:nowrap;min-width:76px;">@WatchQtrStr(poss.Quarter) @FormatClock(poss.ClockSeconds)</span>
                        <span style="color:#3a3a3a;font-size:0.68rem;min-width:52px;text-align:right;padding-right:8px;">@wScoreStr</span>
                        <span style="color:@wTextColor;flex:1;">@poss.Narrative</span>
                    </div>
                }
            </div>
        </div>

        <!-- ══ BOX SCORE ══ -->
        <div style="flex:1;display:flex;flex-direction:column;overflow:hidden;min-height:0;">

            <!-- Tabs -->
            <div style="display:flex;border-bottom:1px solid #1a1a1a;flex-shrink:0;background:#0d0d0d;padding:0 0.5rem;">
                <button class="wm-tab @(_watchBoxTab=="players"?"active":"")" @onclick='() => _watchBoxTab = "players"'>PLAYER STATS</button>
                <button class="wm-tab @(_watchBoxTab=="teams"?"active":"")"   @onclick='() => _watchBoxTab = "teams"'>TEAM STATS</button>
            </div>

            <!-- ── PLAYER STATS TAB ── -->
            @if (_watchBoxTab == "players")
            {
                <div style="flex:1;display:grid;grid-template-columns:1fr 1fr;overflow:hidden;min-height:0;">
                @foreach (var (side, sideAbbr, sideLineup) in new[]{
                    (wg.HomeTeam, wHomeAbbr, _watchHomeLineup),
                    (wg.AwayTeam, wAwayAbbr, _watchAwayLineup)})
                {
                    var allStats  = _watchStats.Values.Where(p => p.Team == side.Name).ToList();
                    var statNames = allStats.Select(p => p.Name).ToHashSet();
                    var dnp = side.Roster.Where(r => !statNames.Contains(r.Name)).OrderBy(r => r.Position).ToList();
                    bool isSideHome = side.Name == wg.HomeTeam.Name;
                    <div style="display:flex;flex-direction:column;overflow:hidden;border-right:@(isSideHome?"1px solid #1a1a1a":"none");">
                        <!-- Team header -->
                        <div style="display:flex;align-items:center;gap:8px;padding:5px 10px;background:#0a0a0a;border-bottom:1px solid #1a1a1a;flex-shrink:0;">
                            <img src="/logos/teams/@(LogoSlug(side.Name)).svg" style="width:16px;height:16px;object-fit:contain;" onerror="this.style.display='none'" />
                            <span style="font-size:0.85rem;font-weight:700;color:#c8c8c8;">@sideAbbr</span>
                        </div>
                        <!-- Stats table -->
                        <div style="flex:1;overflow-y:auto;overflow-x:auto;">
                        <table style="font-size:0.78rem;border-collapse:collapse;width:100%;min-width:500px;">
                            <thead style="position:sticky;top:0;background:#0d0d0d;z-index:1;">
                                <tr style="border-bottom:1px solid #1a1a1a;">
                                    <th style="text-align:left;padding:4px 6px 4px 10px;color:#555;font-weight:500;min-width:105px;">PLAYER</th>
                                    <th style="text-align:center;color:#555;font-weight:500;width:34px;" title="Minutes">MIN</th>
                                    <th style="text-align:center;color:#c8a040;font-weight:600;width:28px;" title="Points">PTS</th>
                                    <th style="text-align:center;color:#555;font-weight:500;width:28px;" title="Rebounds">REB</th>
                                    <th style="text-align:center;color:#60b8d8;font-weight:500;width:28px;" title="Assists">AST</th>
                                    <th style="text-align:center;color:#555;font-weight:500;width:48px;" title="Field Goals">FG</th>
                                    <th style="text-align:center;color:#555;font-weight:500;width:44px;" title="Three Pointers">3PT</th>
                                    <th style="text-align:center;color:#555;font-weight:500;width:40px;" title="Free Throws">FT</th>
                                    <th style="text-align:center;color:#88cc88;font-weight:500;width:28px;" title="Steals">STL</th>
                                    <th style="text-align:center;color:#cc9860;font-weight:500;width:28px;" title="Blocks">BLK</th>
                                    <th style="text-align:center;color:#888;font-weight:500;width:32px;" title="Plus/Minus">+/-</th>
                                </tr>
                            </thead>
                            <tbody>
                            @if (_watchDone)
                            {
                                <!-- Post-game: all players sorted by minutes played -->
                                var sorted = allStats.OrderByDescending(p => p.MinSec).ToList();
                                @foreach (var st in sorted)
                                {
                                    string pn = st.Name.Contains(' ') ? st.Name[(st.Name.LastIndexOf(' ')+1)..] : st.Name;
                                    <tr class="wm-player-row wm-bench">
                                        <td style="color:#c8c8c8;padding:4px 6px 4px 10px;"><span style="font-size:0.6rem;color:#555;margin-right:4px;">@st.Pos</span>@pn</td>
                                        <td style="text-align:center;color:#888;">@st.MinutesPlayed.ToString("F0")</td>
                                        <td style="text-align:center;color:#e8c060;font-weight:700;">@st.Pts</td>
                                        <td style="text-align:center;color:#c8c8c8;">@st.Reb</td>
                                        <td style="text-align:center;color:#60b8d8;">@st.Ast</td>
                                        <td style="text-align:center;color:#c8c8c8;">@st.FGDisplay</td>
                                        <td style="text-align:center;color:#c8c8c8;">@st.ThreeDisplay</td>
                                        <td style="text-align:center;color:#c8c8c8;">@st.FtDisplay</td>
                                        <td style="text-align:center;color:#88cc88;">@st.Stl</td>
                                        <td style="text-align:center;color:#cc9860;">@st.Blk</td>
                                        <td style="text-align:center;color:@PmColor(st.PlusMinus);">@st.PlusMinus.ToString("+0;-0;0")</td>
                                    </tr>
                                }
                                @if (dnp.Count > 0)
                                {
                                    <tr><td colspan="11" class="wm-team-hdr" style="color:#2a2a2a;">DNP</td></tr>
                                    @foreach (var dp in dnp)
                                    {
                                        string dpn = dp.Name.Contains(' ') ? dp.Name[(dp.Name.LastIndexOf(' ')+1)..] : dp.Name;
                                        <tr class="wm-player-row wm-bench">
                                            <td style="color:#383838;padding:4px 6px 4px 10px;"><span style="font-size:0.6rem;color:#2a2a2a;margin-right:4px;">@dp.Position</span>@dpn</td>
                                            <td colspan="10" style="text-align:center;color:#222;font-size:0.7rem;letter-spacing:1px;">DNP</td>
                                        </tr>
                                    }
                                }
                            }
                            else
                            {
                                <!-- During game: ON COURT / BENCH / DNP sections -->
                                var onCourt = allStats.Where(p => sideLineup.Contains(p.Name)).OrderByDescending(p => p.Pts).ToList();
                                var benchSt = allStats.Where(p => !sideLineup.Contains(p.Name)).OrderByDescending(p => p.MinSec).ToList();
                                @if (onCourt.Count > 0)
                                {
                                    <tr><td colspan="11" class="wm-team-hdr">ON COURT</td></tr>
                                    @foreach (var st in onCourt)
                                    {
                                        string pn = st.Name.Contains(' ') ? st.Name[(st.Name.LastIndexOf(' ')+1)..] : st.Name;
                                        <tr class="wm-player-row wm-oncourt">
                                            <td style="color:#e8e8e8;font-weight:600;padding:4px 6px 4px 10px;"><span style="font-size:0.6rem;color:#555;margin-right:4px;">@st.Pos</span>@pn</td>
                                            <td style="text-align:center;color:#888;">@st.MinutesPlayed.ToString("F0")</td>
                                            <td style="text-align:center;color:#e8c060;font-weight:700;">@st.Pts</td>
                                            <td style="text-align:center;color:#c8c8c8;">@st.Reb</td>
                                            <td style="text-align:center;color:#60b8d8;">@st.Ast</td>
                                            <td style="text-align:center;color:#c8c8c8;">@st.FGDisplay</td>
                                            <td style="text-align:center;color:#c8c8c8;">@st.ThreeDisplay</td>
                                            <td style="text-align:center;color:#c8c8c8;">@st.FtDisplay</td>
                                            <td style="text-align:center;color:#88cc88;">@st.Stl</td>
                                            <td style="text-align:center;color:#cc9860;">@st.Blk</td>
                                            <td style="text-align:center;color:@PmColor(st.PlusMinus);">@st.PlusMinus.ToString("+0;-0;0")</td>
                                        </tr>
                                    }
                                }
                                @if (benchSt.Count > 0)
                                {
                                    <tr><td colspan="11" class="wm-team-hdr">BENCH</td></tr>
                                    @foreach (var st in benchSt)
                                    {
                                        string pn = st.Name.Contains(' ') ? st.Name[(st.Name.LastIndexOf(' ')+1)..] : st.Name;
                                        <tr class="wm-player-row wm-bench">
                                            <td style="color:#aaa;padding:4px 6px 4px 10px;"><span style="font-size:0.6rem;color:#3a3a3a;margin-right:4px;">@st.Pos</span>@pn</td>
                                            <td style="text-align:center;color:#666;">@st.MinutesPlayed.ToString("F0")</td>
                                            <td style="text-align:center;color:#c8a040;font-weight:600;">@st.Pts</td>
                                            <td style="text-align:center;color:#888;">@st.Reb</td>
                                            <td style="text-align:center;color:#4a98b8;">@st.Ast</td>
                                            <td style="text-align:center;color:#888;">@st.FGDisplay</td>
                                            <td style="text-align:center;color:#888;">@st.ThreeDisplay</td>
                                            <td style="text-align:center;color:#888;">@st.FtDisplay</td>
                                            <td style="text-align:center;color:#68a868;">@st.Stl</td>
                                            <td style="text-align:center;color:#a87848;">@st.Blk</td>
                                            <td style="text-align:center;color:@PmColor(st.PlusMinus);">@st.PlusMinus.ToString("+0;-0;0")</td>
                                        </tr>
                                    }
                                }
                                @if (dnp.Count > 0)
                                {
                                    <tr><td colspan="11" class="wm-team-hdr" style="color:#2a2a2a;">DNP</td></tr>
                                    @foreach (var dp in dnp)
                                    {
                                        string dpn = dp.Name.Contains(' ') ? dp.Name[(dp.Name.LastIndexOf(' ')+1)..] : dp.Name;
                                        <tr class="wm-player-row wm-bench">
                                            <td style="color:#383838;padding:4px 6px 4px 10px;"><span style="font-size:0.6rem;color:#2a2a2a;margin-right:4px;">@dp.Position</span>@dpn</td>
                                            <td colspan="10" style="text-align:center;color:#222;font-size:0.7rem;letter-spacing:1px;">DNP</td>
                                        </tr>
                                    }
                                }
                                @if (allStats.Count == 0 && dnp.Count == 0)
                                {
                                    <tr><td colspan="11" style="text-align:center;color:#333;padding:1.5rem;">No stats yet.</td></tr>
                                }
                            }
                            </tbody>
                        </table>
                        </div>
                    </div>
                }
                </div>
            }

            @{
                int tsHomePts   = WatchTeamStat(wg, wg.HomeTeam.Name, p => p.Points);
                int tsAwayPts   = WatchTeamStat(wg, wg.AwayTeam.Name, p => p.Points);
                int tsHomeFGM   = WatchTeamStat(wg, wg.HomeTeam.Name, p => p.FGMade);
                int tsHomeFGA   = WatchTeamStat(wg, wg.HomeTeam.Name, p => p.FGAttempts);
                int tsAwayFGM   = WatchTeamStat(wg, wg.AwayTeam.Name, p => p.FGMade);
                int tsAwayFGA   = WatchTeamStat(wg, wg.AwayTeam.Name, p => p.FGAttempts);
                int tsHome3PM   = WatchTeamStat(wg, wg.HomeTeam.Name, p => p.ThreeMade);
                int tsHome3PA   = WatchTeamStat(wg, wg.HomeTeam.Name, p => p.ThreeAttempts);
                int tsAway3PM   = WatchTeamStat(wg, wg.AwayTeam.Name, p => p.ThreeMade);
                int tsAway3PA   = WatchTeamStat(wg, wg.AwayTeam.Name, p => p.ThreeAttempts);
                int tsHomeFTM   = WatchTeamStat(wg, wg.HomeTeam.Name, p => p.FTMade);
                int tsHomeFTA   = WatchTeamStat(wg, wg.HomeTeam.Name, p => p.FTAttempts);
                int tsAwayFTM   = WatchTeamStat(wg, wg.AwayTeam.Name, p => p.FTMade);
                int tsAwayFTA   = WatchTeamStat(wg, wg.AwayTeam.Name, p => p.FTAttempts);
                int tsHomeREB   = WatchTeamStat(wg, wg.HomeTeam.Name, p => p.OffRebounds + p.DefRebounds);
                int tsAwayREB   = WatchTeamStat(wg, wg.AwayTeam.Name, p => p.OffRebounds + p.DefRebounds);
                int tsHomeOREB  = WatchTeamStat(wg, wg.HomeTeam.Name, p => p.OffRebounds);
                int tsAwayOREB  = WatchTeamStat(wg, wg.AwayTeam.Name, p => p.OffRebounds);
                int tsHomeDREB  = WatchTeamStat(wg, wg.HomeTeam.Name, p => p.DefRebounds);
                int tsAwayDREB  = WatchTeamStat(wg, wg.AwayTeam.Name, p => p.DefRebounds);
                int tsHomeAST   = WatchTeamStat(wg, wg.HomeTeam.Name, p => p.Assists);
                int tsAwayAST   = WatchTeamStat(wg, wg.AwayTeam.Name, p => p.Assists);
                int tsHomeSTL   = WatchTeamStat(wg, wg.HomeTeam.Name, p => p.Steals);
                int tsAwaySTL   = WatchTeamStat(wg, wg.AwayTeam.Name, p => p.Steals);
                int tsHomeBLK   = WatchTeamStat(wg, wg.HomeTeam.Name, p => p.Blocks);
                int tsAwayBLK   = WatchTeamStat(wg, wg.AwayTeam.Name, p => p.Blocks);
                int tsHomeTOV   = WatchTeamStat(wg, wg.HomeTeam.Name, p => p.Turnovers);
                int tsAwayTOV   = WatchTeamStat(wg, wg.AwayTeam.Name, p => p.Turnovers);
                int tsHomeFOUL  = WatchTeamStat(wg, wg.HomeTeam.Name, p => p.Fouls);
                int tsAwayFOUL  = WatchTeamStat(wg, wg.AwayTeam.Name, p => p.Fouls);
                double tsFGHome = tsHomeFGA > 0 ? (double)tsHomeFGM / tsHomeFGA : 0;
                double tsFGAway = tsAwayFGA > 0 ? (double)tsAwayFGM / tsAwayFGA : 0;
                double ts3Home  = tsHome3PA > 0 ? (double)tsHome3PM / tsHome3PA : 0;
                double ts3Away  = tsAway3PA > 0 ? (double)tsAway3PM / tsAway3PA : 0;
                double tsFTHome = tsHomeFTA > 0 ? (double)tsHomeFTM / tsHomeFTA : 0;
                double tsFTAway = tsAwayFTA > 0 ? (double)tsAwayFTM / tsAwayFTA : 0;
            }

            <!-- ── TEAM STATS TAB ── -->
            @if (_watchBoxTab == "teams")
            {
                <div style="flex:1;overflow-y:auto;padding:1rem 2rem;">
                <table style="font-size:0.88rem;border-collapse:collapse;width:100%;max-width:520px;margin:0 auto;">
                    <thead>
                        <tr style="border-bottom:1px solid #1e1e1e;">
                            <th style="text-align:left;padding:6px 12px 6px 0;color:#444;font-weight:400;min-width:160px;"></th>
                            <th style="text-align:center;padding:6px 16px;min-width:120px;">
                                <div style="display:flex;align-items:center;justify-content:center;gap:6px;">
                                    <img src="/logos/teams/@(LogoSlug(wg.HomeTeam.Name)).svg" style="width:18px;height:18px;object-fit:contain;" onerror="this.style.display='none'" />
                                    <span style="font-size:0.9rem;font-weight:700;color:@(wHomeWins?"#c8c8c8":"#888");">@wHomeAbbr</span>
                                </div>
                            </th>
                            <th style="text-align:center;padding:6px 16px;min-width:120px;">
                                <div style="display:flex;align-items:center;justify-content:center;gap:6px;">
                                    <img src="/logos/teams/@(LogoSlug(wg.AwayTeam.Name)).svg" style="width:18px;height:18px;object-fit:contain;" onerror="this.style.display='none'" />
                                    <span style="font-size:0.9rem;font-weight:700;color:@(wAwayWins?"#c8c8c8":"#888");">@wAwayAbbr</span>
                                </div>
                            </th>
                        </tr>
                    </thead>
                    <tbody>
                    @{
                        RenderFragment TsRow(string label, string homeVal, string awayVal, bool homeHigher, bool awayHigher) =>
                            @<tr style="border-bottom:1px solid #141414;">
                                <td style="padding:7px 12px 7px 0;color:#666;">@label</td>
                                <td style="text-align:center;padding:7px 16px;color:@(homeHigher?"#c8c8c8":"#888");font-weight:@(homeHigher?"700":"400");">@homeVal</td>
                                <td style="text-align:center;padding:7px 16px;color:@(awayHigher?"#c8c8c8":"#888");font-weight:@(awayHigher?"700":"400");">@awayVal</td>
                            </tr>;
                    }
                    @TsRow("Points",         $"{tsHomePts}",                    $"{tsAwayPts}",                    tsHomePts > tsAwayPts,   tsAwayPts > tsHomePts)
                    @TsRow("FG",             $"{tsHomeFGM}/{tsHomeFGA} ({tsFGHome:P1})", $"{tsAwayFGM}/{tsAwayFGA} ({tsFGAway:P1})", tsFGHome > tsFGAway, tsFGAway > tsFGHome)
                    @TsRow("3-Point",        $"{tsHome3PM}/{tsHome3PA} ({ts3Home:P1})",  $"{tsAway3PM}/{tsAway3PA} ({ts3Away:P1})",  ts3Home > ts3Away,   ts3Away > ts3Home)
                    @TsRow("Free Throws",    $"{tsHomeFTM}/{tsHomeFTA} ({tsFTHome:P1})", $"{tsAwayFTM}/{tsAwayFTA} ({tsFTAway:P1})", tsFTHome > tsFTAway, tsFTAway > tsFTHome)
                    @TsRow("Rebounds",       $"{tsHomeREB}",                    $"{tsAwayREB}",                    tsHomeREB > tsAwayREB,   tsAwayREB > tsHomeREB)
                    @TsRow("Off Rebounds",   $"{tsHomeOREB}",                   $"{tsAwayOREB}",                   tsHomeOREB > tsAwayOREB, tsAwayOREB > tsHomeOREB)
                    @TsRow("Def Rebounds",   $"{tsHomeDREB}",                   $"{tsAwayDREB}",                   tsHomeDREB > tsAwayDREB, tsAwayDREB > tsHomeDREB)
                    @TsRow("Assists",        $"{tsHomeAST}",                    $"{tsAwayAST}",                    tsHomeAST > tsAwayAST,   tsAwayAST > tsHomeAST)
                    @TsRow("Steals",         $"{tsHomeSTL}",                    $"{tsAwaySTL}",                    tsHomeSTL > tsAwaySTL,   tsAwaySTL > tsHomeSTL)
                    @TsRow("Blocks",         $"{tsHomeBLK}",                    $"{tsAwayBLK}",                    tsHomeBLK > tsAwayBLK,   tsAwayBLK > tsHomeBLK)
                    @TsRow("Turnovers",      $"{tsHomeTOV}",                    $"{tsAwayTOV}",                    tsHomeTOV < tsAwayTOV,   tsAwayTOV < tsHomeTOV)
                    @TsRow("Fouls",          $"{tsHomeFOUL}",                   $"{tsAwayFOUL}",                   tsHomeFOUL < tsAwayFOUL, tsAwayFOUL < tsHomeFOUL)
                    </tbody>
                </table>
                </div>
            }

        </div>

        <!-- ══ FOOTER (game over) ══ -->
        @if (_watchDone)
        {
            <div style="padding:0.5rem 1.25rem;border-top:1px solid #1a1a1a;display:flex;align-items:center;gap:1rem;background:#0a0a0a;flex-shrink:0;">
                <span style="font-size:0.8rem;color:#4af080;font-weight:700;">FINAL — @(wAwayWins ? wAwayAbbr : wHomeAbbr) WIN  @wg.FinalAwayScore–@wg.FinalHomeScore</span>
                <span style="flex:1;"></span>
                <button @onclick="CloseWatchModal" style="background:#1a1a2a;border:1px solid #2a2a4a;color:#8ab8ff;padding:5px 24px;border-radius:4px;cursor:pointer;font-family:monospace;font-size:0.85rem;">Done</button>
            </div>
        }

    </div>
    </div>
}

<!-- ═══ HOW IT WORKS MODAL ═══ -->
@if (_showHowItWorks)
{
    <div style="position:fixed;inset:0;background:rgba(0,0,0,0.88);z-index:2000;display:flex;align-items:flex-start;justify-content:center;padding:1.5rem 1rem;overflow-y:auto;"
         @onclick="() => _showHowItWorks = false">
        <div style="background:#111;border:1px solid #2a2a2a;border-radius:8px;width:min(740px,96vw);font-family:monospace;color:#d4d4d4;margin:auto;"
             @onclick:stopPropagation="true">

            <!-- Header -->
            <div style="display:flex;justify-content:space-between;align-items:center;padding:1rem 1.25rem;border-bottom:1px solid #1e1e1e;">
                <div>
                    <span style="font-size:1.15rem;font-weight:800;color:#e8e8e8;letter-spacing:2px;">HOW THE SIM WORKS</span>
                    <span style="color:#333;font-size:0.78rem;margin-left:10px;">click any section to expand</span>
                </div>
                <button @onclick="() => _showHowItWorks = false"
                        style="background:none;border:none;color:#444;font-size:1.3rem;cursor:pointer;line-height:1;padding:0;">✕</button>
            </div>

            <!-- Sections -->
            <div style="padding:1rem 1.25rem;">

                <!-- 1. Overview -->
                <div class="hiw-section">
                    <button class="hiw-header" @onclick='() => HiwToggle("overview")'>
                        <span>OVERVIEW</span><span style="color:#333;font-size:0.9rem;">@(HiwOpen("overview")?"▲":"▼")</span>
                    </button>
                    @if (HiwOpen("overview"))
                    {
                        <div class="hiw-body">
                            <p><strong>BasketballSim</strong> is a possession-by-possession NBA simulator. Every game plays out one possession at a time — the engine generates a shot menu, selects the best available option, resolves the outcome, then moves to the next possession.</p>
                            <p>Stats are calibrated to <strong>NBA 2023-24 league averages</strong>. A full 82-game season takes about 2–3 seconds to simulate.</p>
                            <div class="kv"><span class="kv-label">Target pace</span><span class="kv-val">~103 possessions / team / game</span></div>
                            <div class="kv"><span class="kv-label">Avg game score</span><span class="kv-val">~114 pts / team</span></div>
                            <div class="kv"><span class="kv-label">Rating scale</span><span class="kv-val">5 (worst in NBA) → 50 (league avg) → 95 (best)</span></div>
                            <div class="kv"><span class="kv-label">Roster source</span><span class="kv-val">ESPN rosters with NBA 2K attribute mapping</span></div>
                        </div>
                    }
                </div>

                <!-- 2. Player Attributes -->
                <div class="hiw-section">
                    <button class="hiw-header" @onclick='() => HiwToggle("attrs")'>
                        <span>PLAYER ATTRIBUTES</span><span style="color:#333;font-size:0.9rem;">@(HiwOpen("attrs")?"▲":"▼")</span>
                    </button>
                    @if (HiwOpen("attrs"))
                    {
                        <div class="hiw-body">
                            <p>Each player has <strong>19 attributes</strong> on a 5–95 scale, derived from NBA 2K ratings and remapped to our sim scale.</p>
                            <div style="display:grid;grid-template-columns:1fr 1fr;gap:0.5rem 1.5rem;margin-top:6px;">
                                <div>
                                    <div style="color:#555;font-size:0.76rem;letter-spacing:1px;margin-bottom:4px;">PHYSICAL</div>
                                    @HiwChips("Height","Strength","Speed","Jumping","Endurance")
                                    <div style="color:#555;font-size:0.76rem;letter-spacing:1px;margin:8px 0 4px;">SHOOTING</div>
                                    @HiwChips("Inside","Dunks","Free Throw","Mid-Range","3-Point")
                                </div>
                                <div>
                                    <div style="color:#555;font-size:0.76rem;letter-spacing:1px;margin-bottom:4px;">SKILL</div>
                                    @HiwChips("Off IQ","Def IQ","Hustle","Dribbling","Passing","Off Reb","Def Reb")
                                    <div style="color:#555;font-size:0.76rem;letter-spacing:1px;margin:8px 0 4px;">DEFENSE</div>
                                    @HiwChips("Perimeter Def","Interior Def")
                                </div>
                            </div>
                            <p style="margin-top:8px;">Players also have a <strong>Foul Tendency</strong> and separate <strong>fatigue/injury ratings</strong> not shown in the UI. Attributes drive shooting formulas, block/steal/rebound weights, and turnover rates directly — no hidden scalars.</p>
                        </div>
                    }
                </div>

                <!-- 3. Shot Generation -->
                <div class="hiw-section">
                    <button class="hiw-header" @onclick='() => HiwToggle("shots")'>
                        <span>SHOT GENERATION</span><span style="color:#333;font-size:0.9rem;">@(HiwOpen("shots")?"▲":"▼")</span>
                    </button>
                    @if (HiwOpen("shots"))
                    {
                        <div class="hiw-body">
                            <p>Every half-court possession, the engine builds a <strong>shot menu</strong> — a list of (ShotContext, ShotType, probability) entries for the ball-handler.</p>
                            <p><strong>Shot contexts</strong> include:</p>
                            <div style="margin:4px 0 8px;">
                                <div style="color:#555;font-size:0.76rem;letter-spacing:1px;margin-bottom:3px;">INSIDE</div>
                                @HiwChips("DrivingLayup","FloaterLayup","AlleyOop","CutDunk","CutLayup","PostMove","PickAndRollRoll","PickAndRollDunk","TransitionDunk","ContactDunk","PutbackLayup","TipIn")
                                <div style="color:#555;font-size:0.76rem;letter-spacing:1px;margin:6px 0 3px;">MID-RANGE</div>
                                @HiwChips("IsolationMidRange","FadeawayMidRange","PullUpMidRange","PickAndRollMidRange","PostMoveMidRange","LateClockMidRange")
                                <div style="color:#555;font-size:0.76rem;letter-spacing:1px;margin:6px 0 3px;">THREE-POINT</div>
                                @HiwChips("CatchAndShootCorner","CatchAndShootWing","PullUpThree","StepBackThree","PickAndRollThree","TransitionThree")
                            </div>
                            <p>Each entry has a <strong>perceived PPS</strong> (points per shot) score. The engine selects the highest-PPS option that clears its <strong>threshold</strong> (a minimum quality bar). If nothing clears the threshold, the ball is passed or dribbled until a better opportunity appears.</p>
                            <div class="kv"><span class="kv-label">PPS compression</span><span class="kv-val">actual = 0.95 + (raw – 0.95) × 0.52</span></div>
                            <div class="kv"><span class="kv-label">Thresholds</span><span class="kv-val">&gt;20s left=1.32 · &gt;15=1.09 · &gt;10=0.87 · &gt;5=0.60 · &gt;2=0.35</span></div>
                            <div class="kv"><span class="kv-label">Pass time</span><span class="kv-val">Gaussian(1.5s, 1.0s) — each pass grows the clock</span></div>
                        </div>
                    }
                </div>

                <!-- 4. Shot Tendencies -->
                <div class="hiw-section">
                    <button class="hiw-header" @onclick='() => HiwToggle("tends")'>
                        <span>SHOT TENDENCIES</span><span style="color:#333;font-size:0.9rem;">@(HiwOpen("tends")?"▲":"▼")</span>
                    </button>
                    @if (HiwOpen("tends"))
                    {
                        <div class="hiw-body">
                            <p>Tendencies shape <em>how</em> a player gets their shots — not how many. They are split into two categories:</p>
                            <p><strong>Appearance tendencies</strong> (normalized budget pool) — control which shot contexts appear in the menu. The four pool types compete for a fixed total probability:</p>
                            <div class="kv"><span class="kv-label">Drive</span><span class="kv-val">DrivingLayup, FloaterLayup, PickAndRoll contexts</span></div>
                            <div class="kv"><span class="kv-label">Cut</span><span class="kv-val">AlleyOop, CutDunk, CutLayup</span></div>
                            <div class="kv"><span class="kv-label">Post</span><span class="kv-val">PostMove, PostMoveMidRange</span></div>
                            <div class="kv"><span class="kv-label">Iso</span><span class="kv-val">IsolationMidRange, FadeawayMidRange</span></div>
                            <p style="margin-top:6px;">A player with Drive=80, Cut=20 sees far more drive opportunities, but the total shot volume stays constant — tendencies redistribute, they don't inflate.</p>
                            <p><strong>Threshold tendencies</strong> — lower the quality bar needed to pull the trigger:</p>
                            <div class="kv"><span class="kv-label">ThreePt</span><span class="kv-val">willingness to shoot 3s (CaS, PnR3, Transition3)</span></div>
                            <div class="kv"><span class="kv-label">MidRange</span><span class="kv-val">willingness to shoot mid-range pull-ups</span></div>
                            <div class="kv"><span class="kv-label">PullUp</span><span class="kv-val">willingness to pull up off the dribble</span></div>
                            <p style="margin-top:6px;color:#555;font-size:0.82rem;">Example: Mitchell Robinson has near-zero ThreePt and high Cut — he almost never attempts a 3 and gets most of his shots from cuts and alley-oops.</p>
                        </div>
                    }
                </div>

                <!-- 5. Shooting Formulas -->
                <div class="hiw-section">
                    <button class="hiw-header" @onclick='() => HiwToggle("formulas")'>
                        <span>SHOOTING FORMULAS</span><span style="color:#333;font-size:0.9rem;">@(HiwOpen("formulas")?"▲":"▼")</span>
                    </button>
                    @if (HiwOpen("formulas"))
                    {
                        <div class="hiw-body">
                            <p>Base make percentages scale linearly with the relevant attribute:</p>
                            <div class="kv"><span class="kv-label">Inside</span><span class="kv-val">0.59 + (Inside/100 × 0.22) — at avg: 70%</span></div>
                            <div class="kv"><span class="kv-label">Mid-Range</span><span class="kv-val">0.43 + (MidRange/100 × 0.17) — at avg: 51.5%</span></div>
                            <div class="kv"><span class="kv-label">3-Point</span><span class="kv-val">0.315 + (ThreePoint/100 × 0.20) — at avg: 41.5%</span></div>
                            <div class="kv"><span class="kv-label">Free Throw</span><span class="kv-val">cubic curve: 0.36 + 0.88x − 0.24x² (clamped)</span></div>
                            <div class="kv"><span class="kv-label">Dunk</span><span class="kv-val">0.75 + (Dunks+Jumping)/200 × 0.20</span></div>
                            <p style="margin-top:8px;">Each shot is then reduced by a <strong>ContestPenalty</strong> — how hard the defender contests:</p>
                            <div class="kv"><span class="kv-label">Inside contest</span><span class="kv-val">driven by IntDef + Height of nearest defender</span></div>
                            <div class="kv"><span class="kv-label">Mid contest</span><span class="kv-val">blend of IntDef (40%) + PerimDef (60%)</span></div>
                            <div class="kv"><span class="kv-label">3PT contest</span><span class="kv-val">driven by PerimDef</span></div>
                            <p style="margin-top:6px;">All formulas include an <strong>Efficiency Factor</strong> (EF) that varies by physical/mental state (fatigue, injury).</p>
                        </div>
                    }
                </div>

                <!-- 6. Defensive Focus -->
                <div class="hiw-section">
                    <button class="hiw-header" @onclick='() => HiwToggle("focus")'>
                        <span>DEFENSIVE FOCUS SYSTEM</span><span style="color:#333;font-size:0.9rem;">@(HiwOpen("focus")?"▲":"▼")</span>
                    </button>
                    @if (HiwOpen("focus"))
                    {
                        <div class="hiw-body">
                            <p>Teams concentrate defensive attention on the biggest offensive threats. A <strong>focusMult</strong> is computed for each offensive player on every possession and applied in three places:</p>
                            <div class="kv"><span class="kv-label">Menu generation</span><span class="kv-val">fewer shots clear the PPS threshold (clamped ≥ 1.0)</span></div>
                            <div class="kv"><span class="kv-label">Contest penalty</span><span class="kv-val">contestPenalty × focusMult — harder contest</span></div>
                            <div class="kv"><span class="kv-label">Make %</span><span class="kv-val">adjMake × (1 − (focusMult−1) × 0.30)</span></div>
                            <p style="margin-top:8px;"><strong>How focus is calculated:</strong> each player's threat score (avg of 3PT + Mid + Inside + Dribbling + OffIQ) is normalized against the 5 players on court. A star surrounded by bench players draws much higher focus than a star next to other stars.</p>
                            <div class="kv"><span class="kv-label">Coach influence</span><span class="kv-val">HelpDefenseAmount (38–78) per team, set in CoachFactory</span></div>
                            <div class="kv"><span class="kv-label">Jensen's inequality</span><span class="kv-val">sum(focusMult) ≤ n — over-focusing one player helps others</span></div>
                        </div>
                    }
                </div>

                <!-- 7. Fatigue & Rotation -->
                <div class="hiw-section">
                    <button class="hiw-header" @onclick='() => HiwToggle("fatigue")'>
                        <span>FATIGUE &amp; ROTATION</span><span style="color:#333;font-size:0.9rem;">@(HiwOpen("fatigue")?"▲":"▼")</span>
                    </button>
                    @if (HiwOpen("fatigue"))
                    {
                        <div class="hiw-body">
                            <p>Each player has a <strong>fatigue score</strong> (0–100, starting at 100). Playing minutes drains fatigue; rest days between games restore it. Fatigue reduces shooting efficiency, passing accuracy, and physical attribute effectiveness.</p>
                            <div class="kv"><span class="kv-label">Drain rate</span><span class="kv-val">based on minutes played and Endurance rating</span></div>
                            <div class="kv"><span class="kv-label">Recovery rate</span><span class="kv-val">per rest-day between games, scales with Endurance</span></div>
                            <div class="kv"><span class="kv-label">Rotation depth</span><span class="kv-val">RotationManager assigns ~8 players per game (5 starters + bench)</span></div>
                            <p style="margin-top:8px;">The <strong>RotationManager</strong> builds lineups based on coach style, player overall, and fatigue. Back-to-backs and short rest scenarios cause fatigue accumulation over the season — Endurance rating directly determines durability.</p>
                            <div class="kv"><span class="kv-label">Each team's coach</span><span class="kv-val">has OffensiveStyle (Pace&amp;Space, Motion, Iso-Heavy, etc.)</span></div>
                            <div class="kv"><span class="kv-label">Coach style affects</span><span class="kv-val">dribble isoMult, drive tendency weights, pace</span></div>
                        </div>
                    }
                </div>

                <!-- 8. Injuries -->
                <div class="hiw-section">
                    <button class="hiw-header" @onclick='() => HiwToggle("injuries")'>
                        <span>INJURIES</span><span style="color:#333;font-size:0.9rem;">@(HiwOpen("injuries")?"▲":"▼")</span>
                    </button>
                    @if (HiwOpen("injuries"))
                    {
                        <div class="hiw-body">
                            <p>Injuries occur in-game based on contact plays and player injury susceptibility. Each injury has a <strong>grade</strong>:</p>
                            <div class="kv"><span class="kv-label">Grade 1 (Q)</span><span class="kv-val">questionable — player may play through it (chance-based)</span></div>
                            <div class="kv"><span class="kv-label">Grade 2 (OUT)</span><span class="kv-val">out — misses games, DNP until recovered</span></div>
                            <div class="kv"><span class="kv-label">Grade 3 (OUT)</span><span class="kv-val">severe — extended absence, higher permanent debuff risk</span></div>
                            <p style="margin-top:8px;"><strong>Injury history is tracked</strong> per player through the season. Some injuries apply <strong>permanent rating debuffs</strong> (e.g. "ankle −3 Speed") that persist across possessions and future games.</p>
                            <div class="kv"><span class="kv-label">Recovery ticks</span><span class="kv-val">once per rest day between games</span></div>
                            <div class="kv"><span class="kv-label">Play-through (G1)</span><span class="kv-val">probability depends on player rank + injury severity</span></div>
                            <div class="kv"><span class="kv-label">Perm debuff roll</span><span class="kv-val">runs when a Grade 2+ injury resolves</span></div>
                        </div>
                    }
                </div>

                <!-- 9. Season & Schedule -->
                <div class="hiw-section">
                    <button class="hiw-header" @onclick='() => HiwToggle("schedule")'>
                        <span>SEASON &amp; SCHEDULE</span><span style="color:#333;font-size:0.9rem;">@(HiwOpen("schedule")?"▲":"▼")</span>
                    </button>
                    @if (HiwOpen("schedule"))
                    {
                        <div class="hiw-body">
                            <p>The full 82-game schedule is generated upfront using a <strong>circulant algorithm</strong> that guarantees exactly 82 games, 41 home, 41 away per team across all 30 teams (1,230 total games).</p>
                            <p>Games are then mapped to real NBA calendar dates (October → April) with realistic back-to-back and rest-day distributions. Rest days for each game are pre-computed and fed to fatigue/recovery math.</p>
                            <div class="kv"><span class="kv-label">Live Season mode</span><span class="kv-val">sim one day at a time or auto-sim with a pause button</span></div>
                            <div class="kv"><span class="kv-label">Instant Sim mode</span><span class="kv-val">simulates all 1,230 games in one shot (~2-3 sec)</span></div>
                            <div class="kv"><span class="kv-label">Standings</span><span class="kv-val">W/L, PCT, GB, conf/div splits — updated live</span></div>
                            <div class="kv"><span class="kv-label">Player stats</span><span class="kv-val">per-game averages aggregated after each game</span></div>
                        </div>
                    }
                </div>

                <!-- 10. Playoffs -->
                <div class="hiw-section">
                    <button class="hiw-header" @onclick='() => HiwToggle("playoffs")'>
                        <span>PLAYOFFS &amp; AWARDS</span><span style="color:#333;font-size:0.9rem;">@(HiwOpen("playoffs")?"▲":"▼")</span>
                    </button>
                    @if (HiwOpen("playoffs"))
                    {
                        <div class="hiw-body">
                            <p>After the regular season you can simulate the full NBA Playoffs, including the <strong>Play-In Tournament</strong> (seeds 7–10 in each conference).</p>
                            <div class="kv"><span class="kv-label">Format</span><span class="kv-val">Play-In → First Round → Semis → Conf Finals → NBA Finals</span></div>
                            <div class="kv"><span class="kv-label">Series length</span><span class="kv-val">best-of-7 for all rounds (best-of-5 for play-in)</span></div>
                            <div class="kv"><span class="kv-label">Home court</span><span class="kv-val">higher seed hosts games 1, 2, 5, 7</span></div>
                            <p style="margin-top:8px;"><strong>Season Awards</strong> are computed from regular-season stats:</p>
                            <div class="kv"><span class="kv-label">MVP</span><span class="kv-val">weighted PTS + AST + REB + WS-proxy + team wins</span></div>
                            <div class="kv"><span class="kv-label">DPOY</span><span class="kv-val">STL + BLK + DefRating + IntDef/PerimDef attributes</span></div>
                            <div class="kv"><span class="kv-label">6MOY</span><span class="kv-val">best bench contributor (GP with low starter rate)</span></div>
                            <div class="kv"><span class="kv-label">All-NBA / All-Def</span><span class="kv-val">position-balanced selection from top performers</span></div>
                        </div>
                    }
                </div>

                <!-- 11. Stats & Advanced Metrics -->
                <div class="hiw-section">
                    <button class="hiw-header" @onclick='() => HiwToggle("stats")'>
                        <span>STATS &amp; ADVANCED METRICS</span><span style="color:#333;font-size:0.9rem;">@(HiwOpen("stats")?"▲":"▼")</span>
                    </button>
                    @if (HiwOpen("stats"))
                    {
                        <div class="hiw-body">
                            <p>Box score stats are tracked possession-by-possession. Advanced metrics are derived from the raw counts:</p>
                            <div class="kv"><span class="kv-label">TS%</span><span class="kv-val">True Shooting % — efficiency accounting for FTs</span></div>
                            <div class="kv"><span class="kv-label">eFG%</span><span class="kv-val">Effective FG% — weights 3-pointers at 1.5×</span></div>
                            <div class="kv"><span class="kv-label">USG%</span><span class="kv-val">% of team possessions used while on court</span></div>
                            <div class="kv"><span class="kv-label">AST%</span><span class="kv-val">% of teammate FGM assisted while on court</span></div>
                            <div class="kv"><span class="kv-label">OREB% / DREB%</span><span class="kv-val">rebounding rate vs available opportunities</span></div>
                            <div class="kv"><span class="kv-label">OFF/DEF/NET RTG</span><span class="kv-val">points scored/allowed per 100 possessions on court</span></div>
                            <div class="kv"><span class="kv-label">+/−</span><span class="kv-val">point differential while the player is on the court</span></div>
                            <p style="margin-top:8px;">Click any player row in the standings or stats table to open their <strong>player card</strong> with full career history, attributes, tendencies, and injury log.</p>
                        </div>
                    }
                </div>

            </div><!-- /sections -->

            <div style="padding:0.6rem 1.25rem 1rem;border-top:1px solid #191919;display:flex;justify-content:flex-end;">
                <button @onclick="() => _showHowItWorks = false"
                        style="background:#1a1a1a;border:1px solid #2a2a2a;color:#555;padding:5px 20px;border-radius:4px;cursor:pointer;font-family:monospace;font-size:0.85rem;">
                    Close
                </button>
            </div>
        </div>
    </div>
}

</div>

@code {
    private enum Phase { NeedFetch, Fetching, Syncing, Ready, LiveSeason, Simulating, Done, Playoffs }

    // ── Live season state ─────────────────────────────────────────────────────
    private SeasonScheduleService.LiveSeasonState? _liveState;
    private bool                                   _isAutoSimming;
    private string                                 _selectedTeam = "";
    private string                                 _topTab       = "standings";
    private string                                 _statsTab      = "players";
    private string                                 _playerStatsView = "standard";
    private int                                    _calMonth     = 10;
    private int                                    _calYear      = 2025;
    private SeasonGameRecord?                      _tickerBoxScore;

    // ── Logo helper ───────────────────────────────────────────────────────────
    private static string LogoSlug(string teamName) =>
        teamName.ToLowerInvariant().Replace(' ', '-');

    private record CalGame(string OppAbbr, string OppFullName, bool IsHome, bool IsPast, bool Won, int MyScore, int OppScore, ScheduledGame? ScheduledGameRef);

    private CalGame? GetFollowedGameOnDate(DateOnly date, string followedTeam, bool live)
    {
        if (followedTeam.Length == 0) return null;
        if (live && _liveState is not null)
        {
            var currentDate = DateOnly.FromDateTime(_liveState.CurrentDate < DateTime.MaxValue ? _liveState.CurrentDate : DateTime.Now);
            if (date < currentDate)
            {
                var rec = _liveState.CompletedGames.FirstOrDefault(g =>
                    DateOnly.FromDateTime(g.Date) == date &&
                    (g.HomeTeam.Equals(followedTeam, StringComparison.OrdinalIgnoreCase) ||
                     g.AwayTeam.Equals(followedTeam, StringComparison.OrdinalIgnoreCase)));
                if (rec is null) return null;
                bool isHome = rec.HomeTeam.Equals(followedTeam, StringComparison.OrdinalIgnoreCase);
                bool won = isHome ? rec.HomeScore > rec.AwayScore : rec.AwayScore > rec.HomeScore;
                return new CalGame(isHome ? rec.AwayAbbr : rec.HomeAbbr, isHome ? rec.AwayTeam : rec.HomeTeam,
                    isHome, true, won, isHome ? rec.HomeScore : rec.AwayScore, isHome ? rec.AwayScore : rec.HomeScore, null);
            }
            else
            {
                var sg = _liveState.Schedule.FirstOrDefault(g =>
                    DateOnly.FromDateTime(g.Date) == date &&
                    (g.HomeTeamId.Equals(followedTeam, StringComparison.OrdinalIgnoreCase) ||
                     g.AwayTeamId.Equals(followedTeam, StringComparison.OrdinalIgnoreCase)));
                if (sg is null) return null;
                bool isHome = sg.HomeTeamId.Equals(followedTeam, StringComparison.OrdinalIgnoreCase);
                string oppId   = isHome ? sg.AwayTeamId : sg.HomeTeamId;
                string oppAbbr = _liveState.Teams.TryGetValue(oppId, out var oppTeam) ? oppTeam.Abbreviation : "?";
                return new CalGame(oppAbbr, oppId, isHome, false, false, 0, 0, sg);
            }
        }
        else if (_season is not null)
        {
            var rec = _season.Games.FirstOrDefault(g =>
                DateOnly.FromDateTime(g.Date) == date &&
                (g.HomeTeam.Equals(followedTeam, StringComparison.OrdinalIgnoreCase) ||
                 g.AwayTeam.Equals(followedTeam, StringComparison.OrdinalIgnoreCase)));
            if (rec is null) return null;
            bool isHome = rec.HomeTeam.Equals(followedTeam, StringComparison.OrdinalIgnoreCase);
            bool won = isHome ? rec.HomeScore > rec.AwayScore : rec.AwayScore > rec.HomeScore;
            return new CalGame(isHome ? rec.AwayAbbr : rec.HomeAbbr, isHome ? rec.AwayTeam : rec.HomeTeam,
                isHome, true, won, isHome ? rec.HomeScore : rec.AwayScore, isHome ? rec.AwayScore : rec.HomeScore, null);
        }
        return null;
    }

    private void SyncCalendarToCurrentDate()
    {
        if (_liveState is null) return;
        var d = _liveState.CurrentDate;
        if (d < DateTime.MaxValue && d.Year >= 2025)
        {
            _calMonth = d.Month;
            _calYear  = d.Year;
        }
    }

    private void PrevCalMonth()
    {
        _calMonth--;
        if (_calMonth < 1) { _calMonth = 12; _calYear--; }
    }

    private void NextCalMonth()
    {
        _calMonth++;
        if (_calMonth > 12) { _calMonth = 1; _calYear++; }
    }

    private bool CalNextDisabled()
    {
        var next = new DateOnly(_calYear, _calMonth, 1).AddMonths(1);
        return next > new DateOnly(2026, 5, 1);
    }

    // ── Live season launch ────────────────────────────────────────────────────
    private async Task StartLiveSeason()
    {
        StopAutoSim();
        _liveState = null;
        _phase     = Phase.LiveSeason;
        _topTab    = "standings";
        _statsTab  = "players";
        StateHasChanged();
        _liveState = await Task.Run(() =>
            SeasonSvc.InitializeLiveSeason(_teams, _selectedTeam, disableInjuries: _disableInjuries));
        StateHasChanged();
    }

    private void SimOneDayLive()
    {
        if (_liveState is null || _liveState.IsComplete) return;
        SeasonSvc.SimulateDay(_liveState);
        SyncCalendarToCurrentDate();
        StateHasChanged();
    }

    private async Task SimRestOfSeasonLive()
    {
        if (_liveState is null || _simBusy) return;
        _isAutoSimming = false; // stop auto-sim if running
        _simBusy  = true;
        _simError = null;
        StateHasChanged();
        try
        {
            while (!_liveState.IsComplete)
            {
                await Task.Run(() =>
                {
                    for (int i = 0; i < 5 && !_liveState.IsComplete; i++)
                        SeasonSvc.SimulateDay(_liveState);
                });
                SyncCalendarToCurrentDate();
                StateHasChanged();
            }
        }
        catch (Exception ex)
        {
            _simError = $"Sim error: {ex.Message}";
        }
        finally
        {
            _simBusy = false;
        }
        StateHasChanged();
    }

    private async Task ToggleAutoSim()
    {
        if (_isAutoSimming) { _isAutoSimming = false; return; }
        _isAutoSimming = true;
        StateHasChanged();
        while (_isAutoSimming)
        {
            if (_liveState is null || _liveState.IsComplete) { _isAutoSimming = false; break; }
            if (_simBusy) { await Task.Delay(100); continue; }
            _simBusy = true;
            try
            {
                await Task.Run(() => SeasonSvc.SimulateDay(_liveState));
            }
            finally
            {
                _simBusy = false;
            }
            SyncCalendarToCurrentDate();
            StateHasChanged();
            await Task.Delay(300);
        }
        _isAutoSimming = false;
        StateHasChanged();
    }

    private void StopAutoSim() => _isAutoSimming = false;

