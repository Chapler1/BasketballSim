    private List<PlayoffSeriesRecord>? GetRoundForSeries(PlayoffSeriesRecord s)
    {
        if (_livePlayoffs is null) return null;
        var pr = _livePlayoffs.Result;
        if (pr.EastFirstRound.Contains(s) || pr.WestFirstRound.Contains(s))
            return [..pr.EastFirstRound, ..pr.WestFirstRound];
        if (pr.EastSecondRound.Contains(s) || pr.WestSecondRound.Contains(s))
            return [..pr.EastSecondRound, ..pr.WestSecondRound];
        if (pr.EastConfFinals == s || pr.WestConfFinals == s)
            return new List<PlayoffSeriesRecord?> { pr.EastConfFinals, pr.WestConfFinals }.Where(x => x != null).Cast<PlayoffSeriesRecord>().ToList();
        if (pr.Finals == s)
            return pr.Finals != null ? new List<PlayoffSeriesRecord> { pr.Finals } : null;
        return null;
    }

