        _watchStats       = new();
        _watchHomeLineup.Clear();
        _watchAwayLineup.Clear();
        _watchSubLog.Clear();
        StateHasChanged();
    }

    private async Task WatchGameAsync(CancellationToken ct)
    {
        if (_watchGame is null) return;
        var prevHome = new List<string>();
        var prevAway = new List<string>();
        _watchSubLog.Clear();
        _watchHomeLineup.Clear();
        _watchAwayLineup.Clear();

        foreach (var poss in _watchGame.Possessions)
        {
            if (ct.IsCancellationRequested) break;
            // Pause support — spin until unpaused or cancelled
            while (_watchPaused && !ct.IsCancellationRequested)
            {
                try { await Task.Delay(80, ct); } catch { break; }
                await InvokeAsync(StateHasChanged);
            }
            if (ct.IsCancellationRequested) break;
            _watchHomeScore = poss.HomeScore;
            _watchAwayScore = poss.AwayScore;
            _watchQuarter   = poss.Quarter;
            _watchClockSec  = poss.ClockSeconds;
            _watchPossessions.Add(poss);

            // Track lineups and substitutions
            var homeNames = poss.HomeLineup.Count > 0 ? poss.HomeLineup.ToList() : prevHome;
            var awayNames = poss.AwayLineup.Count > 0 ? poss.AwayLineup.ToList() : prevAway;
            AccumulatePossStats(poss, homeNames, awayNames);
            WatchAppendSubs(prevHome, homeNames, poss.Quarter, poss.ClockSeconds, "HOME");
            WatchAppendSubs(prevAway, awayNames, poss.Quarter, poss.ClockSeconds, "AWAY");
            if (homeNames.Count > 0) { _watchHomeLineup = new List<string>(homeNames); prevHome = homeNames; }
            if (awayNames.Count > 0) { _watchAwayLineup = new List<string>(awayNames); prevAway = awayNames; }

            if (_watchDelayMs > 0)
            {
                try { await Task.Delay(_watchDelayMs, ct); } catch { break; }
                await InvokeAsync(StateHasChanged);
            }
        }
        if (!ct.IsCancellationRequested)
        {
            _watchHomeScore = _watchGame.FinalHomeScore;
            _watchAwayScore = _watchGame.FinalAwayScore;
            _watchDone = true;
            await InvokeAsync(StateHasChanged);
        }
    }

    private void WatchAppendSubs(List<string> prev, List<string> curr, int quarter, int clockSec, string side)
    {
        if (prev.Count == 0 || curr.Count == 0) return;
        var outs = prev.Except(curr).ToList();
        var ins  = curr.Except(prev).ToList();
        for (int i = 0; i < Math.Min(outs.Count, ins.Count); i++)
            _watchSubLog.Add(new WatchSubEvent(quarter, clockSec, side, outs[i], ins[i]));
    }

    private void AccumulatePossStats(PossessionResult poss, List<string> homePlayers, List<string> awayPlayers)
    {
        if (_watchGame is null) return;
        string homeTeam = _watchGame.HomeTeam.Name;
        string awayTeam = _watchGame.AwayTeam.Name;

        WatchStat Ensure(string name)
        {
            if (_watchStats.TryGetValue(name, out var s)) return s;
            string team = ""; Position pos = Position.PG;
            if (_watchGame.Stats.TryGetValue(name, out var gs))         { team = gs.Team; pos = gs.Position; }
            else if (_watchGame.HomeTeam.Roster.FirstOrDefault(r => r.Name == name) is { } hp) { team = homeTeam; pos = hp.Position; }
            else if (_watchGame.AwayTeam.Roster.FirstOrDefault(r => r.Name == name) is { } ap) { team = awayTeam; pos = ap.Position; }
            s = new WatchStat { Name = name, Team = team, Pos = pos };
            _watchStats[name] = s;
            return s;
        }

        // Minutes — add SecondsElapsed to every player on court this possession
        if (poss.SecondsElapsed > 0)
        {
            foreach (var n in homePlayers.Concat(awayPlayers))
                Ensure(n).MinSec += poss.SecondsElapsed;
        }

        // Plus/minus — every player on court gets ± when points scored
        if (poss.PointsScored > 0)
        {
            bool homeScored = poss.Team == homeTeam;
            foreach (var n in homePlayers) Ensure(n).PlusMinus += homeScored ?  poss.PointsScored : -poss.PointsScored;
            foreach (var n in awayPlayers) Ensure(n).PlusMinus += homeScored ? -poss.PointsScored :  poss.PointsScored;
        }

        if (poss.Event is PossessionEvent.ShotMade or PossessionEvent.GameWinnerMade)
        {
            if (poss.Scorer is { } sc)  { var s = Ensure(sc);  s.Pts += poss.PointsScored; s.FGM++; s.FGA++; if (poss.IsThree) { s.Tpm++; s.Tpa++; } }
            if (poss.Assister is { } at) Ensure(at).Ast++;
        }
        else if (poss.Event is PossessionEvent.ShotMissed or PossessionEvent.GameWinnerMissed)
        {
            if (poss.Scorer is { } sc) { var s = Ensure(sc); s.FGA++; if (poss.IsThree) s.Tpa++; }
        }
        else if (poss.Event == PossessionEvent.Blocked)
        {
            if (poss.Scorer  is { } sc) { var s = Ensure(sc); s.FGA++; if (poss.IsThree) s.Tpa++; }
            if (poss.Blocker is { } bl) Ensure(bl).Blk++;
        }
        else if (poss.Event == PossessionEvent.FreeThrows)
        {
            if (poss.Scorer is { } sc) { var s = Ensure(sc); s.FtAtt += poss.FTAttempts; s.FtMade += poss.PointsScored; s.Pts += poss.PointsScored; }
        }
        else if (poss.Event is PossessionEvent.OffensiveRebound or PossessionEvent.DefensiveRebound)
        {
            if (poss.Rebounder is { } rb) Ensure(rb).Reb++;
        }
        else if (poss.Event == PossessionEvent.TurnoverStolen)
        {
            if (poss.Stealer is { } st) Ensure(st).Stl++;
        }
    }

