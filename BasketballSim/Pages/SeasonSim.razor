                            <td style="text-align:center;color:#aaa;">@p.ShotAttemptRate.ToString("P1")</td>
                            <td style="text-align:center;color:#888;">@p.Fgm.ToString("F1")</td>
                            <td style="text-align:center;color:#666;">@p.Fga.ToString("F1")</td>
                            <td style="text-align:center;color:@FgPctColor(p.FgPct);">@p.FgPct.ToString("P1")</td>
                            <td style="text-align:center;color:#888;">@p.Tpm.ToString("F1")</td>
                            <td style="text-align:center;color:#666;">@p.Tpa.ToString("F1")</td>
                            <td style="text-align:center;color:@TpPctColor(p.TpPct);">@(p.TotalThreeAtt > 0 ? p.TpPct.ToString("P1") : "—")</td>
                            <td style="text-align:center;color:#888;">@p.Ftm.ToString("F1")</td>
                            <td style="text-align:center;color:#666;">@p.Fta.ToString("F1")</td>
                            <td style="text-align:center;color:@FtPctColor(p.FtPct);">@(p.TotalFTA > 0 ? p.FtPct.ToString("P1") : "—")</td>
                            <td style="text-align:center;color:@OppFgColor(p.OppFgPct);">@(p.TotalDefFGA > 0 ? p.OppFgPct.ToString("P1") : "—")</td>
                        </tr>
                    }
                </tbody>
                <tfoot>
                @{
                    var _ftl = SortedLeaguePlayers().ToList();
                    long _ftTotalGP = _ftl.Sum(p => (long)p.GP);
                    double _ftPpg  = _ftTotalGP > 0 ? (double)_ftl.Sum(p => p.TotalPTS) / _ftTotalGP : 0;
                    double _ftRpg  = _ftTotalGP > 0 ? (double)_ftl.Sum(p => p.TotalOREB + p.TotalDREB) / _ftTotalGP : 0;
                    double _ftApg  = _ftTotalGP > 0 ? (double)_ftl.Sum(p => p.TotalAST) / _ftTotalGP : 0;
                    double _ftSpg  = _ftTotalGP > 0 ? (double)_ftl.Sum(p => p.TotalSTL) / _ftTotalGP : 0;
                    double _ftBpg  = _ftTotalGP > 0 ? (double)_ftl.Sum(p => p.TotalBLK) / _ftTotalGP : 0;
                    double _ftTopg = _ftTotalGP > 0 ? (double)_ftl.Sum(p => p.TotalTOV) / _ftTotalGP : 0;
                    double _ftMpg  = _ftTotalGP > 0 ? _ftl.Sum(p => p.TotalMIN) / _ftTotalGP : 0;
                    double _ftPm   = _ftl.Count > 0 ? _ftl.Average(p => p.AvgPlusMinus) : 0;
                    double _ftPer  = _ftl.Count > 0 ? _ftl.Average(p => p.PER) : 0;
                    double _ftOws  = _ftl.Count > 0 ? _ftl.Average(p => p.OWS) : 0;
                    double _ftDws  = _ftl.Count > 0 ? _ftl.Average(p => p.DWS) : 0;
                    double _ftWs   = _ftl.Count > 0 ? _ftl.Average(p => p.WS) : 0;
                    double _ftWs48 = _ftl.Count > 0 ? _ftl.Average(p => p.WS48) : 0;
                    long _ftFGA  = _ftl.Sum(p => (long)p.TotalFGA);
                    long _ftFGM  = _ftl.Sum(p => (long)p.TotalFGM);
                    long _ft3PA  = _ftl.Sum(p => (long)p.TotalThreeAtt);
                    long _ft3PM  = _ftl.Sum(p => (long)p.TotalThreeMade);
                    long _ftFTAx = _ftl.Sum(p => (long)p.TotalFTA);
                    long _ftFTMx = _ftl.Sum(p => (long)p.TotalFTM);
                    long _ftDFGA = _ftl.Sum(p => (long)p.TotalDefFGA);
                    long _ftDFGM = _ftl.Sum(p => (long)p.TotalDefFGM);
                    double _ftFgmPg  = _ftTotalGP > 0 ? (double)_ftFGM / _ftTotalGP : 0;
                    double _ftFgaPg  = _ftTotalGP > 0 ? (double)_ftFGA / _ftTotalGP : 0;
                    double _ftFgPct  = _ftFGA > 0 ? (double)_ftFGM / _ftFGA : 0;
                    double _ft3pmPg  = _ftTotalGP > 0 ? (double)_ft3PM / _ftTotalGP : 0;
                    double _ft3paPg  = _ftTotalGP > 0 ? (double)_ft3PA / _ftTotalGP : 0;
                    double _ft3Pct   = _ft3PA > 0 ? (double)_ft3PM / _ft3PA : 0;
                    double _ftFtmPg  = _ftTotalGP > 0 ? (double)_ftFTMx / _ftTotalGP : 0;
                    double _ftFtaPg  = _ftTotalGP > 0 ? (double)_ftFTAx / _ftTotalGP : 0;
                    double _ftFtPct  = _ftFTAx > 0 ? (double)_ftFTMx / _ftFTAx : 0;
                    double _ftOppFg  = _ftDFGA > 0 ? (double)_ftDFGM / _ftDFGA : 0;
                    double _ftShotPct  = _ftl.Count > 0 ? _ftl.Average(p => p.ShotSharePct) : 0;
                    double _ftTouchPct = _ftl.Count > 0 ? _ftl.Average(p => p.TouchPct) : 0;
                    double _ftTouchPg  = _ftl.Count > 0 ? _ftl.Average(p => p.TouchesPg) : 0;
                    double _ftShotRate = _ftl.Count > 0 ? _ftl.Average(p => p.ShotAttemptRate) : 0;
                    string _ftLabel = _ftl.Count == 0 ? "—"
                        : _leagueTeamFilter.Length > 0
                            ? (_season!.TeamStats.FirstOrDefault(t => t.TeamName == _leagueTeamFilter)?.Abbreviation ?? "FILTER") + " AVG"
                            : "LEAGUE AVG";
                }
                <tr style="border-top:2px solid #333;color:#888;background:#0f0f0f;position:sticky;bottom:0;z-index:1;">
                    <td style="color:#555;font-weight:600;padding:4px 6px;">@_ftLabel</td>
                    <td></td>
                    <td></td>
                    <td style="text-align:center;color:#555;">—</td>
                    <td style="text-align:center;color:#555;">—</td>
                    <td style="text-align:center;color:#555;">—</td>
                    <td style="text-align:center;">@_ftMpg.ToString("F1")</td>
                    <td style="text-align:center;color:#e8c060;font-weight:600;">@_ftPpg.ToString("F1")</td>
                    <td style="text-align:center;">@_ftRpg.ToString("F1")</td>
                    <td style="text-align:center;color:#60c8e8;">@_ftApg.ToString("F1")</td>
                    <td style="text-align:center;color:#a0e080;">@_ftSpg.ToString("F1")</td>
                    <td style="text-align:center;color:#e08060;">@_ftBpg.ToString("F1")</td>
                    <td style="text-align:center;color:#f06060;">@_ftTopg.ToString("F1")</td>
                    <td style="text-align:center;color:@PmColor(_ftPm);">@_ftPm.ToString("+0.0;-0.0;0.0")</td>
                    <td style="text-align:center;color:@PerColor(_ftPer);">@_ftPer.ToString("F1")</td>
                    <td style="text-align:center;">@_ftOws.ToString("F1")</td>
                    <td style="text-align:center;">@_ftDws.ToString("F1")</td>
                    <td style="text-align:center;color:#c8a840;font-weight:600;">@_ftWs.ToString("F1")</td>
                    <td style="text-align:center;">@_ftWs48.ToString("F3")</td>
                    <td style="text-align:center;">@_ftShotPct.ToString("P1")</td>
                    <td style="text-align:center;">@_ftTouchPct.ToString("P1")</td>
                    <td style="text-align:center;">@_ftTouchPg.ToString("F1")</td>
                    <td style="text-align:center;">@_ftShotRate.ToString("P1")</td>
                    <td style="text-align:center;color:#888;">@_ftFgmPg.ToString("F1")</td>
                    <td style="text-align:center;color:#666;">@_ftFgaPg.ToString("F1")</td>
                    <td style="text-align:center;color:@FgPctColor(_ftFgPct);font-weight:600;">@_ftFgPct.ToString("P1")</td>
                    <td style="text-align:center;color:#888;">@_ft3pmPg.ToString("F1")</td>
                    <td style="text-align:center;color:#666;">@_ft3paPg.ToString("F1")</td>
                    <td style="text-align:center;color:@TpPctColor(_ft3Pct);font-weight:600;">@(_ft3PA > 0 ? _ft3Pct.ToString("P1") : "—")</td>
                    <td style="text-align:center;color:#888;">@_ftFtmPg.ToString("F1")</td>
                    <td style="text-align:center;color:#666;">@_ftFtaPg.ToString("F1")</td>
                    <td style="text-align:center;color:@FtPctColor(_ftFtPct);font-weight:600;">@(_ftFTAx > 0 ? _ftFtPct.ToString("P1") : "—")</td>
                    <td style="text-align:center;color:@OppFgColor(_ftOppFg);font-weight:600;">@(_ftDFGA > 0 ? _ftOppFg.ToString("P1") : "—")</td>
                </tr>
                </tfoot>
            </table>
            </div>
            <div style="font-size: 0.78rem;color:#333;margin-top:4px;">All stats per game · click headers to sort · selected team highlighted</div>
    </div>
    }
    else if (_statsTab == "teams")
    {
    <!-- ═══ LEAGUE STATS ═══ -->
    <div style="margin-top:1.5rem;">
        <div class="section-title">LEAGUE STATS</div>
        <div style="display:grid;grid-template-columns:repeat(5,auto);gap:0.75rem 2.5rem;align-items:start;">

            <!-- Pace & Possessions -->
            <div>
                <div style="font-size: 0.78rem;color:#444;letter-spacing:1px;margin-bottom:4px;">PACE</div>
                <table style="font-size: 0.9rem;">
                    <tbody>
                        <tr>
                            <td style="color:#666;padding-right:1rem;">Possessions / Team / Game</td>
                            <td style="color:#e8e8e8;font-weight:600;text-align:right;">@_season.AvgPossessionsPerTeam.ToString("F1")</td>
                        </tr>
                        <tr>
                            <td style="color:#666;padding-right:1rem;">Avg Possession Length</td>
                            <td style="color:#e8e8e8;font-weight:600;text-align:right;">@_season.AvgPossessionLengthSeconds.ToString("F1")s</td>
                        </tr>
                        <tr>
                            <td style="color:#666;padding-right:1rem;">Avg Passes / Possession</td>
                            <td style="color:#e8e8e8;font-weight:600;text-align:right;">@_season.AvgPassesPerPossession.ToString("F2")</td>
                        </tr>
                    </tbody>
                </table>
            </div>

            <!-- Per-game averages -->
            <div>
                <div style="font-size: 0.78rem;color:#444;letter-spacing:1px;margin-bottom:4px;">PER TEAM PER GAME</div>
                <table style="font-size: 0.9rem;">
                    <tbody>
                        @{
                            double lgPpg  = _season.TeamStats.Count > 0 ? _season.TeamStats.Average(t => t.Ppg)  : 0;
                            double lgRpg  = _season.TeamStats.Count > 0 ? _season.TeamStats.Average(t => t.Reb)  : 0;
                            double lgOrb  = _season.TeamStats.Count > 0 ? _season.TeamStats.Average(t => t.Oreb) : 0;
                            double lgDrb  = _season.TeamStats.Count > 0 ? _season.TeamStats.Average(t => t.Dreb) : 0;
                            double lgApg  = _season.TeamStats.Count > 0 ? _season.TeamStats.Average(t => t.Ast)  : 0;
                            double lgSpg  = _season.TeamStats.Count > 0 ? _season.TeamStats.Average(t => t.Stl)  : 0;
                            double lgBpg  = _season.TeamStats.Count > 0 ? _season.TeamStats.Average(t => t.Blk)  : 0;
                            double lgTov  = _season.TeamStats.Count > 0 ? _season.TeamStats.Average(t => t.Tov)  : 0;
                        }
                        <tr><td style="color:#666;padding-right:1.5rem;">PTS</td><td style="color:#e8c060;font-weight:600;text-align:right;">@lgPpg.ToString("F1")</td></tr>
                        <tr><td style="color:#666;">REB</td><td style="color:#e8e8e8;text-align:right;">@lgRpg.ToString("F1")</td></tr>
                        <tr><td style="color:#666;">OREB</td><td style="color:#888;text-align:right;">@lgOrb.ToString("F1")</td></tr>
                        <tr><td style="color:#666;">DREB</td><td style="color:#888;text-align:right;">@lgDrb.ToString("F1")</td></tr>
                        <tr><td style="color:#666;">AST</td><td style="color:#60c8e8;text-align:right;">@lgApg.ToString("F1")</td></tr>
                        <tr><td style="color:#666;">STL</td><td style="color:#a0e080;text-align:right;">@lgSpg.ToString("F1")</td></tr>
                        <tr><td style="color:#666;">BLK</td><td style="color:#e08060;text-align:right;">@lgBpg.ToString("F1")</td></tr>
                        <tr><td style="color:#666;">TOV</td><td style="color:#f06060;text-align:right;">@lgTov.ToString("F1")</td></tr>
                    </tbody>
                </table>
            </div>

            <!-- Home/Away -->
            <div>
                <div style="font-size: 0.78rem;color:#444;letter-spacing:1px;margin-bottom:4px;">HOME / AWAY</div>
                <table style="font-size: 0.9rem;">
                    <tbody>
                        @{
                            int totalHomeWins = _season.TeamStats.Sum(t => t.HomeWins);
                            int totalHomeLoss = _season.TeamStats.Sum(t => t.HomeLosses);
                            int totalAwayWins = _season.TeamStats.Sum(t => t.AwayWins);
                            int totalAwayLoss = _season.TeamStats.Sum(t => t.AwayLosses);
                            double homeWinPct = (totalHomeWins + totalHomeLoss) > 0
                                ? (double)totalHomeWins / (totalHomeWins + totalHomeLoss) : 0;
                            double awayWinPct = (totalAwayWins + totalAwayLoss) > 0
                                ? (double)totalAwayWins / (totalAwayWins + totalAwayLoss) : 0;
                        }
                        <tr>
                            <td style="color:#666;padding-right:1.5rem;">Home W%</td>
                            <td style="color:#e8c060;font-weight:600;text-align:right;">@homeWinPct.ToString("P1")</td>
                        </tr>
                        <tr>
                            <td style="color:#666;">Home W-L</td>
                            <td style="color:#888;text-align:right;">@totalHomeWins–@totalHomeLoss</td>
                        </tr>
                        <tr>
                            <td style="color:#666;">Away W%</td>
                            <td style="color:#e8e8e8;font-weight:600;text-align:right;">@awayWinPct.ToString("P1")</td>
                        </tr>
                        <tr>
                            <td style="color:#666;">Away W-L</td>
                            <td style="color:#888;text-align:right;">@totalAwayWins–@totalAwayLoss</td>
                        </tr>
                    </tbody>
                </table>
            </div>

            <!-- Shooting Splits -->
            <div>
                <div style="font-size: 0.78rem;color:#444;letter-spacing:1px;margin-bottom:4px;">SHOOTING (PER TEAM PER GAME)</div>
                <table style="font-size: 0.9rem;border-collapse:collapse;">
                    <thead>
                        <tr>
                            <th style="color:#444;padding:2px 10px 2px 0;text-align:left;font-weight:400;font-size: 0.82rem;"></th>
                            <th style="color:#555;padding:2px 10px;text-align:right;font-weight:400;font-size: 0.82rem;">MADE</th>
                            <th style="color:#555;padding:2px 10px;text-align:right;font-weight:400;font-size: 0.82rem;">ATT</th>
                            <th style="color:#555;padding:2px 10px;text-align:right;font-weight:400;font-size: 0.82rem;">PCT</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td style="color:#666;padding-right:1rem;">FG</td>
                            <td style="text-align:right;padding:1px 10px;color:#c8c8c8;">@_season.LeagueFgmPg.ToString("F1")</td>
                            <td style="text-align:right;padding:1px 10px;color:#888;">@_season.LeagueFgaPg.ToString("F1")</td>
                            <td style="text-align:right;padding:1px 10px;color:@FgPctColor(_season.LeagueFgPct);font-weight:600;">@_season.LeagueFgPct.ToString("P1")</td>
                        </tr>
                        <tr>
                            <td style="color:#666;padding-right:1rem;">3PT</td>
                            <td style="text-align:right;padding:1px 10px;color:#c8c8c8;">@_season.LeagueTpmPg.ToString("F1")</td>
                            <td style="text-align:right;padding:1px 10px;color:#888;">@_season.LeagueTpaPg.ToString("F1")</td>
                            <td style="text-align:right;padding:1px 10px;color:@TpPctColor(_season.LeagueTpPct);font-weight:600;">@_season.LeagueTpPct.ToString("P1")</td>
                        </tr>
                        <tr>
                            <td style="color:#666;padding-right:1rem;">2PT</td>
                            @{
                                double lg2pm = _season.LeagueFgmPg - _season.LeagueTpmPg;
                                double lg2pa = _season.LeagueFgaPg - _season.LeagueTpaPg;
                                double lg2pct = lg2pa > 0 ? lg2pm / lg2pa : 0;
                            }
                            <td style="text-align:right;padding:1px 10px;color:#c8c8c8;">@lg2pm.ToString("F1")</td>
                            <td style="text-align:right;padding:1px 10px;color:#888;">@lg2pa.ToString("F1")</td>
                            <td style="text-align:right;padding:1px 10px;color:@FgPctColor(lg2pct);font-weight:600;">@lg2pct.ToString("P1")</td>
                        </tr>
                        <tr>
                            <td style="color:#666;padding-right:1rem;">FT</td>
                            <td style="text-align:right;padding:1px 10px;color:#c8c8c8;">@_season.LeagueFtmPg.ToString("F1")</td>
                            <td style="text-align:right;padding:1px 10px;color:#888;">@_season.LeagueFtaPg.ToString("F1")</td>
                            <td style="text-align:right;padding:1px 10px;color:@FtPctColor(_season.LeagueFtPct);font-weight:600;">@_season.LeagueFtPct.ToString("P1")</td>
                        </tr>
                    </tbody>
                </table>
            </div>

            <!-- Injuries -->
            <div>
                <div style="font-size:0.78rem;color:#444;letter-spacing:1px;margin-bottom:4px;">INJURIES</div>
                @{
                    var allInj     = _season.PlayerStats.SelectMany(p => p.InjuryHistory).ToList();
                    int totalInj   = allInj.Count;
                    int totalMissG = allInj.Sum(r => r.GamesMissed);
                    double avgMiss = totalInj > 0 ? (double)totalMissG / totalInj : 0;
                }
                <table style="font-size:0.9rem;">
                    <tbody>
                        <tr>
                            <td style="color:#666;padding-right:1rem;">Total Injuries</td>
                            <td style="color:#e8e8e8;font-weight:600;text-align:right;">@totalInj</td>
                        </tr>
                        <tr>
                            <td style="color:#666;padding-right:1rem;">Total Games Missed</td>
                            <td style="color:#e8e8e8;font-weight:600;text-align:right;">@totalMissG</td>
                        </tr>
                        <tr>
                            <td style="color:#666;padding-right:1rem;">Avg Games Missed / Injury</td>
                            <td style="color:#e8e8e8;font-weight:600;text-align:right;">@avgMiss.ToString("F1")</td>
                        </tr>
                    </tbody>
                </table>
            </div>

        </div>
    </div>

    <!-- ═══ TEAM STATS ═══ -->
    <div style="margin-top:1.5rem;">
        <div class="section-title">TEAM STATS</div>
        <div class="scroll-x">
        <table>
            <thead style="position:sticky;top:0;background:#111;z-index:1;">
                <tr>
                    <th style="text-align:left;min-width:42px;">TEAM</th>
                    @TeamTh("wins",  "W")
                    @TeamTh("losses","L")
                    @TeamTh("pct",   "PCT")
                    @TeamTh("ppg",   "PPG")
                    @TeamTh("papg",  "PA")
                    @TeamTh("diff",  "DIFF")
                    @TeamTh("fgm",   "FGM")
                    @TeamTh("fga",   "FGA")
                    @TeamTh("fgpct", "FG%")
                    @TeamTh("tpm",   "3PM")
                    @TeamTh("tpa",   "3PA")
                    @TeamTh("tppct", "3P%")
                    @TeamTh("ftm",   "FTM")
                    @TeamTh("fta",   "FTA")
                    @TeamTh("ftpct", "FT%")
                    @TeamTh("oreb",  "ORB")
                    @TeamTh("dreb",  "DRB")
                    @TeamTh("reb",   "REB")
                    @TeamTh("ast",   "AST")
                    @TeamTh("stl",   "STL")
                    @TeamTh("blk",   "BLK")
                    @TeamTh("tov",   "TOV")
                    @TeamTh("pace",  "PACE")
                </tr>
            </thead>
            <tbody>
            @foreach (var t in SortedTeams())
            {
                double tdiff = t.Ppg - t.Papg;
                <tr>
                    <td style="color:#b8b8b8;font-weight:600;">@t.Abbreviation</td>
                    <td style="text-align:center;color:#4af080;font-weight:600;">@t.Wins</td>
                    <td style="text-align:center;color:#f06060;">@t.Losses</td>
                    <td style="text-align:center;color:#888;">@t.Pct.ToString("F3")</td>
                    <td style="text-align:center;color:#e8c060;font-weight:600;">@t.Ppg.ToString("F1")</td>
                    <td style="text-align:center;color:#888;">@t.Papg.ToString("F1")</td>
                    <td style="text-align:center;color:@(tdiff>=0?"#4af080":"#f06060");">@tdiff.ToString("+0.0;-0.0;0.0")</td>
                    <td style="text-align:center;color:#888;">@t.Fgm.ToString("F1")</td>
                    <td style="text-align:center;color:#666;">@t.Fga.ToString("F1")</td>
                    <td style="text-align:center;color:@FgPctColor(t.FgPct);">@t.FgPct.ToString("P1")</td>
                    <td style="text-align:center;color:#888;">@t.Tpm.ToString("F1")</td>
                    <td style="text-align:center;color:#666;">@t.Tpa.ToString("F1")</td>
                    <td style="text-align:center;color:@TpPctColor(t.TpPct);">@t.TpPct.ToString("P1")</td>
                    <td style="text-align:center;color:#888;">@t.Ftm.ToString("F1")</td>
                    <td style="text-align:center;color:#666;">@t.Fta.ToString("F1")</td>
                    <td style="text-align:center;color:@FtPctColor(t.FtPct);">@t.FtPct.ToString("P1")</td>
                    <td style="text-align:center;">@t.Oreb.ToString("F1")</td>
                    <td style="text-align:center;color:#666;">@t.Dreb.ToString("F1")</td>
                    <td style="text-align:center;">@t.Reb.ToString("F1")</td>
                    <td style="text-align:center;color:#60c8e8;">@t.Ast.ToString("F1")</td>
                    <td style="text-align:center;color:#a0e080;">@t.Stl.ToString("F1")</td>
                    <td style="text-align:center;color:#e08060;">@t.Blk.ToString("F1")</td>
                    <td style="text-align:center;color:#f06060;">@t.Tov.ToString("F1")</td>
                    <td style="text-align:center;color:#777;">@t.Pace.ToString("F1")</td>
                </tr>
            }
            </tbody>
            <tfoot>
            @{
                var _tfl = _season!.TeamStats;
                string _tflabel = "LEAGUE AVG";
            }
            <tr style="border-top:2px solid #333;color:#888;background:#0f0f0f;position:sticky;bottom:0;z-index:1;">
                <td style="color:#555;font-weight:600;">@_tflabel</td>
                <td style="text-align:center;color:#555;">@_tfl.Average(t=>t.Wins).ToString("F1")</td>
                <td style="text-align:center;color:#555;">@_tfl.Average(t=>t.Losses).ToString("F1")</td>
                <td style="text-align:center;">@_tfl.Average(t=>t.Pct).ToString("F3")</td>
                <td style="text-align:center;color:#e8c060;">@_tfl.Average(t=>t.Ppg).ToString("F1")</td>
                <td style="text-align:center;">@_tfl.Average(t=>t.Papg).ToString("F1")</td>
                <td style="text-align:center;">@(_tfl.Average(t=>t.Ppg)-_tfl.Average(t=>t.Papg)).ToString("+0.0;-0.0;0.0")</td>
                <td style="text-align:center;">@_tfl.Average(t=>t.Fgm).ToString("F1")</td>
                <td style="text-align:center;">@_tfl.Average(t=>t.Fga).ToString("F1")</td>
                <td style="text-align:center;">@(_season.LeagueFgPct).ToString("P1")</td>
                <td style="text-align:center;">@_tfl.Average(t=>t.Tpm).ToString("F1")</td>
                <td style="text-align:center;">@_tfl.Average(t=>t.Tpa).ToString("F1")</td>
                <td style="text-align:center;">@(_season.LeagueTpPct).ToString("P1")</td>
                <td style="text-align:center;">@_tfl.Average(t=>t.Ftm).ToString("F1")</td>
                <td style="text-align:center;">@_tfl.Average(t=>t.Fta).ToString("F1")</td>
                <td style="text-align:center;">@(_season.LeagueFtPct).ToString("P1")</td>
                <td style="text-align:center;">@_tfl.Average(t=>t.Oreb).ToString("F1")</td>
                <td style="text-align:center;">@_tfl.Average(t=>t.Dreb).ToString("F1")</td>
                <td style="text-align:center;">@_tfl.Average(t=>t.Reb).ToString("F1")</td>
                <td style="text-align:center;">@_tfl.Average(t=>t.Ast).ToString("F1")</td>
                <td style="text-align:center;">@_tfl.Average(t=>t.Stl).ToString("F1")</td>
                <td style="text-align:center;">@_tfl.Average(t=>t.Blk).ToString("F1")</td>
                <td style="text-align:center;">@_tfl.Average(t=>t.Tov).ToString("F1")</td>
                <td style="text-align:center;">@_tfl.Average(t=>t.Pace).ToString("F1")</td>
            </tr>
            </tfoot>
        </table>
        </div>
    </div>
    }

    else if (_statsTab == "playoffs")
    {
    @if (_playoffs is not null)
    {
        <!-- PLAYOFF LEADERS -->
        <div style="margin-bottom:1.5rem;">
            <div class="section-title" style="margin-bottom:6px;">PLAYOFF LEADERS</div>
            <div class="scroll-x" style="max-height:420px;overflow-y:auto;">
            <table>
                <thead style="position:sticky;top:0;background:#111;z-index:1;">
                    <tr>
                        <th style="text-align:left;min-width:120px;">PLAYER</th>
                        <th style="text-align:left;min-width:36px;">TEAM</th>
                        <th style="text-align:center;width:28px;">GP</th>
                        <th style="text-align:center;width:38px;">MIN</th>
                        <th style="text-align:center;width:38px;color:#e8c060;">PTS</th>
                        <th style="text-align:center;width:38px;">REB</th>
                        <th style="text-align:center;width:38px;color:#60c8e8;">AST</th>
                        <th style="text-align:center;width:38px;color:#a0e080;">STL</th>
                        <th style="text-align:center;width:38px;color:#e08060;">BLK</th>
                        <th style="text-align:center;width:38px;color:#f06060;">TOV</th>
                        <th style="text-align:center;width:44px;">+/-</th>
                        <th style="text-align:center;width:44px;">FG%</th>
                        <th style="text-align:center;width:34px;">3PA</th>
                        <th style="text-align:center;width:44px;">3P%</th>
                        <th style="text-align:center;width:44px;">FT%</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var p in _playoffs.PlayerStats.Where(p => p.GP > 0).OrderByDescending(p => p.Ppg))
                {
                    <tr @onclick="() => OpenPlayerModal(p)" style="cursor:pointer;">
                        <td style="color:#b8b8b8;">@p.Name</td>
                        <td style="color:#555;font-size:0.85rem;">@p.TeamAbbr</td>
                        <td style="text-align:center;color:#555;">@p.GP</td>
                        <td style="text-align:center;color:#777;">@p.Mpg.ToString("F1")</td>
                        <td style="text-align:center;color:#e8c060;font-weight:600;">@p.Ppg.ToString("F1")</td>
                        <td style="text-align:center;">@p.Rpg.ToString("F1")</td>
                        <td style="text-align:center;color:#60c8e8;">@p.Apg.ToString("F1")</td>
                        <td style="text-align:center;color:#a0e080;">@p.Spg.ToString("F1")</td>
                        <td style="text-align:center;color:#e08060;">@p.Bpg.ToString("F1")</td>
                        <td style="text-align:center;color:#f06060;">@p.Topg.ToString("F1")</td>
                        <td style="text-align:center;color:@PmColor(p.AvgPlusMinus);">@p.AvgPlusMinus.ToString("+0.0;-0.0;0.0")</td>
                        <td style="text-align:center;color:@FgPctColor(p.FgPct);">@p.FgPct.ToString("P1")</td>
                        <td style="text-align:center;color:#666;">@p.Tpa.ToString("F1")</td>
                        <td style="text-align:center;color:@TpPctColor(p.TpPct);">@(p.TotalThreeAtt > 0 ? p.TpPct.ToString("P1") : "—")</td>
                        <td style="text-align:center;color:@FtPctColor(p.FtPct);">@(p.TotalFTA > 0 ? p.FtPct.ToString("P1") : "—")</td>
                    </tr>
                }
                </tbody>
            </table>
            </div>
        </div>

        <!-- BRACKET -->
        <div style="margin-bottom:1.5rem;">
            <div class="section-title">PLAYOFF BRACKET</div>

            @if (_playoffs.PlayInGames.Count > 0)
            {
                <div style="margin-bottom:1rem;">
                    <div style="font-size:0.75rem;color:#444;letter-spacing:1px;margin-bottom:6px;">PLAY-IN TOURNAMENT</div>
                    <div style="display:flex;flex-wrap:wrap;gap:4px 20px;">
                        @foreach (var g in _playoffs.PlayInGames)
                        {
                            bool hw = g.HomeScore > g.AwayScore;
                            <span style="font-size:0.84rem;">
                                <span style="color:@(hw ? "#c8c8c8" : "#555");">@g.HomeAbbr @g.HomeScore</span>
                                <span style="color:#2a2a2a;"> – </span>
                                <span style="color:@(!hw ? "#c8c8c8" : "#555");">@g.AwayScore @g.AwayAbbr</span>
                            </span>
                        }
                    </div>
                </div>
            }

            @if (_playoffs.EastFirstRound.Count > 0 || _playoffs.WestFirstRound.Count > 0)
            {
                <div style="display:grid;grid-template-columns:1fr 1fr;gap:1.5rem;margin-bottom:1rem;">
                    <div>
                        <div style="font-size:0.72rem;color:#444;letter-spacing:1px;margin-bottom:4px;">FIRST ROUND — EAST</div>
                        @foreach (var s in _playoffs.EastFirstRound) { @SeriesRow(s) }
                    </div>
                    <div>
                        <div style="font-size:0.72rem;color:#444;letter-spacing:1px;margin-bottom:4px;">FIRST ROUND — WEST</div>
                        @foreach (var s in _playoffs.WestFirstRound) { @SeriesRow(s) }
                    </div>
                </div>
            }

            @if (_playoffs.EastSecondRound.Count > 0 || _playoffs.WestSecondRound.Count > 0)
            {
                <div style="display:grid;grid-template-columns:1fr 1fr;gap:1.5rem;margin-bottom:1rem;">
                    <div>
                        <div style="font-size:0.72rem;color:#444;letter-spacing:1px;margin-bottom:4px;">SECOND ROUND — EAST</div>
                        @foreach (var s in _playoffs.EastSecondRound) { @SeriesRow(s) }
                    </div>
                    <div>
                        <div style="font-size:0.72rem;color:#444;letter-spacing:1px;margin-bottom:4px;">SECOND ROUND — WEST</div>
                        @foreach (var s in _playoffs.WestSecondRound) { @SeriesRow(s) }
                    </div>
                </div>
            }

            @if (_playoffs.EastConfFinals is not null || _playoffs.WestConfFinals is not null)
            {
                <div style="display:grid;grid-template-columns:1fr 1fr;gap:1.5rem;margin-bottom:1rem;">
                    <div>
                        <div style="font-size:0.72rem;color:#444;letter-spacing:1px;margin-bottom:4px;">CONF FINALS — EAST</div>
                        @if (_playoffs.EastConfFinals is not null) { @SeriesRow(_playoffs.EastConfFinals) }
                    </div>
                    <div>
                        <div style="font-size:0.72rem;color:#444;letter-spacing:1px;margin-bottom:4px;">CONF FINALS — WEST</div>
                        @if (_playoffs.WestConfFinals is not null) { @SeriesRow(_playoffs.WestConfFinals) }
                    </div>
                </div>
            }

            @if (_playoffs.Finals is not null)
            {
                <div>
                    <div style="font-size:0.72rem;color:#fca;letter-spacing:1px;margin-bottom:4px;">NBA FINALS</div>
                    @SeriesRow(_playoffs.Finals)
                </div>
            }
        </div>

        <!-- AWARDS -->
        @if (_awards is not null)
        {
        <div style="margin-top:1.5rem;">
            <div class="section-title">SEASON AWARDS</div>

            <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:1rem;margin-bottom:1.25rem;">
                @if (_awards.MVP    is not null) { @AwardCard("MOST VALUABLE PLAYER",       _awards.MVP,    "#fca",    "#0d0900", "#2a1800") }
                @if (_awards.DPOY   is not null) { @AwardCard("DEF. PLAYER OF THE YEAR",    _awards.DPOY,   "#4af0c0", "#000d0d", "#001e1e") }
                @if (_awards.SixMOY is not null) { @AwardCard("6TH MAN OF THE YEAR",        _awards.SixMOY, "#b080ff", "#0a000d", "#1e0030") }
            </div>

            @{
                var allNbaRows = new (string Label, List<AwardWinner> Players)[]
                {
                    ("ALL-NBA 1ST TEAM", _awards.AllNba1),
                    ("ALL-NBA 2ND TEAM", _awards.AllNba2),
                    ("ALL-NBA 3RD TEAM", _awards.AllNba3),
                };
                var allDefRows = new (string Label, List<AwardWinner> Players)[]
                {
                    ("ALL-DEFENSE 1ST TEAM", _awards.AllDef1),
                    ("ALL-DEFENSE 2ND TEAM", _awards.AllDef2),
                };
            }

            <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:1rem;margin-bottom:1rem;">
                @foreach (var (teamLabel, players) in allNbaRows)
                {
                    <div>
                        <div style="font-size:0.7rem;color:#445;letter-spacing:1px;margin-bottom:5px;border-bottom:1px solid #1a1a1a;padding-bottom:3px;">@teamLabel</div>
                        @foreach (var p in players)
                        {
                            <div style="display:flex;justify-content:space-between;padding:2px 0;font-size:0.84rem;">
                                <span style="color:#b8b8b8;">@p.Name</span>
                                <span style="color:#444;font-size:0.76rem;">@p.TeamAbbr</span>
                            </div>
                        }
                    </div>
                }
            </div>

            <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;max-width:66%;">
                @foreach (var (teamLabel, players) in allDefRows)
                {
                    <div>
                        <div style="font-size:0.7rem;color:#345;letter-spacing:1px;margin-bottom:5px;border-bottom:1px solid #1a1a1a;padding-bottom:3px;">@teamLabel</div>
                        @foreach (var p in players)
                        {
                            <div style="display:flex;justify-content:space-between;padding:2px 0;font-size:0.84rem;">
                                <span style="color:#b0b8b0;">@p.Name</span>
                                <span style="color:#444;font-size:0.76rem;">@p.TeamAbbr</span>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
        }
    }
    else
    {
        <div style="text-align:center;padding:3rem 0;color:#333;font-family:monospace;">
            Use ▶ Simulate Playoffs to unlock this tab.
        </div>
    }
    }

}

<!-- ═══ GAME LOG MODAL ═══ -->
@if (_gameLogTeam is not null && _season is not null)
{
    var glTeam  = _gameLogTeam;
    var glGames = _season.Games
        .Where(g => g.HomeTeam == glTeam.TeamName || g.AwayTeam == glTeam.TeamName)
        .OrderBy(g => g.Date)
        .ToList();

    <div style="position:fixed;inset:0;background:rgba(0,0,0,0.82);z-index:1000;display:flex;align-items:center;justify-content:center;padding:1rem;"
         @onclick="() => _gameLogTeam = null">
        <div style="background:#141414;border:1px solid #2a2a2a;border-radius:6px;width:min(560px,95vw);max-height:90vh;display:flex;flex-direction:column;font-family:monospace;color:#d4d4d4;"
             @onclick:stopPropagation="true">

            <!-- Header -->
            <div style="display:flex;justify-content:space-between;align-items:center;padding:0.85rem 1.25rem;border-bottom:1px solid #1e1e1e;flex-shrink:0;">
                <div>
                    <span style="display:inline-block;width:9px;height:9px;border-radius:50%;background:@glTeam.PrimaryColor;margin-right:6px;vertical-align:middle;"></span>
                    <span style="font-size:1.1rem;font-weight:800;color:#e8e8e8;letter-spacing:1px;">@glTeam.TeamName</span>
                    <span style="color:#333;margin-left:8px;font-size:0.88rem;">@glTeam.Wins–@glTeam.Losses</span>
                </div>
                <button @onclick="() => _gameLogTeam = null" style="background:none;border:none;color:#444;font-size:1.3rem;cursor:pointer;line-height:1;padding:0;">✕</button>
            </div>

            <!-- Column headers -->
            <div style="display:grid;grid-template-columns:72px 22px 44px 1fr 36px;gap:0 6px;padding:5px 1.25rem 3px;border-bottom:1px solid #1e1e1e;flex-shrink:0;">
                <span style="font-size:0.75rem;color:#3a3a3a;letter-spacing:0.5px;">DATE</span>
                <span style="font-size:0.75rem;color:#3a3a3a;text-align:center;">H/A</span>
                <span style="font-size:0.75rem;color:#3a3a3a;text-align:center;">OPP</span>
                <span style="font-size:0.75rem;color:#3a3a3a;text-align:right;padding-right:4px;">SCORE</span>
                <span style="font-size:0.75rem;color:#3a3a3a;text-align:center;">W/L</span>
            </div>

            <!-- Scrollable game list -->
            <div style="overflow-y:auto;flex:1;padding:0 1.25rem 0.75rem;">
                @foreach (var g in glGames)
                {
                    bool isHome = g.HomeTeam == glTeam.TeamName;
                    bool won    = isHome ? g.HomeScore > g.AwayScore : g.AwayScore > g.HomeScore;
                    string oppAbbr = isHome ? g.AwayAbbr : g.HomeAbbr;
                    string scoreStr = isHome
                        ? $"{g.HomeScore}–{g.AwayScore}"
                        : $"{g.AwayScore}–{g.HomeScore}";

                    <div class="glog-row">
                        <span style="color:#555;font-size:0.82rem;">@g.Date.ToString("MMM d")</span>
                        <span style="text-align:center;font-size:0.78rem;color:@(isHome?"#60c8e8":"#888");">@(isHome?"H":"A")</span>
                        <span style="text-align:center;color:#888;font-size:0.85rem;">@oppAbbr</span>
                        <span style="text-align:right;padding-right:4px;color:@(won?"#c8c8c8":"#666");">@scoreStr</span>
                        <span style="text-align:center;" class="@(won?"glog-w":"glog-l")">@(won?"W":"L")</span>
                    </div>
                }
                @if (glGames.Count == 0)
                {
                    <div style="color:#333;text-align:center;padding:2rem 0;">No games recorded.</div>
                }
            </div>

            <!-- Footer -->
            <div style="padding:0.5rem 1.25rem;border-top:1px solid #1a1a1a;flex-shrink:0;display:flex;gap:1.5rem;font-size:0.8rem;color:#3a3a3a;">
                <span>Home: <span style="color:#555;">@glTeam.HomeWins–@glTeam.HomeLosses</span></span>
                <span>Away: <span style="color:#555;">@glTeam.AwayWins–@glTeam.AwayLosses</span></span>
                <span>Conf: <span style="color:#555;">@glTeam.ConfWins–@glTeam.ConfLosses</span></span>
                <span style="margin-left:auto;">@glGames.Count games</span>
            </div>
        </div>
    </div>
}

<!-- ═══ TICKER BOX SCORE MODAL ═══ -->
@if (_tickerBoxScore is not null)
{
    var tbs = _tickerBoxScore;
    bool thw = tbs.HomeScore > tbs.AwayScore;
    <div style="position:fixed;inset:0;background:rgba(0,0,0,0.82);z-index:1001;display:flex;align-items:center;justify-content:center;padding:1rem;"
         @onclick="() => _tickerBoxScore = null">
        <div style="background:#141414;border:1px solid #2a2a2a;border-radius:6px;width:min(380px,90vw);font-family:monospace;color:#d4d4d4;"
             @onclick:stopPropagation="true">
            <div style="display:flex;justify-content:space-between;align-items:center;padding:0.75rem 1rem;border-bottom:1px solid #1e1e1e;">
                <span style="font-size:0.7rem;color:#444;letter-spacing:1px;">@tbs.Date.ToString("dddd, MMMM d").ToUpper()</span>
                <button @onclick="() => _tickerBoxScore = null" style="background:none;border:none;color:#444;font-size:1.1rem;cursor:pointer;">✕</button>
            </div>
            <div style="padding:1.25rem 1.5rem;text-align:center;">
                <div style="display:flex;align-items:center;justify-content:center;gap:1.5rem;">
                    <div style="text-align:center;">
                        <img src="/logos/teams/@(LogoSlug(tbs.HomeTeam)).svg" style="width:48px;height:48px;object-fit:contain;display:block;margin:0 auto 4px;" onerror="this.style.display='none'" />
                        <div style="font-size:0.8rem;color:@(thw?"#e8e8e8":"#555");">@tbs.HomeAbbr</div>
                    </div>
                    <div>
                        <div style="font-size:2rem;font-weight:800;color:#e8e8e8;letter-spacing:2px;">
                            <span style="color:@(thw?"#4af080":"#888");">@tbs.HomeScore</span>
                            <span style="color:#222;font-size:1.2rem;"> – </span>
                            <span style="color:@(!thw?"#4af080":"#888");">@tbs.AwayScore</span>
                        </div>
                        <div style="font-size:0.68rem;color:#333;text-align:center;margin-top:2px;">FINAL</div>
                    </div>
                    <div style="text-align:center;">
                        <img src="/logos/teams/@(LogoSlug(tbs.AwayTeam)).svg" style="width:48px;height:48px;object-fit:contain;display:block;margin:0 auto 4px;" onerror="this.style.display='none'" />
                        <div style="font-size:0.8rem;color:@(!thw?"#e8e8e8":"#555");">@tbs.AwayAbbr</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

<!-- ═══ PLAYER DETAIL MODAL ═══ -->
@if (_detailPlayer is not null)
{
    <div style="position:fixed;inset:0;background:rgba(0,0,0,0.82);z-index:1000;display:flex;align-items:center;justify-content:center;padding:1rem;"
         @onclick="CloseModal">
        <div style="background:#141414;border:1px solid #2a2a2a;border-radius:6px;width:min(1060px,95vw);max-height:94vh;overflow-y:auto;font-family:monospace;color:#d4d4d4;"
             @onclick:stopPropagation="true">

            <!-- Header -->
            <div style="display:flex;justify-content:space-between;align-items:center;padding:0.85rem 1.25rem;border-bottom:1px solid #1e1e1e;gap:1rem;">
                <div style="flex:1;">
                    <div style="font-size:1.3rem;font-weight:800;color:#e8e8e8;letter-spacing:1px;">@_detailPlayer.Name</div>
                    <div style="font-size:0.88rem;color:#555;margin-top:2px;">
                        @_detailPlayer.Team
                        <span style="color:#2a2a2a;">&nbsp;·&nbsp;</span>@_detailPlayer.Position
                        @if (_detailRecord is not null)
                        {
                            <span style="color:#2a2a2a;">&nbsp;·&nbsp;</span><span>@_detailRecord.Height</span>
                            @if (_detailRecord.Positions.Count > 1)
                            {
                                <span style="color:#3a3a3a;">&nbsp;(@string.Join("/", _detailRecord.Positions))</span>
                            }
                        }
                    </div>
                </div>
                <button @onclick="CloseModal" style="background:none;border:none;color:#444;font-size:1.3rem;cursor:pointer;line-height:1;padding:0;">✕</button>
            </div>

            <!-- Tab bar -->
            <div style="display:flex;border-bottom:1px solid #1e1e1e;padding:0 1rem;">
                <button class="pdlg-tab @(_detailTab=="career"?"active":"")"   @onclick='() => _detailTab = "career"'>CAREER STATS</button>
                <button class="pdlg-tab @(_detailTab=="advanced"?"active":"")" @onclick='() => _detailTab = "advanced"'>ADVANCED STATS</button>
                @if (_detailRecord is not null)
                {
                    <button class="pdlg-tab @(_detailTab=="attrs"?"active":"")"  @onclick='() => _detailTab = "attrs"'>ATTRIBUTES</button>
                    <button class="pdlg-tab @(_detailTab=="tends"?"active":"")"  @onclick='() => _detailTab = "tends"'>TENDENCIES</button>
                }
                <button class="pdlg-tab @(_detailTab=="injuries"?"active":"")" @onclick='() => _detailTab = "injuries"'>INJURIES</button>
            </div>

            <div style="padding:0.85rem 1.25rem;">

            @if (_detailTab == "attrs" && _detailRecord is not null)
            {
                <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:0.75rem 1rem;">
                    @AttrGroup("PHYSICAL",  new[]{("Height","Height"),("Strength","Strength"),("Speed","Speed"),("Jumping","Jumping"),("Endurance","Endurance")})
                    @AttrGroup("SHOOTING",  new[]{("Inside","Inside"),("Dunks","Dunks"),("Free Throw","FreeThrow"),("Mid-Range","MidRange"),("3-Point","ThreePoint")})
                    @AttrGroup("SKILL",     new[]{("Off IQ","oBBIQ"),("Def IQ","dBBIQ"),("Hustle","Hustle"),("Dribbling","Dribbling"),("Passing","Passing"),("Off Reb","RebOff"),("Def Reb","RebDef")})
                    @AttrGroup("DEFENSE",   new[]{("Perim Def","PerimDef"),("Int Def","IntDef"),("Foul Tend","FoulTend")})
                </div>
            }
            else if (_detailTab == "tends" && _detailRecord is not null)
            {
                <div style="display:grid;grid-template-columns:1fr 1fr;gap:0.5rem 2rem;">
                    @TendGroup("OFFENSIVE", new[]{("Touches","Touches"),("Drive","Drive"),("3-Point","ThreePt"),("Mid-Range","MidRange"),("Post-Up","PostUp"),("Isolation","Iso"),("Pull-Up","PullUp"),("Cut","Cut"),("Off Rebound","OffReb")})
                    @TendGroup("DEFENSIVE", new[]{("Steal","Steal"),("Block","Block")})
                </div>
            }
            else if (_detailTab == "injuries")
            {
                var hist = _detailPlayer.InjuryHistory;
                if (hist.Count == 0)
                {
                    <div style="color:#444;padding:1.5rem 0;font-size:0.9rem;">No injuries this season.</div>
                }
                else
                {
                    int totalMissed = hist.Sum(r => r.GamesMissed);
                    int permCount   = hist.Count(r => r.HadPermanentDebuff);
                    <div style="font-size:0.82rem;color:#555;margin-bottom:0.75rem;">
                        @hist.Count injur@(hist.Count == 1 ? "y" : "ies") &nbsp;·&nbsp; @totalMissed games missed
                        @if (permCount > 0) { <span style="color:#f06060;">&nbsp;·&nbsp; @permCount with permanent effects</span> }
                    </div>
                    <div class="scroll-x">
                    <table style="width:100%;font-size:0.85rem;border-collapse:collapse;">
                        <thead>
                            <tr style="border-bottom:1px solid #252525;">
                                <th style="color:#444;font-weight:600;text-align:left;padding:3px 8px 3px 0;white-space:nowrap;">DATE</th>
                                <th style="color:#444;font-weight:600;text-align:left;padding:3px 6px;">INJURY</th>
                                <th style="color:#444;font-weight:600;text-align:left;padding:3px 6px;">BODY PART</th>
                                <th style="color:#444;font-weight:600;text-align:center;padding:3px 6px;">GRD</th>
                                <th style="color:#444;font-weight:600;text-align:right;padding:3px 6px;">EST.</th>
                                <th style="color:#444;font-weight:600;text-align:right;padding:3px 6px;">ACTUAL</th>
                                <th style="color:#444;font-weight:600;text-align:right;padding:3px 6px;">MISSED</th>
                                <th style="color:#444;font-weight:600;text-align:left;padding:3px 6px;">PERM LOSS</th>
                            </tr>
                        </thead>
                        <tbody>
                        @foreach (var rec in hist.OrderByDescending(r => r.InjuredDate))
                        {
                            var gc = rec.Grade == 3 ? "#f06060" : rec.Grade == 2 ? "#fca" : "#88dd88";
                            var permStr = rec.PermanentPenalties?.Count > 0
                                ? string.Join(", ", rec.PermanentPenalties.Select(kv => $"{kv.Key} –{kv.Value}"))
                                : "—";
                            var actualStr = rec.ReturnedDate.HasValue ? $"{rec.ActualDays}d" : $"{rec.ActualDays}d*";
                            <tr style="border-bottom:1px solid #1a1a1a;">
                                <td style="color:#555;padding:3px 8px 3px 0;white-space:nowrap;">@rec.InjuredDate.ToString("MMM d")</td>
                                <td style="padding:3px 6px;">@rec.InjuryName</td>
                                <td style="color:#888;padding:3px 6px;">@rec.BodyPart</td>
                                <td style="text-align:center;color:@gc;font-weight:700;padding:3px 6px;">G@rec.Grade</td>
                                <td style="text-align:right;color:#666;padding:3px 6px;">@(rec.EstimatedDays)d</td>
                                <td style="text-align:right;color:#888;padding:3px 6px;">@actualStr</td>
                                <td style="text-align:right;color:#888;padding:3px 6px;">@rec.GamesMissed</td>
                                <td style="color:@(rec.HadPermanentDebuff?"#f06060":"#555");padding:3px 6px;">@permStr</td>
                            </tr>
                        }
                        </tbody>
                    </table>
                    @if (hist.Any(r => !r.ReturnedDate.HasValue))
                    {
                        <div style="font-size:0.75rem;color:#333;margin-top:4px;">* still injured at season end</div>
                    }
                    </div>
                }
            }
            else if (_detailTab == "career")
            {
                <div class="scroll-x">
                <table style="width:100%;font-size:0.88rem;border-collapse:collapse;">
                    <thead>
                        <tr style="border-bottom:1px solid #252525;">
                            <th style="color:#444;font-weight:600;text-align:left;padding:3px 8px 3px 0;white-space:nowrap;min-width:60px;">SEASON</th>
                            <th style="color:#3a3a3a;font-weight:400;text-align:left;padding:3px 6px;white-space:nowrap;">TEAM</th>
                            <th style="color:#555;font-weight:400;text-align:center;padding:3px 6px;">GP</th>
                            <th style="color:#555;font-weight:400;text-align:center;padding:3px 6px;">MIN</th>
                            <th style="color:#c8a840;font-weight:600;text-align:center;padding:3px 6px;">PTS</th>
