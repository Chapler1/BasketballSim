                        @LeagueTh("touch",    "TOUCH%")
                        @LeagueTh("touchpg",  "TCH/G")
                        @LeagueTh("shotrate", "SA/TCH")
                        @LeagueTh("fgm",      "FGM")
                        @LeagueTh("fga",     "FGA")
                        @LeagueTh("fg",      "FG%")
                        @LeagueTh("3pm",     "3PM")
                        @LeagueTh("3pa",     "3PA")
                        @LeagueTh("3p",      "3P%")
                        @LeagueTh("ftm",     "FTM")
                        @LeagueTh("fta",     "FTA")
                        @LeagueTh("ft",      "FT%")
                        @LeagueTh("ofg",     "oFG%")
                    </tr>
                </thead>
                <tbody>
                    @foreach (var p in SortedLeaguePlayers())
                    {
