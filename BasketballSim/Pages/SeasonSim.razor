    // ── Lifecycle ─────────────────────────────────────────────────────────────
    protected override Task OnInitializedAsync()
    {
        if (RosterSvc.HasData)
        {
            _teams = RosterSvc.LoadTeams();
            _phase = Phase.Ready;
        }
        return Task.CompletedTask;
    }

    // ── ESPN fetch + sync ─────────────────────────────────────────────────────
    private int _syncUpdated, _syncAdded, _syncFreed;

    private async Task FetchRosters()
    {
        _phase = Phase.Fetching; _fetchDone = 0;
        StateHasChanged();
        var progress = new Progress<(int done, int total)>(p =>
        {
            _fetchDone = p.done; _fetchTotal = p.total;
            InvokeAsync(StateHasChanged);
        });
        await RosterSvc.FetchAndSaveAsync(progress);

        _phase = Phase.Syncing;
        StateHasChanged();
        (_syncUpdated, _syncAdded, _syncFreed) = await PlayerSvc.SyncRostersAsync();

        _teams = RosterSvc.LoadTeams();
        _phase = Phase.Ready;
        StateHasChanged();
    }

    // ── Simulate ──────────────────────────────────────────────────────────────
    private async Task SimulateSeason()
    {
        _phase = Phase.Simulating; _gamesPlayed = 0; _season = null; _playoffs = null; _awards = null; _statsTab = "players";
        StateHasChanged();
        var progress = new Progress<(int current, int total)>(p =>
        {
            _gamesPlayed = p.current;
            InvokeAsync(StateHasChanged);
        });
        _season    = await Task.Run(() => SeasonSvc.SimulateSeason(_teams, progress, disableInjuries: _disableInjuries));
        _awards    = SeasonScheduleService.ComputeAwards(_season);
        _savedPath = await Task.Run(() => SaveResults(_season));
        _phase = Phase.Done;
        StateHasChanged();
    }

    private async Task SimulatePlayoffs()
    {
        // Resolve the season result from whichever mode produced it
        SeasonResult? seasonResult = _season ?? _liveState?.Result;
        IReadOnlyDictionary<string, Team> teams = (_liveState is not null)
            ? _liveState.Teams
            : _teams;
        if (seasonResult is null) return;

        _phase = Phase.Playoffs; _playoffGamesPlayed = 0; _playoffGamesTotal = 83;
        _simError = null;
        StateHasChanged();
        var progress = new Progress<(int done, int total)>(p =>
        {
            _playoffGamesPlayed = p.done;
            if (p.total > 0) _playoffGamesTotal = p.total;
            InvokeAsync(StateHasChanged);
        });
        try
        {
            _playoffs = await Task.Run(() => SeasonSvc.SimulatePlayoffs(teams, seasonResult, progress));
        }
        catch (Exception ex)
        {
            _simError = $"Playoff sim error: {ex.Message}";
            _phase = _season is not null ? Phase.Done : Phase.LiveSeason;
            StateHasChanged();
            return;
        }
        // Keep the awards computation using the resolved season result
        _awards = SeasonScheduleService.ComputeAwards(seasonResult);
        // If we came from LiveSeason, promote the result so Phase.Done renders properly
        if (_season is null && _liveState?.Result is not null)
            _season = _liveState.Result;
        _phase    = Phase.Done;
        _statsTab = "playoffs";
        StateHasChanged();
    }

