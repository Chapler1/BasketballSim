                </select>
                <label style="display:flex;align-items:center;gap:5px;cursor:pointer;font-size:0.82rem;color:@(_leagueEligOnly?"#fca":"#444");white-space:nowrap;">
                    <input type="checkbox" @bind="_leagueEligOnly" style="cursor:pointer;accent-color:#fca;" />
