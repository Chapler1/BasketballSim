    // ── Sorting helpers ───────────────────────────────────────────────────────
    private void SetLeagueSort(string col)
    {
        if (_leagueSort == col) _leagueSortAsc = !_leagueSortAsc;
        else { _leagueSort = col; _leagueSortAsc = false; }
    }

    private IEnumerable<PlayerSeasonStats> SortedLeaguePlayers()
    {
        var q = _season!.PlayerStats.Where(p => p.GP > 0).AsEnumerable();
        if (_leagueEligOnly)
            q = q.Where(p => p.GP >= 41 && p.Mpg >= 15.0);
        if (_leagueSearch.Length > 1)
            q = q.Where(p => p.Name.Contains(_leagueSearch, StringComparison.OrdinalIgnoreCase));
        if (_leagueTeamFilter.Length > 0)
            q = q.Where(p => p.Team == _leagueTeamFilter);
        return ApplySort(q, _leagueSort, _leagueSortAsc);
    }

    private void SetTeamSort(string col)
    {
        if (_teamSort == col) _teamSortAsc = !_teamSortAsc;
        else { _teamSort = col; _teamSortAsc = col is "losses" or "papg" or "tov"; }
    }

    private IEnumerable<TeamSeasonStats> SortedTeams()
    {
        if (_season is null) return [];
        Func<TeamSeasonStats, double> key = _teamSort switch
        {
            "wins"   => t => t.Wins,
            "losses" => t => t.Losses,
            "pct"    => t => t.Pct,
            "ppg"    => t => t.Ppg,
            "papg"   => t => t.Papg,
            "diff"   => t => t.Ppg - t.Papg,
            "fgm"    => t => t.Fgm,
            "fga"    => t => t.Fga,
            "fgpct"  => t => t.FgPct,
            "tpm"    => t => t.Tpm,
            "tpa"    => t => t.Tpa,
            "tppct"  => t => t.TpPct,
            "ftm"    => t => t.Ftm,
            "fta"    => t => t.Fta,
            "ftpct"  => t => t.FtPct,
            "oreb"   => t => t.Oreb,
            "dreb"   => t => t.Dreb,
            "reb"    => t => t.Reb,
            "ast"    => t => t.Ast,
            "stl"    => t => t.Stl,
            "blk"    => t => t.Blk,
            "tov"    => t => t.Tov,
            "pace"   => t => t.Pace,
            _        => t => t.Wins,
        };
        return _teamSortAsc
            ? _season.TeamStats.OrderBy(key)
            : _season.TeamStats.OrderByDescending(key);
    }

    private static IEnumerable<PlayerSeasonStats> ApplySort(
        IEnumerable<PlayerSeasonStats> src, string col, bool asc)
    {
        Func<PlayerSeasonStats, double> key = col switch
        {
            "pts" => p => p.Ppg,
            "reb" => p => p.Rpg,
            "orb" => p => p.Opg,
            "drb" => p => p.Dpg,
            "ast" => p => p.Apg,
            "stl" => p => p.Spg,
            "blk" => p => p.Bpg,
            "tov" => p => p.Topg,
            "min"  => p => p.Mpg,
            "gp"   => p => p.GP,
            "inj"  => p => p.GamesInjured,
            "rest" => p => p.GamesRested,
            "sf"   => p => p.AvgSeasonFatigue,
            "fg"      => p => p.FgPct,
            "3p"      => p => p.TpPct,
            "ft"      => p => p.FtPct,
            "fgm"     => p => p.Fgm,
            "fga"     => p => p.Fga,
            "3pm"     => p => p.Tpm,
            "3pa"     => p => p.Tpa,
            "ftm"     => p => p.Ftm,
            "fta"     => p => p.Fta,
            "pm"       => p => p.AvgPlusMinus,
            "shotpct"  => p => p.ShotSharePct,
            "touch"    => p => p.TouchPct,
            "touchpg"  => p => p.TouchesPg,
            "shotrate" => p => p.ShotAttemptRate,
            "per"      => p => p.PER,
            "ows"      => p => p.OWS,
            "dws"      => p => p.DWS,
            "ws"       => p => p.WS,
            "ws48"     => p => p.WS48,
            "ofg"      => p => p.OppFgPct,
            "ts"       => p => p.TsPct,
            "efg"      => p => p.EfgPct,
            "3par"     => p => p.TotalFGA > 0 ? (double)p.TotalThreeAtt / p.TotalFGA : 0,
            "ftr"      => p => p.TotalFGA > 0 ? (double)p.TotalFTA / p.TotalFGA : 0,
            "orbpct"   => p => p.OrebPct,
            "drbpct"   => p => p.DrebPct,
            "rebpct"   => p => p.RebPct,
            "astpct"   => p => p.AstPct,
            "usgpct"   => p => p.UsgPct,
            "ortg"     => p => p.OffRating,
            "drtg"     => p => p.DefRating,
            "nrtg"     => p => p.NetRating,
            _          => p => p.Ppg,
        };
        return asc ? src.OrderBy(key) : src.OrderByDescending(key);
    }

