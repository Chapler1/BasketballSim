                                <td style="text-align:center;padding:3px 6px;color:#3a88a0;">@s.Ast.ToString("F1")</td>
                                <td style="text-align:center;padding:3px 6px;color:#608850;">@s.Stl.ToString("F1")</td>
                                <td style="text-align:center;padding:3px 6px;color:#905030;">@s.Blk.ToString("F1")</td>
                                <td style="text-align:center;padding:3px 6px;color:#a03030;">@s.Tov.ToString("F1")</td>
                                <td style="text-align:center;padding:3px 6px;color:#777;">@s.Fgm.ToString("F1")</td>
                                <td style="text-align:center;padding:3px 6px;color:#555;">@s.Fga.ToString("F1")</td>
