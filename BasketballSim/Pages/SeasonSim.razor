    {
        if (_livePlayoffs is null || _simBusy) return;
        var round = GetRoundForSeries(series);
        if (round is null) return;
        _bracketPopupSeries = null;
        _simBusy = true; _simError = null;
        StateHasChanged();
        try
        {
            await Task.Run(() => SeasonSvc.SimPlayoffRound(_livePlayoffs, round));
            if (_livePlayoffs.IsComplete) { _playoffs = _livePlayoffs.Result; }
        }
        catch (Exception ex) { _simError = $"Sim error: {ex.Message}"; }
        finally { _simBusy = false; }
        StateHasChanged();
    }

