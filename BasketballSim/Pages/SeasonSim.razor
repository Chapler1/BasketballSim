        // Open watch modal — user presses Start to begin playback
        _watchGame       = captured;
        _watchDone       = false;
        _watchStarted    = false;
        _watchBoxTab     = "players";
        _watchHomeScore  = 0;
        _watchAwayScore  = 0;
        _watchQuarter    = 1;
        _watchClockSec   = 720;
