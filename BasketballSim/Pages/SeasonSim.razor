    private async Task SimulatePlayoffs()
    {
        SeasonResult? seasonResult = _season ?? _liveState?.Result;
        IReadOnlyDictionary<string, Team> teams = (_liveState is not null) ? _liveState.Teams : _teams;
        if (seasonResult is null) return;

        _simError = null;
        _livePlayoffs = null;
        StateHasChanged();

        // Initialize live playoffs (runs play-in instantly, then R1 bracket is ready)
        try
        {
            _livePlayoffs = await Task.Run(() => SeasonSvc.InitializeLivePlayoffs(teams, seasonResult));
        }
        catch (Exception ex)
        {
            _simError = $"Playoff init error: {ex.Message}";
            StateHasChanged();
            return;
        }

        _awards = SeasonScheduleService.ComputeAwards(seasonResult);
        if (_season is null && _liveState?.Result is not null)
            _season = _liveState.Result;
        _phase    = Phase.Done;
        _statsTab = "players";
        StateHasChanged();
    }

    private async Task SimInstantPlayoffs()
    {
        SeasonResult? seasonResult = _season ?? _liveState?.Result;
        IReadOnlyDictionary<string, Team> teams = (_liveState is not null) ? _liveState.Teams : _teams;
