@page "/season"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@using BasketballSim.Models
@using BasketballSim.Services
@using BasketballSim.Simulation
@using System.Text.Json
@using Microsoft.AspNetCore.Components.Web
@using static Microsoft.AspNetCore.Components.Web.RenderMode
@implements IAsyncDisposable
@inject NbaRosterService RosterSvc
@inject SeasonScheduleService SeasonSvc
@inject PlayerDataService PlayerSvc
@inject HistoricalStatsService HistSvc

<PageTitle>Season Sim</PageTitle>

<style>
    .ssim { font-family: monospace; color: #d4d4d4; background: #111; }
    .ssim table { border-collapse: collapse; width: 100%; font-size: 0.83rem; }
    .ssim th { padding: 5px 7px; color: #888; font-weight: 600; letter-spacing: 0.5px; border-bottom: 1px solid #2a2a2a; white-space: nowrap; user-select: none; font-size: 0.78rem; }
    .ssim th.sort-active { color: #fca; }
    .ssim th[data-sortable] { cursor: pointer; }
    .ssim th[data-sortable]:hover { color: #c8c8c8; }
    .ssim td { padding: 4px 7px; border-bottom: 1px solid #1e1e1e; white-space: nowrap; color: #c8c8c8; }
    .ssim tr:hover td { background: #1e1e1e; }
    .ssim .section-title { font-size: 0.85rem; font-weight: 700; color: #888; letter-spacing: 2px; margin-bottom: 6px; }
    .ssim .scroll-x { overflow-x: auto; }
    .ssim .tag-playoff { background: #0d1a0d; }
    .ssim .tag-playin  { background: #0d0d1a; }
    .ssim input[type=text] { background: #1a1a1a; color: #d4d4d4; border: 1px solid #333; padding: 4px 10px; border-radius: 4px; font-family: monospace; font-size: 0.93rem; outline: none; }
    .ssim input[type=text]:focus { border-color: #555; }
    .ssim select { background: #1a1a1a; color: #d4d4d4; border: 1px solid #333; padding: 4px 10px; border-radius: 4px; font-family: monospace; font-size: 0.93rem; cursor: pointer; }
    .ssim tr.clickable-row { cursor: pointer; }
    .pdlg-tab { background:none;border:none;padding:6px 16px;font-family:monospace;font-size:0.88rem;cursor:pointer;letter-spacing:0.5px;border-bottom:2px solid transparent; }
    .pdlg-tab.active { color:#fca;border-bottom-color:#fca; }
    .pdlg-tab:not(.active) { color:#666; }
    .pdlg-attr { display:flex;align-items:center;gap:6px;margin:2px 0; }
    .pdlg-attr-label { width:82px;color:#777;font-size:0.82rem;text-align:right; }
    .pdlg-attr-bar-bg { width:90px;background:#1a1a1a;height:3px;border-radius:2px; }
    .pdlg-attr-val { width:22px;color:#c8c8c8;font-size:0.84rem;text-align:right;font-weight:600; }
    .pdlg-qs { flex:1;min-width:44px;text-align:center;padding:5px 3px;border-right:1px solid #1a1a1a; }
    .pdlg-qs:last-child { border-right:none; }
    .pdlg-qs-label { font-size:0.68rem;color:#555;letter-spacing:0.5px;margin-bottom:1px; }
    .pdlg-qs-val { font-size:0.93rem;font-weight:600; }
    .glog-row { display:grid;grid-template-columns:72px 22px 44px 1fr 36px;gap:0 6px;align-items:center;padding:3px 0;border-bottom:1px solid #181818;font-size:0.88rem; }
    .glog-row:hover { background:#1e1e1e; }
    .glog-w { color:#4af080;font-weight:700; }
    .glog-l { color:#f06060;font-weight:700; }
    .hiw-section { border:1px solid #1e1e1e;border-radius:4px;margin-bottom:6px;overflow:hidden; }
    .hiw-header { width:100%;background:#111;border:none;color:#aaa;font-family:monospace;font-size:0.88rem;font-weight:700;letter-spacing:1px;text-align:left;padding:9px 14px;cursor:pointer;display:flex;justify-content:space-between;align-items:center; }
    .hiw-header:hover { background:#161616; }
    .hiw-body { padding:12px 16px;background:#0d0d0d;font-size:0.84rem;line-height:1.65;color:#999; }
    .hiw-body strong { color:#d4d4d4; }
    .hiw-body .kv { display:flex;gap:0.5rem;margin:2px 0; }
    .hiw-body .kv-label { color:#666;min-width:130px;flex-shrink:0; }
    .hiw-body .kv-val { color:#bbb; }
    .hiw-chip { display:inline-block;background:#1a1a1a;border:1px solid #2a2a2a;border-radius:3px;padding:1px 7px;font-size:0.78rem;color:#888;margin:1px 2px; }
    @@keyframes watchEntryFlash {
        0%   { background-color: rgba(255,200,80,0.22); }
        100% { background-color: transparent; }
    }
    .watch-entry { animation: watchEntryFlash 1.8s ease-out forwards; }
    .wm-tab { background:none;border:none;padding:7px 18px;font-family:monospace;font-size:0.82rem;cursor:pointer;letter-spacing:0.5px;border-bottom:2px solid transparent;color:#666; }
    .wm-tab.active { color:#c8c8c8;border-bottom-color:#fca; }
    .wm-tab:not(.active):hover { color:#888; }
    .wm-oncourt { background:#111a11; }
    .wm-bench   { background:transparent; }
    .wm-player-row td { padding:3px 6px;border-bottom:1px solid #141414;white-space:nowrap; }
    .wm-player-row:hover td { background:#1a1a1a; }
    .wm-team-hdr { font-size:0.72rem;color:#555;letter-spacing:1.5px;padding:4px 8px;border-bottom:1px solid #141414;background:#0a0a0a; }
    .sbar-row { display:flex;align-items:center;gap:4px;padding:3px 8px;cursor:pointer;border-bottom:1px solid #111; }
    .sbar-row:hover { background:#1a1a1a; }
    .stats-frozen { position:sticky;left:0;z-index:1;background:#111; }
    .ssim tr:hover .stats-frozen { background:#1e1e1e; }
    .stats-thead th { position:sticky;top:0;background:#111;z-index:2; }
    .stats-thead .stats-frozen { z-index:3; }
</style>

<div class="ssim" style="position:fixed;inset:0;display:flex;flex-direction:column;overflow:hidden;">
@if (_phase == Phase.NeedFetch)
{
    <div style="text-align:center;padding:4rem 0;">
        <div style="color:#555;font-size: 1.0rem;margin-bottom:0.4rem;">No roster data found.</div>
        <div style="color:#444;font-size: 0.9rem;margin-bottom:1.5rem;">Fetch once from ESPN to cache rosters locally.</div>
        <button @onclick="FetchRosters" style="background:#3a2a1a;color:#fca;border:1px solid #6a4a2a;padding:10px 36px;border-radius:5px;cursor:pointer;font-size: 1.05rem;font-family:monospace;font-weight:700;">↓ Fetch Rosters from ESPN</button>
    </div>
}
else if (_phase == Phase.Fetching)
{
    <div style="text-align:center;padding:4rem 0;color:#555;">
        <div style="margin-bottom:0.5rem;">Fetching rosters… @_fetchDone / @_fetchTotal teams</div>
        <div style="background:#1a1a1a;border-radius:4px;height:6px;width:320px;margin:0 auto;">
            <div style="background:#fca;height:6px;border-radius:4px;width:@(_fetchTotal>0?_fetchDone*100/_fetchTotal:0)%;transition:width 0.2s;"></div>
        </div>
    </div>
}
else if (_phase == Phase.Syncing)
{
    <div style="text-align:center;padding:4rem 0;color:#555;">
        <div>Syncing players.json…</div>
    </div>
}
else if (_phase == Phase.Ready)
{
    <!-- ═══ LANDING PAGE ═══ -->
    <div style="padding:1.25rem 0 2rem;">
        <div style="text-align:center;margin-bottom:1.5rem;">
            <div style="font-size:1.7rem;font-weight:800;color:#e8e8e8;letter-spacing:3px;">NBA SEASON SIM</div>
            <div style="font-size:0.82rem;color:#3a3a3a;letter-spacing:2px;margin-top:3px;">2025–26 · 82 GAMES · 30 TEAMS · 1,230 MATCHUPS</div>
            @if (_syncAdded > 0 || _syncFreed > 0 || _syncUpdated > 0)
            {
                <div style="font-size:0.73rem;color:#2a2a2a;margin-top:5px;">Last sync: @_syncUpdated traded · @_syncAdded new · @_syncFreed free agents</div>
            }
        </div>

        <!-- Team logo grid -->
        <div style="text-align:center;font-size:0.7rem;color:#2a2a2a;letter-spacing:2px;margin-bottom:8px;">SELECT A TEAM TO FOLLOW (OPTIONAL)</div>
        <div style="display:flex;flex-wrap:wrap;justify-content:center;gap:6px;max-width:900px;margin:0 auto 1.75rem;">
        @foreach (var (name, team) in _teams.OrderBy(t => t.Value.Abbreviation))
        {
            bool sel = _selectedTeam == name;
            <div @onclick="() => { _selectedTeam = sel ? string.Empty : name; }"
                 style="cursor:pointer;background:@(sel?"#0d1a0d":"#0e0e0e");border:1px solid @(sel?"#2a4a2a":"#1e1e1e");border-radius:5px;padding:5px 6px;width:76px;text-align:center;">
                <img src="/logos/teams/@(LogoSlug(name)).svg"
                     style="width:36px;height:36px;object-fit:contain;display:block;margin:0 auto 3px;"
                     onerror="this.style.display='none'" />
                <div style="font-size:0.68rem;color:@(sel?"#4af080":"#484848");font-weight:@(sel?"700":"400");letter-spacing:0.5px;">@team.Abbreviation</div>
            </div>
        }
        </div>

        <!-- Controls -->
        <div style="display:flex;align-items:center;justify-content:center;gap:0.75rem;flex-wrap:wrap;">
            <button @onclick="() => _disableInjuries = !_disableInjuries"
                    style="background:@(_disableInjuries?"#2a1a1a":"#141414");color:@(_disableInjuries?"#f88":"#444");border:1px solid @(_disableInjuries?"#4a2a2a":"#242424");padding:7px 14px;border-radius:4px;cursor:pointer;font-family:monospace;font-size:0.83rem;">
                @(_disableInjuries ? "✕ Injuries OFF" : "✓ Injuries ON")
            </button>
            <button @onclick="StartLiveSeason"
                    style="background:#0d2a0d;color:#4af080;border:1px solid #1a4a1a;padding:10px 36px;border-radius:5px;cursor:pointer;font-weight:700;font-size:1.05rem;font-family:monospace;">
                ▶ Start Live Season
            </button>
            <button @onclick="SimulateSeason"
                    style="background:#0d0d2a;color:#8ab8ff;border:1px solid #1a1a4a;padding:10px 36px;border-radius:5px;cursor:pointer;font-size:1.0rem;font-family:monospace;">
                Simulate Instantly
            </button>
        </div>
        <div style="text-align:center;margin-top:0.75rem;">
            <button @onclick="FetchRosters" style="background:none;border:none;color:#2a2a2a;font-size:0.78rem;cursor:pointer;font-family:monospace;">↺ Re-fetch rosters from ESPN</button>
        </div>
    </div>
}
else if (_phase == Phase.Simulating)
{
    <div style="text-align:center;padding:4rem 0;color:#555;">
        <div style="margin-bottom:0.5rem;">Simulating… @_gamesPlayed / 1,230 games</div>
        <div style="background:#1a1a1a;border-radius:4px;height:6px;width:320px;margin:0 auto;">
            <div style="background:#4af080;height:6px;border-radius:4px;width:@(_gamesPlayed*100/1230)%;transition:width 0.15s;"></div>
        </div>
    </div>
}
else if (_phase == Phase.Playoffs)
{
    <div style="text-align:center;padding:4rem 0;color:#555;">
        <div style="margin-bottom:0.5rem;">Simulating playoffs… @_playoffGamesPlayed games played</div>
        <div style="background:#1a1a1a;border-radius:4px;height:6px;width:320px;margin:0 auto;">
            <div style="background:#fca;height:6px;border-radius:4px;width:@(_playoffGamesTotal > 0 ? Math.Min(_playoffGamesPlayed * 100 / _playoffGamesTotal, 100) : 0)%;transition:width 0.15s;"></div>
        </div>
    </div>
}
else if ((_phase == Phase.LiveSeason && _liveState is not null) || (_phase == Phase.Done && _season is not null))
{
    bool isLive = _phase == Phase.LiveSeason;
    string followedTeam = isLive ? (_liveState?.FollowedTeam ?? "") : (_liveState?.FollowedTeam ?? _selectedTeam);
    bool hasFollowed = followedTeam.Length > 0;
    var standingsValues = isLive
        ? (IList<TeamSeasonStats>)_liveState!.Standings.Values.ToList()
        : (IList<TeamSeasonStats>)_season!.TeamStats;
    var myTeamStats = hasFollowed ? standingsValues.FirstOrDefault(t => t.TeamName.Equals(followedTeam, StringComparison.OrdinalIgnoreCase)) : null;
    IEnumerable<PlayerSeasonStats> statPlayers;
    if (isLive && _liveState is not null)
    {
        var lp = _liveState.PlayerAgg.Values.Where(p => p.GP > 0).ToList();
        // Populate TeamPossEventsPg from live standings: total team on-court events
        // = TotalTeamFGAOnCourt scaled by team (FGA+0.44*FTA+TOV)/FGA ratio.
        foreach (var p in lp)
            if (_liveState.Standings.TryGetValue(p.Team, out var tmStats))
            {
                double possScale = tmStats.Fga > 0
                    ? (tmStats.Fga + 0.44 * tmStats.Fta + tmStats.Tov) / tmStats.Fga : 1.26;
                p.TeamPossEventsPg = p.TotalTeamFGAOnCourt * possScale;
            }
        IEnumerable<PlayerSeasonStats> lpe = lp;
        if (_leagueSearch.Length > 1) lpe = lpe.Where(p => p.Name.Contains(_leagueSearch, StringComparison.OrdinalIgnoreCase));
        if (_leagueTeamFilter.Length > 0) lpe = lpe.Where(p => p.Team == _leagueTeamFilter);
        statPlayers = ApplySort(lpe, _leagueSort, _leagueSortAsc);
    }
    else { statPlayers = SortedLeaguePlayers(); }
    var teamStatsOrdered = isLive
        ? (IList<TeamSeasonStats>)_liveState!.Standings.Values.Where(t => t.GP > 0).OrderByDescending(t => t.Wins).ToList()
        : (IList<TeamSeasonStats>)SortedTeams().ToList();
    // Precompute current injury status for live season player badges
    var injStatus = new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase);
    if (isLive && _liveState is not null)
        foreach (var _t in _liveState.Teams.Values)
        foreach (var _rp in _t.Roster)
            if (_rp.CurrentInjury is not null)
                injStatus[_rp.Name] = _rp.CurrentInjury.Definition.Grade >= 2 ? "Out" : "DTD";

    <!-- HEADER BAR -->
    <div style="flex-shrink:0;display:flex;align-items:center;gap:6px;padding:5px 10px;background:#0f0f0f;border-bottom:1px solid #1e1e1e;min-height:40px;">
        <span style="font-size:0.65rem;color:#555;letter-spacing:2px;font-weight:700;flex-shrink:0;">SEASON SIM</span>
        @if (hasFollowed && myTeamStats is not null)
        {
            <span style="color:#2a2a2a;flex-shrink:0;">|</span>
            <img src="/logos/teams/@(LogoSlug(followedTeam)).svg" style="width:13px;height:13px;object-fit:contain;flex-shrink:0;" onerror="this.style.display='none'" />
            <span style="color:#fca;font-size:0.78rem;font-weight:700;flex-shrink:0;">@myTeamStats.Abbreviation</span>
            <span style="color:#4af080;font-size:0.76rem;flex-shrink:0;">@myTeamStats.Wins&#x2013;@myTeamStats.Losses</span>
        }
        <div style="flex:1;"></div>
        @if (isLive && _liveState is not null)
        {
            @if (!_liveState.IsComplete)
            {
                <button @onclick="SimOneDayLive" disabled="@_simBusy"
                        style="background:#141414;color:@(_simBusy?"#333":"#888");border:1px solid #222;padding:4px 11px;border-radius:3px;cursor:@(_simBusy?"default":"pointer");font-family:monospace;font-size:0.76rem;flex-shrink:0;">Day</button>
                <button @onclick="ToggleAutoSim" disabled="@_simBusy"
                        style="background:@(_isAutoSimming?"#2a1a0a":"#141414");color:@(_simBusy?"#333":_isAutoSimming?"#fca":"#888");border:1px solid @(_isAutoSimming?"#4a3a1a":"#222");padding:4px 11px;border-radius:3px;cursor:@(_simBusy?"default":"pointer");font-family:monospace;font-size:0.76rem;flex-shrink:0;">@(_isAutoSimming ? "Pause" : "Auto")</button>
                <button @onclick="SimRestOfSeasonLive" disabled="@_simBusy"
                        style="background:@(_simBusy?"#0d0d1a":"#0d0d2a");color:@(_simBusy?"#444":"#8ab8ff");border:1px solid #1a1a4a;padding:4px 11px;border-radius:3px;cursor:@(_simBusy?"default":"pointer");font-family:monospace;font-size:0.76rem;flex-shrink:0;">@(_simBusy?"Simming...":"Sim Rest")</button>
                <span style="color:#1a1a1a;flex-shrink:0;">|</span>
                <span style="color:#4af080;font-weight:700;font-size:0.7rem;flex-shrink:0;">&#x25CF;</span>
                <span style="color:#5a8a5a;font-size:0.74rem;flex-shrink:0;">@_liveState.CurrentDate.ToString("MMM d, yyyy")</span>
                <span style="color:#3a3a3a;font-size:0.7rem;flex-shrink:0;">@(_liveState.DateIndex+1)/@_liveState.TotalScheduledDays</span>
            }
            else
            {
                <span style="color:#4af080;font-size:0.74rem;font-weight:700;flex-shrink:0;">SEASON COMPLETE</span>
                @if (_livePlayoffs is null && _playoffs is null)
                {
                    <button @onclick="SimulatePlayoffs"
                            style="background:#1a1a2a;color:#cdf;border:1px solid #2a2a4a;padding:4px 11px;border-radius:3px;cursor:pointer;font-family:monospace;font-size:0.76rem;flex-shrink:0;">&#x25B6; Playoffs</button>
                    <button @onclick="SimInstantPlayoffs"
                            style="background:none;color:#3a3a5a;border:1px solid #1e1e2e;padding:4px 9px;border-radius:3px;cursor:pointer;font-family:monospace;font-size:0.72rem;flex-shrink:0;">instant</button>
                }
            }
        }
        else
        {
            @if (_playoffs is null && _livePlayoffs is null)
            {
                <button @onclick="SimulatePlayoffs"
                        style="background:#1a1a2a;color:#cdf;border:1px solid #2a2a4a;padding:4px 11px;border-radius:3px;cursor:pointer;font-family:monospace;font-size:0.76rem;flex-shrink:0;">&#x25B6; Playoffs</button>
                <button @onclick="SimInstantPlayoffs"
                        style="background:none;color:#3a3a5a;border:1px solid #1e1e2e;padding:4px 9px;border-radius:3px;cursor:pointer;font-family:monospace;font-size:0.72rem;flex-shrink:0;">instant</button>
            }
            @if ((_playoffs?.Champion ?? _livePlayoffs?.Result.Champion) is not null)
            {
                <span style="color:#fca;font-size:0.74rem;font-weight:700;flex-shrink:0;">@(_playoffs?.ChampionAbbr ?? _livePlayoffs?.Result.ChampionAbbr) CHAMPS</span>
            }
            <button @onclick="SimulateSeason"
                    style="background:#141414;color:#888;border:1px solid #222;padding:4px 11px;border-radius:3px;cursor:pointer;font-family:monospace;font-size:0.76rem;flex-shrink:0;">&#x21BA; Re-sim</button>
        }
        <button @onclick="() => _showHowItWorks = true"
                style="background:none;border:1px solid #2a2a2a;color:#444;border-radius:50%;width:20px;height:20px;cursor:pointer;font-family:monospace;font-size:0.72rem;display:flex;align-items:center;justify-content:center;flex-shrink:0;padding:0;line-height:1;">?</button>
    </div>

    <!-- ERROR BANNER -->
    @if (_simError is not null)
    {
        <div style="flex-shrink:0;background:#2a0a0a;border-bottom:1px solid #4a1a1a;padding:5px 12px;font-size:0.8rem;color:#f06060;display:flex;justify-content:space-between;align-items:center;">
            <span>&#x26A0; @_simError</span>
            <button @onclick="() => _simError = null" style="background:none;border:none;color:#f06060;cursor:pointer;font-size:0.9rem;padding:0 4px;">&#x2715;</button>
        </div>
    }

    <!-- CHAMPION STRIP -->
    @if ((_playoffs ?? _livePlayoffs?.Result) is {} champResult && champResult.Champion is not null)
    {
        string champOpp    = champResult.Finals is not null
            ? (champResult.Finals.HighSeedTeam == champResult.Champion ? champResult.Finals.LowSeedTeam : champResult.Finals.HighSeedTeam)
            : "";
        string champSeries = champResult.Finals?.SeriesScore ?? "";
        <div style="flex-shrink:0;display:flex;align-items:center;justify-content:center;gap:8px;padding:5px 12px;background:#0d0900;border-bottom:1px solid #2a1800;">
            <span style="font-size:0.6rem;color:#665;letter-spacing:2px;">NBA CHAMPION</span>
            <img src="/logos/teams/@(LogoSlug(champResult.Champion)).svg" style="width:13px;height:13px;object-fit:contain;" onerror="this.style.display='none'" />
            <span style="font-size:0.85rem;font-weight:800;color:#fca;letter-spacing:1px;">@champResult.Champion</span>
            @if (champOpp.Length > 0) { <span style="font-size:0.76rem;color:#554;">def. @champOpp &#x2014; @champSeries</span> }
        </div>
    }

    <!-- BODY -->
    <div style="flex:1;display:flex;overflow:hidden;">

        <!-- SIDEBAR: East/West standings -->
        <div style="width:250px;flex-shrink:0;overflow-y:auto;border-right:1px solid #1a1a1a;font-size:0.82rem;">
            @foreach (var confName in new[] { "Eastern", "Western" })
            {
                var confTeams = standingsValues
                    .Where(t => t.Conference == confName)
                    .OrderByDescending(t => t.Wins).ThenBy(t => t.Losses).ToList();
                var confLeader = confTeams.FirstOrDefault();
                <div style="padding:5px 10px;font-size:0.6rem;color:#555;letter-spacing:2px;border-bottom:1px solid #181818;background:#0a0a0a;position:sticky;top:0;z-index:1;display:flex;justify-content:space-between;">
                    <span>@confName.ToUpper()</span>
                    <span style="color:#333;letter-spacing:0;">W &nbsp; L &nbsp; GB</span>
                </div>
                @for (int ri = 0; ri < confTeams.Count; ri++)
                {
                    var t = confTeams[ri];
                    bool isPlayoff = ri < 6;
                    bool isPlayIn  = ri >= 6 && ri < 10;
                    bool isFollow  = t.TeamName.Equals(followedTeam, StringComparison.OrdinalIgnoreCase);
                    double gb = confLeader is null || ri == 0 ? 0 : ((confLeader.Wins - t.Wins) + (t.Losses - confLeader.Losses)) / 2.0;
                    string gbStr = ri == 0 ? "—" : gb.ToString("F1");
                    <div class="sbar-row" @onclick="() => OpenGameLog(t)"
                         style="padding:5px 10px;border-left:3px solid @(isPlayoff?"#1a4a1a":isPlayIn?"#1a1a4a":"transparent");background:@(isFollow?"#141408":"transparent");">
                        <span style="color:#3a3a3a;width:16px;text-align:right;flex-shrink:0;font-size:0.73rem;">@(ri+1)</span>
                        <img src="/logos/teams/@(LogoSlug(t.TeamName)).svg" style="width:16px;height:16px;object-fit:contain;flex-shrink:0;margin:0 2px;" onerror="this.style.display='none'" />
                        <span style="flex:1;color:@(isFollow?"#fca":isPlayoff?"#c8c8c8":"#777");font-weight:@(isFollow?"700":"400");overflow:hidden;text-overflow:ellipsis;white-space:nowrap;font-size:0.82rem;">@t.Abbreviation</span>
                        <span style="color:#4af080;flex-shrink:0;min-width:20px;text-align:right;font-size:0.82rem;">@t.Wins</span>
                        <span style="color:#2a2a2a;margin:0 1px;">&#x2013;</span>
                        <span style="color:#f06060;flex-shrink:0;min-width:20px;font-size:0.82rem;">@t.Losses</span>
                        <span style="color:#444;flex-shrink:0;min-width:24px;text-align:right;font-size:0.75rem;padding-left:2px;">@gbStr</span>
                    </div>
                    @if (ri == 5 && ri < confTeams.Count - 1)
                    {
                        <div style="border-top:1px dashed #1e1e1e;margin:0;"></div>
                    }
                    @if (ri == 9 && ri < confTeams.Count - 1)
                    {
                        <div style="border-top:1px solid #2a1a1a;margin:0;"></div>
                    }
                }
            }
        </div>

        <!-- MAIN AREA -->
        <div style="flex:1;display:flex;flex-direction:column;overflow:hidden;min-width:0;">

            <!-- CALENDAR / BRACKET -->
            @if (_livePlayoffs is not null)
            {
            <!-- PLAYOFF BRACKET -->
            <div style="flex:0 0 auto;overflow:auto;border-bottom:1px solid #1a1a1a;">
                @{
                    var pr = _livePlayoffs.Result;
                    bool hasPlayIn = pr.PlayInGames.Count >= 6;
                    // card height: ~90px (2 team rows + footer, no min-height, measured empirically)
                    // gap between cards: 8px. label row: ~18px
                    // R2 padding-top = label_h + card_h/2 + gap/2 ≈ 18 + 45 + 4 = 54 (centers R2[0] between R1[0] and R1[1])
                    // ECF padding-top = R2_pt + card_h/2 + gap/2 + card_h/2 = 54+45+4+45 = 108 (wrong; recalc below)
                    // ECF should center between R2[0] and R2[1]:
                    //   R2[0] center = 54+18+45 = 117, R2[1] center = 54+18+90+8+45 = 215
                    //   ECF center = (117+215)/2 = 166, ECF_pt = 166-18-45 = 103
                    // Finals center = ECF center = 166, Finals_pt = 166-18-45 = 103
                }
                <!-- Bracket header with date -->
                <div style="padding:6px 16px;background:#080808;border-bottom:1px solid #141414;display:flex;align-items:center;gap:8px;flex-shrink:0;">
                    <span style="font-size:0.7rem;color:#555;letter-spacing:2px;font-weight:700;">NBA PLAYOFFS</span>
                    @if (_livePlayoffs.CurrentDate != default)
                    {
                        <span style="color:#2a2a2a;">|</span>
                        <span style="font-size:0.75rem;color:#5a8a5a;">@_livePlayoffs.CurrentDate.ToString("MMM d, yyyy")</span>
                    }
                    @if (pr.Champion is not null)
                    {
                        <span style="color:#2a2a2a;">|</span>
                        <img src="/logos/teams/@(LogoSlug(pr.Champion)).svg" style="width:14px;height:14px;object-fit:contain;" onerror="this.style.display='none'" />
                        <span style="font-size:0.8rem;font-weight:700;color:#fca;">@pr.ChampionAbbr CHAMPION</span>
                    }
                </div>
                <!-- Bracket columns — centered when fits, scrollable when wide -->
                <div style="display:flex;justify-content:center;padding:16px 24px;min-width:max-content;">
                <div style="display:flex;gap:14px;align-items:flex-start;">

                    @* East: play-in + R1 wrapped tight *@
                    <div style="display:flex;gap:4px;align-items:flex-start;">
                    @if (hasPlayIn)
                    {
                        var eg3 = pr.PlayInGames[2]; bool eg3hw = eg3.HomeScore > eg3.AwayScore;
                        var eg1 = pr.PlayInGames[0]; bool eg1hw = eg1.HomeScore > eg1.AwayScore;
                        var eg2 = pr.PlayInGames[1]; bool eg2hw = eg2.HomeScore > eg2.AwayScore;
                        <div style="display:flex;flex-direction:column;gap:8px;">
                            <div style="font-size:0.65rem;color:#33336a;letter-spacing:1.5px;text-align:center;margin-bottom:3px;">E PLAY-IN</div>
                            @* G3: consolation → #8 seed (aligns with R1[0]: 1v8) *@
                            <div style="width:148px;display:flex;flex-direction:column;background:#0a0a14;border:1px solid #1a1a2a;border-radius:5px;padding:8px 10px;">
                                <div style="display:flex;align-items:center;gap:5px;margin-bottom:5px;">
                                    <img src="/logos/teams/@(LogoSlug(eg3.HomeTeam)).svg" style="width:20px;height:20px;object-fit:contain;flex-shrink:0;" onerror="this.style.display='none'" />
                                    <span style="flex:1;font-size:0.88rem;color:@(eg3hw?"#d0d0d0":"#444");">@eg3.HomeAbbr</span>
                                    <span style="font-size:1.05rem;font-weight:700;color:@(eg3hw?"#4af080":"#555");">@eg3.HomeScore</span>
                                </div>
                                <div style="display:flex;align-items:center;gap:5px;">
                                    <img src="/logos/teams/@(LogoSlug(eg3.AwayTeam)).svg" style="width:20px;height:20px;object-fit:contain;flex-shrink:0;" onerror="this.style.display='none'" />
                                    <span style="flex:1;font-size:0.88rem;color:@(!eg3hw?"#d0d0d0":"#444");">@eg3.AwayAbbr</span>
                                    <span style="font-size:1.05rem;font-weight:700;color:@(!eg3hw?"#4af080":"#555");">@eg3.AwayScore</span>
                                </div>
                                <div style="margin-top:auto;padding-top:5px;font-size:0.65rem;color:#33336a;border-top:1px solid #1a1a2a;">→ #8 SEED</div>
                            </div>
                            @* G1: 7 vs 8 → #7 seed (aligns with R1[1]: 2v7) *@
                            <div style="width:148px;display:flex;flex-direction:column;background:#0a0a14;border:1px solid #1a1a2a;border-radius:5px;padding:8px 10px;">
                                <div style="display:flex;align-items:center;gap:5px;margin-bottom:5px;">
                                    <img src="/logos/teams/@(LogoSlug(eg1.HomeTeam)).svg" style="width:20px;height:20px;object-fit:contain;flex-shrink:0;" onerror="this.style.display='none'" />
                                    <span style="flex:1;font-size:0.88rem;color:@(eg1hw?"#d0d0d0":"#444");">@eg1.HomeAbbr</span>
                                    <span style="font-size:1.05rem;font-weight:700;color:@(eg1hw?"#4af080":"#555");">@eg1.HomeScore</span>
                                </div>
                                <div style="display:flex;align-items:center;gap:5px;">
                                    <img src="/logos/teams/@(LogoSlug(eg1.AwayTeam)).svg" style="width:20px;height:20px;object-fit:contain;flex-shrink:0;" onerror="this.style.display='none'" />
                                    <span style="flex:1;font-size:0.88rem;color:@(!eg1hw?"#d0d0d0":"#444");">@eg1.AwayAbbr</span>
                                    <span style="font-size:1.05rem;font-weight:700;color:@(!eg1hw?"#4af080":"#555");">@eg1.AwayScore</span>
                                </div>
                                <div style="margin-top:auto;padding-top:5px;font-size:0.65rem;color:#33336a;border-top:1px solid #1a1a2a;">→ #7 SEED</div>
                            </div>
                            @* G2: 9 vs 10 feeder (compact) *@
                            <div style="width:148px;background:#07070f;border:1px solid #111120;border-radius:4px;padding:6px 10px;">
                                <div style="font-size:0.65rem;color:#1e1e40;margin-bottom:3px;">9 vs 10 → feeds #8</div>
                                <div style="display:flex;justify-content:space-between;font-size:0.82rem;"><span style="color:@(eg2hw?"#888":"#2a2a2a");">@eg2.HomeAbbr</span><span style="color:@(eg2hw?"#888":"#2a2a2a");">@eg2.HomeScore</span></div>
                                <div style="display:flex;justify-content:space-between;font-size:0.82rem;margin-top:2px;"><span style="color:@(!eg2hw?"#888":"#2a2a2a");">@eg2.AwayAbbr</span><span style="color:@(!eg2hw?"#888":"#2a2a2a");">@eg2.AwayScore</span></div>
                            </div>
                        </div>
                    }
                    <div style="display:flex;flex-direction:column;gap:8px;">
                        <div style="font-size:0.65rem;color:#555;letter-spacing:2px;text-align:center;margin-bottom:3px;">EAST R1</div>
                        @foreach (var series in new[]{ pr.EastFirstRound.ElementAtOrDefault(0), pr.EastFirstRound.ElementAtOrDefault(1), pr.EastFirstRound.ElementAtOrDefault(2), pr.EastFirstRound.ElementAtOrDefault(3) })
                        { @BracketSeriesCard(series, "1ST RD") }
                    </div>
                    </div>

                    <div style="display:flex;flex-direction:column;gap:8px;padding-top:54px;">
                        <div style="font-size:0.65rem;color:#555;letter-spacing:2px;text-align:center;margin-bottom:3px;">E R2</div>
                        @foreach (var series in new[]{ pr.EastSecondRound.ElementAtOrDefault(0), pr.EastSecondRound.ElementAtOrDefault(1) })
                        { @BracketSeriesCard(series, "2ND RD") }
                    </div>
                    <div style="display:flex;flex-direction:column;gap:8px;padding-top:103px;">
                        <div style="font-size:0.65rem;color:#555;letter-spacing:2px;text-align:center;margin-bottom:3px;">ECF</div>
                        @BracketSeriesCard(pr.EastConfFinals, "ECF")
                    </div>

                    @* Finals — wider gold card *@
                    <div style="display:flex;flex-direction:column;gap:8px;padding-top:103px;border-left:1px solid #2a2a10;border-right:1px solid #2a2a10;padding-left:10px;padding-right:10px;">
                        <div style="font-size:0.7rem;color:#887744;letter-spacing:2px;text-align:center;margin-bottom:3px;">NBA FINALS</div>
                        @FinalsSeriesCard(pr.Finals)
                    </div>

                    @* West bracket (reversed) *@
                    <div style="display:flex;flex-direction:column;gap:8px;padding-top:103px;">
                        <div style="font-size:0.65rem;color:#555;letter-spacing:2px;text-align:center;margin-bottom:3px;">WCF</div>
                        @BracketSeriesCard(pr.WestConfFinals, "WCF")
                    </div>
                    <div style="display:flex;flex-direction:column;gap:8px;padding-top:54px;">
                        <div style="font-size:0.65rem;color:#555;letter-spacing:2px;text-align:center;margin-bottom:3px;">W R2</div>
                        @foreach (var series in new[]{ pr.WestSecondRound.ElementAtOrDefault(0), pr.WestSecondRound.ElementAtOrDefault(1) })
                        { @BracketSeriesCard(series, "2ND RD") }
                    </div>

                    @* West: R1 + play-in wrapped tight *@
                    <div style="display:flex;gap:4px;align-items:flex-start;">
                    <div style="display:flex;flex-direction:column;gap:8px;">
                        <div style="font-size:0.65rem;color:#555;letter-spacing:2px;text-align:center;margin-bottom:3px;">WEST R1</div>
                        @foreach (var series in new[]{ pr.WestFirstRound.ElementAtOrDefault(0), pr.WestFirstRound.ElementAtOrDefault(1), pr.WestFirstRound.ElementAtOrDefault(2), pr.WestFirstRound.ElementAtOrDefault(3) })
                        { @BracketSeriesCard(series, "1ST RD") }
                    </div>
                    @if (hasPlayIn)
                    {
                        var wg3 = pr.PlayInGames[5]; bool wg3hw = wg3.HomeScore > wg3.AwayScore;
                        var wg1 = pr.PlayInGames[3]; bool wg1hw = wg1.HomeScore > wg1.AwayScore;
                        var wg2 = pr.PlayInGames[4]; bool wg2hw = wg2.HomeScore > wg2.AwayScore;
                        <div style="display:flex;flex-direction:column;gap:8px;">
                            <div style="font-size:0.65rem;color:#33336a;letter-spacing:1.5px;text-align:center;margin-bottom:3px;">W PLAY-IN</div>
                            @* G3: consolation → #8 seed *@
                            <div style="width:148px;display:flex;flex-direction:column;background:#0a0a14;border:1px solid #1a1a2a;border-radius:5px;padding:8px 10px;">
                                <div style="display:flex;align-items:center;gap:5px;margin-bottom:5px;">
                                    <img src="/logos/teams/@(LogoSlug(wg3.HomeTeam)).svg" style="width:20px;height:20px;object-fit:contain;flex-shrink:0;" onerror="this.style.display='none'" />
                                    <span style="flex:1;font-size:0.88rem;color:@(wg3hw?"#d0d0d0":"#444");">@wg3.HomeAbbr</span>
                                    <span style="font-size:1.05rem;font-weight:700;color:@(wg3hw?"#4af080":"#555");">@wg3.HomeScore</span>
                                </div>
                                <div style="display:flex;align-items:center;gap:5px;">
                                    <img src="/logos/teams/@(LogoSlug(wg3.AwayTeam)).svg" style="width:20px;height:20px;object-fit:contain;flex-shrink:0;" onerror="this.style.display='none'" />
                                    <span style="flex:1;font-size:0.88rem;color:@(!wg3hw?"#d0d0d0":"#444");">@wg3.AwayAbbr</span>
                                    <span style="font-size:1.05rem;font-weight:700;color:@(!wg3hw?"#4af080":"#555");">@wg3.AwayScore</span>
                                </div>
                                <div style="margin-top:auto;padding-top:5px;font-size:0.65rem;color:#33336a;border-top:1px solid #1a1a2a;">#8 SEED ←</div>
                            </div>
                            @* G1: 7 vs 8 → #7 seed *@
                            <div style="width:148px;display:flex;flex-direction:column;background:#0a0a14;border:1px solid #1a1a2a;border-radius:5px;padding:8px 10px;">
                                <div style="display:flex;align-items:center;gap:5px;margin-bottom:5px;">
                                    <img src="/logos/teams/@(LogoSlug(wg1.HomeTeam)).svg" style="width:20px;height:20px;object-fit:contain;flex-shrink:0;" onerror="this.style.display='none'" />
                                    <span style="flex:1;font-size:0.88rem;color:@(wg1hw?"#d0d0d0":"#444");">@wg1.HomeAbbr</span>
                                    <span style="font-size:1.05rem;font-weight:700;color:@(wg1hw?"#4af080":"#555");">@wg1.HomeScore</span>
                                </div>
                                <div style="display:flex;align-items:center;gap:5px;">
                                    <img src="/logos/teams/@(LogoSlug(wg1.AwayTeam)).svg" style="width:20px;height:20px;object-fit:contain;flex-shrink:0;" onerror="this.style.display='none'" />
                                    <span style="flex:1;font-size:0.88rem;color:@(!wg1hw?"#d0d0d0":"#444");">@wg1.AwayAbbr</span>
                                    <span style="font-size:1.05rem;font-weight:700;color:@(!wg1hw?"#4af080":"#555");">@wg1.AwayScore</span>
                                </div>
                                <div style="margin-top:auto;padding-top:5px;font-size:0.65rem;color:#33336a;border-top:1px solid #1a1a2a;">#7 SEED ←</div>
                            </div>
                            @* G2: 9 vs 10 feeder *@
                            <div style="width:148px;background:#07070f;border:1px solid #111120;border-radius:4px;padding:6px 10px;">
                                <div style="font-size:0.65rem;color:#1e1e40;margin-bottom:3px;">9 vs 10 → feeds #8</div>
                                <div style="display:flex;justify-content:space-between;font-size:0.82rem;"><span style="color:@(wg2hw?"#888":"#2a2a2a");">@wg2.HomeAbbr</span><span style="color:@(wg2hw?"#888":"#2a2a2a");">@wg2.HomeScore</span></div>
                                <div style="display:flex;justify-content:space-between;font-size:0.82rem;margin-top:2px;"><span style="color:@(!wg2hw?"#888":"#2a2a2a");">@wg2.AwayAbbr</span><span style="color:@(!wg2hw?"#888":"#2a2a2a");">@wg2.AwayScore</span></div>
                            </div>
                        </div>
                    }
                    </div>

                </div>
                </div>
            </div>
            }
            else
            {
            <div style="flex-shrink:0;padding:6px 10px;border-bottom:1px solid #1a1a1a;">
                <div style="display:flex;align-items:center;gap:6px;margin-bottom:4px;">
                    <button @onclick="PrevCalMonth"
                            style="background:none;border:none;color:#666;cursor:pointer;font-size:0.9rem;padding:0 4px;font-family:monospace;">&#x2039;</button>
                    <span style="font-size:0.7rem;color:#888;letter-spacing:2px;font-weight:700;">@(new DateTime(_calYear, _calMonth, 1).ToString("MMM yyyy").ToUpper())</span>
                    <button @onclick="NextCalMonth" disabled="@CalNextDisabled()"
                            style="background:none;border:none;color:@(CalNextDisabled()?"#333":"#666");cursor:@(CalNextDisabled()?"default":"pointer");font-size:0.9rem;padding:0 4px;font-family:monospace;">&#x203A;</button>
                </div>
                @{
                    var dowLabels = new[] { "Su","Mo","Tu","We","Th","Fr","Sa" };
                    var calStart  = new DateOnly(_calYear, _calMonth, 1);
                    int startDow  = (int)calStart.DayOfWeek;
                    int daysInMo  = DateTime.DaysInMonth(_calYear, _calMonth);
                    DateOnly? currentDateOnly = (isLive && _liveState is not null && _liveState.CurrentDate < DateTime.MaxValue)
                        ? DateOnly.FromDateTime(_liveState.CurrentDate) : (DateOnly?)null;
                }
                <div style="display:grid;grid-template-columns:repeat(7,1fr);gap:2px;margin-bottom:2px;">
                    @foreach (var lbl in dowLabels)
                    {
                        <div style="text-align:center;font-size:0.6rem;color:#484848;padding:2px 0;letter-spacing:0.5px;">@lbl</div>
                    }
                </div>
                <div style="display:grid;grid-template-columns:repeat(7,1fr);gap:2px;">
                    @for (int bi = 0; bi < startDow; bi++) { <div style="min-height:72px;border:1px solid #161616;border-radius:3px;background:#0d0d0d;"></div> }
                    @for (int d = 1; d <= daysInMo; d++)
                    {
                        var date    = new DateOnly(_calYear, _calMonth, d);
                        bool today  = currentDateOnly.HasValue && date == currentDateOnly.Value;
                        var calGame = hasFollowed ? GetFollowedGameOnDate(date, followedTeam, isLive) : null;
                        bool isClickable = isLive && calGame is not null && !calGame.IsPast && calGame.ScheduledGameRef is not null;
                        string cellBg = today ? "#0d1a0d"
                            : calGame is null ? "#0d0d0d"
                            : calGame.IsPast ? (calGame.Won ? "#0a180a" : "#180a0a")
                            : "#13120a";
                        string cellBorder = today ? "#2a4a2a" : isClickable ? "#2a2818" : "#1e1e1e";
                        var capturedCalGame = calGame;
                        <div style="min-height:72px;padding:3px 3px 2px;background:@cellBg;border:1px solid @cellBorder;border-radius:3px;display:flex;flex-direction:column;align-items:center;position:relative;cursor:@(isClickable?"pointer":"default");"
                             @onclick="@(isClickable ? () => { _simToGameTarget = capturedCalGame!.ScheduledGameRef; _showWatchPopup = true; } : (Action)(() => {}))">
                            <div style="font-size:0.6rem;color:@(today?"#5a9a5a":"#3a3a3a");align-self:flex-start;line-height:1;font-weight:@(today?"700":"400");">@d</div>
                            @if (calGame is not null)
                            {
                                <img src="/logos/teams/@(LogoSlug(calGame.OppFullName)).svg"
                                     style="width:24px;height:24px;object-fit:contain;margin:3px 0 1px;"
                                     onerror="this.style.display='none'" />
                                <div style="font-size:0.6rem;color:@(calGame.IsPast?(calGame.Won?"#5aca70":"#d06060"):"#b89040");letter-spacing:0.3px;line-height:1;">
                                    @(calGame.IsPast ? "" : (calGame.IsHome ? "vs " : "@ "))@calGame.OppAbbr
                                </div>
                                @if (calGame.IsPast)
                                {
                                    <div style="font-size:0.82rem;font-weight:700;color:@(calGame.Won?"#4af080":"#f06060");line-height:1.2;margin-top:1px;">@calGame.MyScore&#x2013;@calGame.OppScore</div>
                                    <div style="font-size:0.55rem;color:@(calGame.Won?"#2a5a2a":"#5a2a2a");margin-top:1px;">@(calGame.IsHome ? "HOME" : "AWAY")</div>
                                }
                                else
                                {
                                    <div style="font-size:0.55rem;color:#4a3a10;margin-top:2px;letter-spacing:0.5px;">@(today ? "TODAY" : "UPCOMING")</div>
                                }
                            }
                        </div>
                    }
                </div>
            </div>
            } @* end calendar else *@

            <!-- STATS SECTION -->
            <div style="@(_livePlayoffs is not null ? "flex:1;min-height:200px;" : "flex:1;")display:flex;flex-direction:column;overflow:hidden;min-height:0;">
                <!-- Tab bar -->
                <div style="flex-shrink:0;display:flex;align-items:center;border-bottom:1px solid #1a1a1a;padding:0 2px;gap:0;flex-wrap:wrap;">
                    <button class="pdlg-tab @(_statsTab=="players"?"active":"")" @onclick='()=>_statsTab="players"'>PLAYERS</button>
                    <button class="pdlg-tab @(_statsTab=="teams"?"active":"")"   @onclick='()=>_statsTab="teams"'>TEAMS</button>
                    @if (_playoffs is not null || _livePlayoffs is not null)
                    {
                        <button class="pdlg-tab @(_statsTab=="playoffs"?"active":"")" @onclick='()=>_statsTab="playoffs"'>PLAYOFFS</button>
                    }
                    @if (_statsTab == "players")
                    {
                        <span style="color:#222;margin:0 4px;">|</span>
                        <button class="pdlg-tab @(_playerStatsView=="standard"?"active":"")" @onclick='()=>_playerStatsView="standard"' style="font-size:0.75rem;padding:5px 10px;">STD</button>
                        <button class="pdlg-tab @(_playerStatsView=="advanced"?"active":"")" @onclick='()=>_playerStatsView="advanced"' style="font-size:0.75rem;padding:5px 10px;">ADV</button>
                        <button class="pdlg-tab @(_playerStatsView=="per36"?"active":"")"    @onclick='()=>_playerStatsView="per36"'    style="font-size:0.75rem;padding:5px 10px;">P36</button>
                        <div style="flex:1;display:flex;align-items:center;gap:4px;padding:0 6px;">
                            <input type="text" @bind="_leagueSearch" @bind:event="oninput" placeholder="Search..." style="width:110px;font-size:0.78rem;padding:3px 7px;" />
                            <select @bind="_leagueTeamFilter" style="font-size:0.76rem;padding:2px 4px;">
                                <option value="">All Teams</option>
                                @foreach (var t in standingsValues.OrderBy(t => t.Abbreviation))
                                {
                                    <option value="@t.TeamName">@t.Abbreviation</option>
                                }
                            </select>
                        </div>
                    }
                </div>
                <!-- Table -->
                <div class="stats-wrap" style="flex:1;overflow:auto;">
                    @if (_statsTab == "players")
                    {
                        @if (_playerStatsView == "standard")
                        {
                        <table>
                            <thead class="stats-thead">
                                <tr>
                                    <th class="stats-frozen" style="text-align:left;min-width:110px;">PLAYER</th>
                                    <th style="text-align:left;min-width:34px;">TEAM</th>
                                    <th style="text-align:center;width:28px;">POS</th>
                                    @LeagueTh("gp",  "G")
                                    @LeagueTh("min", "MIN")
                                    @LeagueTh("pts", "PTS")
                                    @LeagueTh("orb", "ORB")
                                    @LeagueTh("drb", "DRB")
                                    @LeagueTh("reb", "REB")
                                    @LeagueTh("ast", "AST")
                                    @LeagueTh("stl", "STL")
                                    @LeagueTh("blk", "BLK")
                                    @LeagueTh("tov", "TOV")
                                    @LeagueTh("fgm", "FGM")
