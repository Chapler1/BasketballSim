@page "/season"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@using BasketballSim.Models
@using BasketballSim.Services
@using BasketballSim.Simulation
@using System.Text.Json
@using Microsoft.AspNetCore.Components.Web
@using static Microsoft.AspNetCore.Components.Web.RenderMode
@implements IAsyncDisposable
@inject NbaRosterService RosterSvc
@inject SeasonScheduleService SeasonSvc
@inject PlayerDataService PlayerSvc
@inject HistoricalStatsService HistSvc

<PageTitle>Season Sim</PageTitle>

<style>
    .ssim { font-family: monospace; color: #d4d4d4; padding: 0.75rem 1.25rem; }
    .ssim table { border-collapse: collapse; width: 100%; font-size: 0.9rem; }
    .ssim th { padding: 4px 6px; color: #555; font-weight: 600; letter-spacing: 0.5px; border-bottom: 1px solid #2a2a2a; white-space: nowrap; user-select: none; }
    .ssim th.sort-active { color: #fca; }
    .ssim th[data-sortable] { cursor: pointer; }
    .ssim th[data-sortable]:hover { color: #aaa; }
    .ssim td { padding: 3px 6px; border-bottom: 1px solid #191919; white-space: nowrap; }
    .ssim tr:hover td { background: #1e1e1e; }
    .ssim .section-title { font-size: 0.85rem; font-weight: 700; color: #555; letter-spacing: 2px; margin-bottom: 6px; }
    .ssim .scroll-x { overflow-x: auto; }
    .ssim .tag-playoff { background: #0d1a0d; }
    .ssim .tag-playin  { background: #0d0d1a; }
    .ssim input[type=text] { background: #1a1a1a; color: #d4d4d4; border: 1px solid #333; padding: 4px 10px; border-radius: 4px; font-family: monospace; font-size: 0.93rem; outline: none; }
    .ssim input[type=text]:focus { border-color: #555; }
    .ssim select { background: #1a1a1a; color: #d4d4d4; border: 1px solid #333; padding: 4px 10px; border-radius: 4px; font-family: monospace; font-size: 0.93rem; cursor: pointer; }
    .ssim tr.clickable-row { cursor: pointer; }
    .pdlg-tab { background:none;border:none;padding:6px 16px;font-family:monospace;font-size:0.88rem;cursor:pointer;letter-spacing:0.5px;border-bottom:2px solid transparent; }
    .pdlg-tab.active { color:#fca;border-bottom-color:#fca; }
    .pdlg-tab:not(.active) { color:#555; }
    .pdlg-attr { display:flex;align-items:center;gap:6px;margin:2px 0; }
    .pdlg-attr-label { width:82px;color:#555;font-size:0.82rem;text-align:right; }
    .pdlg-attr-bar-bg { width:90px;background:#1a1a1a;height:3px;border-radius:2px; }
    .pdlg-attr-val { width:22px;color:#c8c8c8;font-size:0.84rem;text-align:right;font-weight:600; }
    .pdlg-qs { flex:1;min-width:44px;text-align:center;padding:5px 3px;border-right:1px solid #1a1a1a; }
    .pdlg-qs:last-child { border-right:none; }
    .pdlg-qs-label { font-size:0.68rem;color:#333;letter-spacing:0.5px;margin-bottom:1px; }
    .pdlg-qs-val { font-size:0.93rem;font-weight:600; }
    .glog-row { display:grid;grid-template-columns:72px 22px 44px 1fr 36px;gap:0 6px;align-items:center;padding:3px 0;border-bottom:1px solid #181818;font-size:0.88rem; }
    .glog-row:hover { background:#1e1e1e; }
    .glog-w { color:#4af080;font-weight:700; }
    .glog-l { color:#f06060;font-weight:700; }
    .hiw-section { border:1px solid #1e1e1e;border-radius:4px;margin-bottom:6px;overflow:hidden; }
    .hiw-header { width:100%;background:#111;border:none;color:#aaa;font-family:monospace;font-size:0.88rem;font-weight:700;letter-spacing:1px;text-align:left;padding:9px 14px;cursor:pointer;display:flex;justify-content:space-between;align-items:center; }
    .hiw-header:hover { background:#161616; }
    .hiw-body { padding:12px 16px;background:#0d0d0d;font-size:0.84rem;line-height:1.65;color:#888; }
    .hiw-body strong { color:#c8c8c8; }
    .hiw-body .kv { display:flex;gap:0.5rem;margin:2px 0; }
    .hiw-body .kv-label { color:#555;min-width:130px;flex-shrink:0; }
    .hiw-body .kv-val { color:#aaa; }
    .hiw-chip { display:inline-block;background:#1a1a1a;border:1px solid #2a2a2a;border-radius:3px;padding:1px 7px;font-size:0.78rem;color:#777;margin:1px 2px; }
    @@keyframes watchEntryFlash {
        0%   { background-color: rgba(255,200,80,0.22); }
        100% { background-color: transparent; }
    }
    .watch-entry { animation: watchEntryFlash 1.8s ease-out forwards; }
    .wm-tab { background:none;border:none;padding:7px 18px;font-family:monospace;font-size:0.82rem;cursor:pointer;letter-spacing:0.5px;border-bottom:2px solid transparent;color:#444; }
    .wm-tab.active { color:#c8c8c8;border-bottom-color:#fca; }
    .wm-tab:not(.active):hover { color:#777; }
    .wm-oncourt { background:#111a11; }
    .wm-bench   { background:transparent; }
    .wm-player-row td { padding:3px 6px;border-bottom:1px solid #141414;white-space:nowrap; }
    .wm-player-row:hover td { background:#1a1a1a; }
    .wm-team-hdr { font-size:0.72rem;color:#333;letter-spacing:1.5px;padding:4px 8px;border-bottom:1px solid #141414;background:#0a0a0a; }
</style>

<div class="ssim">

<div style="display:flex;align-items:center;gap:1rem;margin-bottom:1rem;flex-wrap:wrap;">
    <span style="font-size: 1.3rem;font-weight:800;color:#e8e8e8;letter-spacing:2px;">SEASON SIM</span>
    <span style="color:#2a2a2a;font-size: 0.85rem;letter-spacing:1px;">82 GAMES · 30 TEAMS · 1,230 MATCHUPS</span>
    @if (_phase == Phase.Done && _season is not null)
    {
        <button @onclick="SimulateSeason" style="margin-left:auto;background:#1a2a1a;color:#4af080;border:1px solid #2a4a2a;padding:4px 16px;border-radius:4px;cursor:pointer;font-size: 0.92rem;font-family:monospace;">↺ Re-simulate</button>
        <button @onclick="() => _disableInjuries = !_disableInjuries"
                style="background:@(_disableInjuries?"#2a1a1a":"#1a1a1a");color:@(_disableInjuries?"#f88":"#444");border:1px solid @(_disableInjuries?"#4a2a2a":"#2a2a2a");padding:4px 12px;border-radius:4px;cursor:pointer;font-size:0.82rem;font-family:monospace;">
            @(_disableInjuries ? "Injuries OFF" : "Injuries ON")
        </button>
        @if (_playoffs is null)
        {
            <button @onclick="SimulatePlayoffs" style="background:#1a1a2a;color:#cdf;border:1px solid #2a2a4a;padding:4px 16px;border-radius:4px;cursor:pointer;font-size:0.92rem;font-family:monospace;">▶ Simulate Playoffs</button>
        }
        @if (_playoffs?.Champion is not null)
        {
            <span style="background:#1a0d00;color:#fca;border:1px solid #3a2200;padding:3px 12px;border-radius:4px;font-size:0.92rem;font-weight:700;letter-spacing:1px;">@_playoffs.ChampionAbbr CHAMPS</span>
        }
        <span style="color:#444;font-size: 0.82rem;">@_season.SimulatedAt.ToString("yyyy-MM-dd HH:mm")</span>
        @if (_savedPath is not null)
        {
            <span style="color:#333;font-size: 0.8rem;" title="@_savedPath">saved</span>
        }
    }
    <button @onclick="() => _showHowItWorks = true"
            style="margin-left:auto;background:none;border:1px solid #222;color:#444;border-radius:50%;width:24px;height:24px;cursor:pointer;font-family:monospace;font-size:0.78rem;display:flex;align-items:center;justify-content:center;flex-shrink:0;"
            title="How the sim works">?</button>
</div>

@if (_phase == Phase.NeedFetch)
{
    <div style="text-align:center;padding:4rem 0;">
        <div style="color:#555;font-size: 1.0rem;margin-bottom:0.4rem;">No roster data found.</div>
        <div style="color:#444;font-size: 0.9rem;margin-bottom:1.5rem;">Fetch once from ESPN to cache rosters locally.</div>
        <button @onclick="FetchRosters" style="background:#3a2a1a;color:#fca;border:1px solid #6a4a2a;padding:10px 36px;border-radius:5px;cursor:pointer;font-size: 1.05rem;font-family:monospace;font-weight:700;">↓ Fetch Rosters from ESPN</button>
    </div>
}
else if (_phase == Phase.Fetching)
{
    <div style="text-align:center;padding:4rem 0;color:#555;">
        <div style="margin-bottom:0.5rem;">Fetching rosters… @_fetchDone / @_fetchTotal teams</div>
        <div style="background:#1a1a1a;border-radius:4px;height:6px;width:320px;margin:0 auto;">
            <div style="background:#fca;height:6px;border-radius:4px;width:@(_fetchTotal>0?_fetchDone*100/_fetchTotal:0)%;transition:width 0.2s;"></div>
        </div>
    </div>
}
else if (_phase == Phase.Syncing)
{
    <div style="text-align:center;padding:4rem 0;color:#555;">
        <div>Syncing players.json…</div>
    </div>
}
else if (_phase == Phase.Ready)
{
    <!-- ═══ LANDING PAGE ═══ -->
    <div style="padding:1.25rem 0 2rem;">
        <div style="text-align:center;margin-bottom:1.5rem;">
            <div style="font-size:1.7rem;font-weight:800;color:#e8e8e8;letter-spacing:3px;">NBA SEASON SIM</div>
            <div style="font-size:0.82rem;color:#3a3a3a;letter-spacing:2px;margin-top:3px;">2025–26 · 82 GAMES · 30 TEAMS · 1,230 MATCHUPS</div>
            @if (_syncAdded > 0 || _syncFreed > 0 || _syncUpdated > 0)
            {
                <div style="font-size:0.73rem;color:#2a2a2a;margin-top:5px;">Last sync: @_syncUpdated traded · @_syncAdded new · @_syncFreed free agents</div>
            }
        </div>

        <!-- Team logo grid -->
        <div style="text-align:center;font-size:0.7rem;color:#2a2a2a;letter-spacing:2px;margin-bottom:8px;">SELECT A TEAM TO FOLLOW (OPTIONAL)</div>
        <div style="display:flex;flex-wrap:wrap;justify-content:center;gap:6px;max-width:900px;margin:0 auto 1.75rem;">
        @foreach (var (name, team) in _teams.OrderBy(t => t.Value.Abbreviation))
        {
            bool sel = _selectedTeam == name;
            <div @onclick="() => { _selectedTeam = sel ? string.Empty : name; }"
                 style="cursor:pointer;background:@(sel?"#0d1a0d":"#0e0e0e");border:1px solid @(sel?"#2a4a2a":"#1e1e1e");border-radius:5px;padding:5px 6px;width:76px;text-align:center;">
                <img src="/logos/teams/@(LogoSlug(name)).svg"
                     style="width:36px;height:36px;object-fit:contain;display:block;margin:0 auto 3px;"
                     onerror="this.style.display='none'" />
                <div style="font-size:0.68rem;color:@(sel?"#4af080":"#484848");font-weight:@(sel?"700":"400");letter-spacing:0.5px;">@team.Abbreviation</div>
            </div>
        }
        </div>

        <!-- Controls -->
        <div style="display:flex;align-items:center;justify-content:center;gap:0.75rem;flex-wrap:wrap;">
            <button @onclick="() => _disableInjuries = !_disableInjuries"
                    style="background:@(_disableInjuries?"#2a1a1a":"#141414");color:@(_disableInjuries?"#f88":"#444");border:1px solid @(_disableInjuries?"#4a2a2a":"#242424");padding:7px 14px;border-radius:4px;cursor:pointer;font-family:monospace;font-size:0.83rem;">
                @(_disableInjuries ? "✕ Injuries OFF" : "✓ Injuries ON")
            </button>
            <button @onclick="StartLiveSeason"
                    style="background:#0d2a0d;color:#4af080;border:1px solid #1a4a1a;padding:10px 36px;border-radius:5px;cursor:pointer;font-weight:700;font-size:1.05rem;font-family:monospace;">
                ▶ Start Live Season
            </button>
            <button @onclick="SimulateSeason"
                    style="background:#0d0d2a;color:#8ab8ff;border:1px solid #1a1a4a;padding:10px 36px;border-radius:5px;cursor:pointer;font-size:1.0rem;font-family:monospace;">
                Simulate Instantly
            </button>
        </div>
        <div style="text-align:center;margin-top:0.75rem;">
            <button @onclick="FetchRosters" style="background:none;border:none;color:#2a2a2a;font-size:0.78rem;cursor:pointer;font-family:monospace;">↺ Re-fetch rosters from ESPN</button>
        </div>
    </div>
}
else if (_phase == Phase.Simulating)
{
    <div style="text-align:center;padding:4rem 0;color:#555;">
        <div style="margin-bottom:0.5rem;">Simulating… @_gamesPlayed / 1,230 games</div>
        <div style="background:#1a1a1a;border-radius:4px;height:6px;width:320px;margin:0 auto;">
            <div style="background:#4af080;height:6px;border-radius:4px;width:@(_gamesPlayed*100/1230)%;transition:width 0.15s;"></div>
        </div>
    </div>
}
else if (_phase == Phase.Playoffs)
{
    <div style="text-align:center;padding:4rem 0;color:#555;">
        <div style="margin-bottom:0.5rem;">Simulating playoffs… @_playoffGamesPlayed games played</div>
        <div style="background:#1a1a1a;border-radius:4px;height:6px;width:320px;margin:0 auto;">
            <div style="background:#fca;height:6px;border-radius:4px;width:@(_playoffGamesTotal > 0 ? Math.Min(_playoffGamesPlayed * 100 / _playoffGamesTotal, 100) : 0)%;transition:width 0.15s;"></div>
        </div>
    </div>
}
else if (_phase == Phase.LiveSeason && _liveState is not null)
{
    bool hasFollowedTeam = !string.IsNullOrEmpty(_liveState.FollowedTeam);
    var tickerCompleted = hasFollowedTeam
        ? _liveState.CompletedGames
            .Where(g => g.HomeTeam.Equals(_liveState.FollowedTeam, StringComparison.OrdinalIgnoreCase)
                     || g.AwayTeam.Equals(_liveState.FollowedTeam, StringComparison.OrdinalIgnoreCase))
            .TakeLast(20).ToList()
        : _liveState.RecentCompleted(20);
    // Next 8 upcoming games for followed team (across however many days that spans)
    var tickerUpcoming = _liveState.IsComplete
        ? new List<ScheduledGame>()
        : (hasFollowedTeam
            ? _liveState.Schedule
                .Where(g => g.Date.Date >= _liveState.CurrentDate
                         && (g.HomeTeamId.Equals(_liveState.FollowedTeam, StringComparison.OrdinalIgnoreCase)
                          || g.AwayTeamId.Equals(_liveState.FollowedTeam, StringComparison.OrdinalIgnoreCase)))
                .OrderBy(g => g.Date)
                .Take(8)
                .ToList()
            : _liveState.GamesOn(_liveState.CurrentDate).Take(12).ToList());
    var liveMyTeam = _liveState.Standings.TryGetValue(_liveState.FollowedTeam, out var _lmt) ? _lmt : null;
    var livePlayers = _liveState.PlayerAgg.Values.Where(p => p.GP > 0).OrderByDescending(p => p.Ppg).ToList();
    var liveFiltered = livePlayers.AsEnumerable();
    if (_leagueSearch.Length > 1) liveFiltered = liveFiltered.Where(p => p.Name.Contains(_leagueSearch, StringComparison.OrdinalIgnoreCase));
    if (_leagueTeamFilter.Length > 0) liveFiltered = liveFiltered.Where(p => p.Team == _leagueTeamFilter);
    var liveSorted = ApplySort(liveFiltered, _leagueSort, _leagueSortAsc).ToList();
    var liveTeamsOrdered = _liveState.Standings.Values.Where(t => t.GP > 0).OrderByDescending(t => t.Wins).ToList();
    <div style="overflow-x:auto;display:flex;align-items:center;gap:6px;padding:6px 12px;background:#090909;border-bottom:1px solid #181818;position:sticky;top:0;z-index:50;min-height:52px;scrollbar-width:thin;">
    @foreach (var g in tickerCompleted)
    {
        bool hw = g.HomeScore > g.AwayScore;
        <div @onclick="() => _tickerBoxScore = g"
             style="flex-shrink:0;cursor:pointer;background:#111;border:1px solid #1e1e1e;border-radius:4px;padding:4px 8px;text-align:center;min-width:96px;">
            <div style="font-size:0.6rem;color:#2a2a2a;margin-bottom:2px;">@g.Date.ToString("MMM d")</div>
            <div style="font-size:0.82rem;display:flex;gap:4px;align-items:center;justify-content:center;">
                <span style="color:@(hw?"#c8c8c8":"#444");">@g.HomeAbbr <span style="font-weight:700;">@g.HomeScore</span></span>
                <span style="color:#222;">-</span>
                <span style="color:@(!hw?"#c8c8c8":"#444");"><span style="font-weight:700;">@g.AwayScore</span> @g.AwayAbbr</span>
            </div>
        </div>
    }
    @if (!_liveState.IsComplete)
    {
        <div style="flex-shrink:0;width:1px;background:#222;height:32px;margin:0 2px;"></div>
        @foreach (var sg in tickerUpcoming)
        {
            bool isToday = sg.Date.Date == _liveState.CurrentDate;
            bool isSelected = _simToGameTarget == sg;
            string hAb = _liveState.Teams.TryGetValue(sg.HomeTeamId, out var _ht) ? _ht.Abbreviation : "?";
            string aAb = _liveState.Teams.TryGetValue(sg.AwayTeamId, out var _at) ? _at.Abbreviation : "?";
            <div @onclick="() => { _simToGameTarget = sg; _showWatchPopup = true; }"
                 style="flex-shrink:0;cursor:pointer;background:@(isSelected?"#1a1a0d":"#0a0a0a");border:1px solid @(isSelected?"#4a4a1a":isToday?"#1a2a1a":"#1a1a1a");border-radius:4px;padding:4px 8px;text-align:center;min-width:88px;transition:border-color 0.1s;">
                <div style="font-size:0.6rem;color:@(isToday?"#2a4a2a":"#252525");margin-bottom:2px;">@sg.Date.ToString("MMM d")@(isToday?" — TODAY":"")</div>
                <div style="font-size:0.8rem;color:@(isToday?"#3a5a3a":"#2a2a2a");">@hAb <span style="color:#181818;">vs</span> @aAb</div>
            </div>
        }
    }
    @if (_liveState.IsComplete)
    {
        <span style="flex-shrink:0;color:#4af080;font-size:0.75rem;font-weight:700;padding:0 8px;">SEASON COMPLETE</span>
    }
    </div>

    <!-- ═══ CONTROLS + STATUS BAR ═══ -->
    <div style="display:flex;align-items:center;gap:0.6rem;padding:6px 0 8px;flex-wrap:wrap;">
        @if (!_liveState.IsComplete)
        {
            <button @onclick="SimOneDayLive" disabled="@_simBusy"
                    style="background:#141414;color:@(_simBusy?"#333":"#888");border:1px solid #222;padding:5px 14px;border-radius:4px;cursor:@(_simBusy?"default":"pointer");font-family:monospace;font-size:0.82rem;">
                Sim Day
            </button>
            <button @onclick="ToggleAutoSim" disabled="@_simBusy"
                    style="background:@(_isAutoSimming?"#2a1a0a":"#141414");color:@(_simBusy?"#333":_isAutoSimming?"#fca":"#888");border:1px solid @(_isAutoSimming?"#4a3a1a":"#222");padding:5px 14px;border-radius:4px;cursor:@(_simBusy?"default":"pointer");font-family:monospace;font-size:0.82rem;">
                @(_isAutoSimming ? "Pause" : "Auto")
            </button>
            <button @onclick="SimRestOfSeasonLive" disabled="@_simBusy"
                    style="background:@(_simBusy?"#0d0d1a":"#0d0d2a");color:@(_simBusy?"#444":"#8ab8ff");border:1px solid #1a1a4a;padding:5px 14px;border-radius:4px;cursor:@(_simBusy?"default":"pointer");font-family:monospace;font-size:0.82rem;">
                @(_simBusy ? "Simming…" : "Sim Rest of Season")
            </button>
            <span style="color:#1a1a1a;">|</span>
            <span style="color:#4af080;font-weight:700;font-size:0.78rem;">●</span>
            <span style="color:#3a6a3a;font-size:0.8rem;">@_liveState.CurrentDate.ToString("MMM d, yyyy")</span>
            <span style="color:#222;font-size:0.78rem;">Day @(_liveState.DateIndex+1) / @_liveState.TotalScheduledDays</span>
        }
        else
        {
            <button @onclick="SimulatePlayoffs"
                    style="background:#1a1a2a;color:#cdf;border:1px solid #2a2a4a;padding:5px 14px;border-radius:4px;cursor:pointer;font-family:monospace;font-size:0.82rem;">
                ▶ Simulate Playoffs
            </button>
            <span style="color:#4af080;font-size:0.8rem;font-weight:700;">Season Complete</span>
        }
        @if (!string.IsNullOrEmpty(_liveState.FollowedTeam) && liveMyTeam is not null)
        {
            <span style="color:#1a1a1a;">|</span>
            <span style="color:#888;font-size:0.8rem;font-weight:600;">@liveMyTeam.Abbreviation</span>
            <span style="color:#4af080;font-size:0.8rem;">@liveMyTeam.Wins–@liveMyTeam.Losses</span>
        }
    </div>
    @if (_simError is not null)
    {
        <div style="background:#2a0a0a;border:1px solid #4a1a1a;border-radius:4px;padding:6px 12px;margin-bottom:6px;font-size:0.82rem;color:#f06060;display:flex;justify-content:space-between;align-items:center;">
            <span>⚠ @_simError</span>
            <button @onclick="() => _simError = null" style="background:none;border:none;color:#f06060;cursor:pointer;font-size:0.9rem;padding:0 4px;">✕</button>
        </div>
    }


    <!-- ═══ TOP TABS: STANDINGS | CALENDAR ═══ -->
    <div style="display:flex;gap:0;border-bottom:1px solid #1e1e1e;margin-bottom:0.75rem;">
        <button class="pdlg-tab @(_topTab=="standings"?"active":"")" @onclick='()=>_topTab="standings"'>STANDINGS</button>
        <button class="pdlg-tab @(_topTab=="calendar"?"active":"")"  @onclick='()=>_topTab="calendar"'>CALENDAR</button>
    </div>

    @if (_topTab == "standings")
    {
        var liveStandings = _liveState.Standings.Values.ToList();
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;margin-bottom:1rem;">
        @foreach (var conf in new[] { "Eastern", "Western" })
        {
            var ct = liveStandings.Where(t => t.Conference == conf)
                .OrderByDescending(t => t.Wins).ThenBy(t => t.Losses).ToList();
            var leader = ct.FirstOrDefault();
            <div>
                <div class="section-title">@conf.ToUpper() CONFERENCE</div>
                <div class="scroll-x">
                <table style="font-size:0.85rem;">
                    <thead><tr>
                        <th style="width:18px;"></th>
                        <th style="text-align:left;">TEAM</th>
                        <th style="text-align:center;width:28px;">W</th>
                        <th style="text-align:center;width:28px;">L</th>
                        <th style="text-align:center;width:44px;">PCT</th>
                        <th style="text-align:center;width:34px;">GB</th>
                        <th style="text-align:center;width:52px;">CONF</th>
                        <th style="text-align:center;width:38px;">PPG</th>
                        <th style="text-align:center;width:38px;">OPP</th>
                        <th style="text-align:center;width:38px;">DIFF</th>
                    </tr></thead>
                    <tbody>
                    @for (int r2 = 0; r2 < ct.Count; r2++)
                    {
                        var t = ct[r2];
                        double gb2 = leader is null ? 0 : ((leader.Wins - t.Wins) + (t.Losses - leader.Losses)) / 2.0;
                        double diff2 = t.GP > 0 ? t.Ppg - t.Papg : 0;
                        string rowBg2 = r2 < 6 ? "#0d1a0d" : r2 < 10 ? "#0d0d1a" : "#111";
                        bool followed = t.TeamName.Equals(_liveState.FollowedTeam, StringComparison.OrdinalIgnoreCase);
                        <tr style="background:@(followed?"#1a1a0a":rowBg2);" @onclick="() => OpenGameLog(t)">
                            <td style="color:#3a3a3a;font-size:0.78rem;text-align:right;">@(r2+1)</td>
                            <td>
                                <img src="/logos/teams/@(LogoSlug(t.TeamName)).svg" style="width:14px;height:14px;vertical-align:middle;margin-right:4px;object-fit:contain;" onerror="this.style.display='none'" />
                                <span style="font-weight:@(r2<3?"700":"400");color:@(followed?"#fca":r2==0?"#e8e8e8":"#b8b8b8");">@t.Abbreviation</span>
                            </td>
                            <td style="text-align:center;color:#4af080;font-weight:@(r2==0?"700":"400");">@t.Wins</td>
                            <td style="text-align:center;color:#f06060;">@t.Losses</td>
                            <td style="text-align:center;">@t.Pct.ToString("F3")</td>
                            <td style="text-align:center;color:#444;font-size:0.8rem;">@(r2==0?"—":gb2.ToString("F1"))</td>
                            <td style="text-align:center;color:#555;font-size:0.8rem;">@t.ConfWins-@t.ConfLosses</td>
                            <td style="text-align:center;">@(t.GP>0?t.Ppg.ToString("F1"):"—")</td>
                            <td style="text-align:center;color:#666;">@(t.GP>0?t.Papg.ToString("F1"):"—")</td>
                            <td style="text-align:center;color:@(diff2>=0?"#4af080":"#f06060");">@(t.GP>0?diff2.ToString("+0.0;-0.0;0.0"):"—")</td>
                        </tr>
                    }
                    </tbody>
                </table>
                </div>
            </div>
        }
        </div>
    }
    else if (_topTab == "calendar")
    {
        var followTeamId = string.IsNullOrEmpty(_liveState.FollowedTeam) ? "" : _liveState.FollowedTeam;
        var upcomingAll  = _liveState.IsComplete
            ? (List<ScheduledGame>)[]
            : _liveState.Schedule
                .Where(g => g.Date.Date >= _liveState.CurrentDate)
                .OrderBy(g => g.Date)
                .Take(60)
                .ToList();
        var calDates = upcomingAll.Select(g => g.Date.Date).Distinct().Take(14).ToList();

        if (!calDates.Any())
        {
            <div style="color:#2a2a2a;padding:2rem 0;text-align:center;">Season complete.</div>
        }
        else
        {
            <div style="display:flex;flex-wrap:wrap;gap:1rem;">
            @foreach (var d in calDates)
            {
                var dayGames = upcomingAll.Where(g => g.Date.Date == d).ToList();
                <div style="background:#0e0e0e;border:1px solid #1a1a1a;border-radius:4px;padding:8px 10px;min-width:160px;">
                    <div style="font-size:0.72rem;color:@(d==_liveState.CurrentDate?"#4af080":"#333");letter-spacing:1px;margin-bottom:6px;font-weight:@(d==_liveState.CurrentDate?"700":"400");">
                        @(d == _liveState.CurrentDate ? "TODAY — " : "")@d.ToString("ddd MMM d").ToUpper()
                    </div>
                    @foreach (var sg in dayGames)
                    {
                        bool myGame = sg.HomeTeamId.Equals(followTeamId, StringComparison.OrdinalIgnoreCase)
                                   || sg.AwayTeamId.Equals(followTeamId, StringComparison.OrdinalIgnoreCase);
                        string hAbbr = _liveState.Teams.TryGetValue(sg.HomeTeamId, out var hT) ? hT.Abbreviation : "?";
                        string aAbbr = _liveState.Teams.TryGetValue(sg.AwayTeamId, out var aT) ? aT.Abbreviation : "?";
                        <div style="font-size:0.82rem;padding:2px 0;color:@(myGame?"#fca":"#555");">
                            @hAbbr <span style="color:#2a2a2a;">vs</span> @aAbbr
                        </div>
                    }
                </div>
            }
            </div>
        }
    }

    <div style="display:flex;gap:0;border-bottom:1px solid #1e1e1e;margin:1rem 0 0.75rem;">
        <button class="pdlg-tab @(_statsTab=="players"?"active":"")" @onclick='()=>_statsTab="players"'>PLAYER STATS</button>
        <button class="pdlg-tab @(_statsTab=="teams"?"active":"")"   @onclick='()=>_statsTab="teams"'>TEAM STATS</button>
    </div>

    @if (_statsTab == "players")
    {
        <div style="display:flex;align-items:center;gap:0.75rem;margin-bottom:0.5rem;flex-wrap:wrap;">
            <input type="text" @bind="_leagueSearch" @bind:event="oninput" placeholder="Search player…" style="width:150px;" />
            <select @bind="_leagueTeamFilter" style="font-size:0.85rem;padding:3px 6px;">
                <option value="">All Teams</option>
                @foreach (var t in _liveState.Standings.Values.OrderBy(t => t.Abbreviation))
                {
                    <option value="@t.TeamName">@t.Abbreviation</option>
                }
            </select>
            <span style="color:#2a2a2a;font-size:0.78rem;">@livePlayers.Count players</span>
        </div>
        <div class="scroll-x" style="max-height:460px;overflow-y:auto;">
        <table>
            <thead style="position:sticky;top:0;background:#111;z-index:1;">
                <tr>
                    <th style="text-align:left;min-width:110px;">PLAYER</th>
                    <th style="text-align:left;min-width:34px;">TEAM</th>
                    <th style="text-align:center;min-width:28px;">POS</th>
                    <th style="text-align:center;">STATUS</th>
                    @LeagueTh("gp","GP") @LeagueTh("min","MIN") @LeagueTh("pts","PTS")
                    @LeagueTh("reb","REB") @LeagueTh("ast","AST") @LeagueTh("stl","STL")
                    @LeagueTh("blk","BLK") @LeagueTh("tov","TOV") @LeagueTh("fg","FG%")
                    @LeagueTh("3p","3P%") @LeagueTh("ft","FT%")
                    @LeagueTh("fga","FGA") @LeagueTh("3pa","3PA") @LeagueTh("fta","FTA")
                    @LeagueTh("pm","+/-")
                </tr>
            </thead>
            <tbody>
            @foreach (var p in liveSorted)
            {
                var rp = GetRosterPlayer(p.Name);
                bool isOut = rp?.CurrentInjury?.Definition.Grade >= 2;
                bool isQ   = rp?.CurrentInjury?.Definition.Grade == 1;
                <tr class="clickable-row" @onclick="() => OpenPlayerModal(p)">
                    <td style="color:#b8b8b8;">@p.Name</td>
                    <td style="color:#555;font-size:0.82rem;">@p.TeamAbbr</td>
                    <td style="text-align:center;color:#444;font-size:0.78rem;">@p.Position</td>
                    <td style="text-align:center;">
                        @if (isOut)  { <span style="background:#2a0a0a;color:#f06060;border:1px solid #4a1a1a;border-radius:3px;padding:1px 5px;font-size:0.7rem;letter-spacing:0.5px;">OUT</span> }
                        @if (isQ)    { <span style="background:#2a1a00;color:#fca;border:1px solid #4a3000;border-radius:3px;padding:1px 5px;font-size:0.7rem;letter-spacing:0.5px;">Q</span> }
                    </td>
                    <td style="text-align:center;color:#555;">@p.GP</td>
                    <td style="text-align:center;color:#666;">@p.Mpg.ToString("F1")</td>
                    <td style="text-align:center;color:#e8c060;font-weight:600;">@p.Ppg.ToString("F1")</td>
                    <td style="text-align:center;">@p.Rpg.ToString("F1")</td>
                    <td style="text-align:center;color:#60c8e8;">@p.Apg.ToString("F1")</td>
                    <td style="text-align:center;color:#a0e080;">@p.Spg.ToString("F1")</td>
                    <td style="text-align:center;color:#e08060;">@p.Bpg.ToString("F1")</td>
                    <td style="text-align:center;color:#f06060;">@p.Topg.ToString("F1")</td>
                    <td style="text-align:center;color:@FgPctColor(p.FgPct);">@(p.TotalFGA>0?p.FgPct.ToString("P1"):"—")</td>
                    <td style="text-align:center;color:@TpPctColor(p.TpPct);">@(p.TotalThreeAtt>0?p.TpPct.ToString("P1"):"—")</td>
                    <td style="text-align:center;color:@FtPctColor(p.FtPct);">@(p.TotalFTA>0?p.FtPct.ToString("P1"):"—")</td>
                    <td style="text-align:center;color:#666;">@p.Fga.ToString("F1")</td>
                    <td style="text-align:center;color:#666;">@p.Tpa.ToString("F1")</td>
                    <td style="text-align:center;color:#666;">@p.Fta.ToString("F1")</td>
                    <td style="text-align:center;color:@PmColor(p.AvgPlusMinus);">@p.AvgPlusMinus.ToString("+0.0;-0.0;0.0")</td>
                </tr>
            }
            </tbody>
        </table>
        </div>
    }
    else if (_statsTab == "teams")
    {
        <div class="scroll-x">
        <table>
            <thead><tr>
                <th style="text-align:left;">TEAM</th>
                <th style="text-align:center;">W</th><th style="text-align:center;">L</th>
                <th style="text-align:center;">PCT</th><th style="text-align:center;">PPG</th>
                <th style="text-align:center;">PA</th><th style="text-align:center;">DIFF</th>
                <th style="text-align:center;">FG%</th><th style="text-align:center;">3P%</th>
                <th style="text-align:center;">FT%</th><th style="text-align:center;">AST</th>
                <th style="text-align:center;">STL</th><th style="text-align:center;">BLK</th>
                <th style="text-align:center;">TOV</th><th style="text-align:center;">PACE</th>
            </tr></thead>
            <tbody>
            @foreach (var t in liveTeamsOrdered)
            {
                double td2 = t.Ppg - t.Papg;
                <tr>
                    <td>
                        <img src="/logos/teams/@(LogoSlug(t.TeamName)).svg" style="width:14px;height:14px;vertical-align:middle;margin-right:4px;object-fit:contain;" onerror="this.style.display='none'" />
                        <span style="color:#b8b8b8;font-weight:600;">@t.Abbreviation</span>
                    </td>
                    <td style="text-align:center;color:#4af080;font-weight:600;">@t.Wins</td>
                    <td style="text-align:center;color:#f06060;">@t.Losses</td>
                    <td style="text-align:center;color:#888;">@t.Pct.ToString("F3")</td>
                    <td style="text-align:center;color:#e8c060;font-weight:600;">@t.Ppg.ToString("F1")</td>
                    <td style="text-align:center;color:#888;">@t.Papg.ToString("F1")</td>
                    <td style="text-align:center;color:@(td2>=0?"#4af080":"#f06060");">@td2.ToString("+0.0;-0.0;0.0")</td>
                    <td style="text-align:center;color:@FgPctColor(t.FgPct);">@t.FgPct.ToString("P1")</td>
                    <td style="text-align:center;color:@TpPctColor(t.TpPct);">@t.TpPct.ToString("P1")</td>
                    <td style="text-align:center;color:@FtPctColor(t.FtPct);">@t.FtPct.ToString("P1")</td>
                    <td style="text-align:center;color:#60c8e8;">@t.Ast.ToString("F1")</td>
                    <td style="text-align:center;color:#a0e080;">@t.Stl.ToString("F1")</td>
                    <td style="text-align:center;color:#e08060;">@t.Blk.ToString("F1")</td>
                    <td style="text-align:center;color:#f06060;">@t.Tov.ToString("F1")</td>
                    <td style="text-align:center;color:#666;">@t.Pace.ToString("F1")</td>
                </tr>
            }
            </tbody>
        </table>
        </div>
    }

}
else if (_phase == Phase.Done && _season is not null)
{
    <!-- ═══ CHAMPION BANNER ═══ -->
    @if (_playoffs?.Champion is not null)
    {
        string _champOpp = "";
        string _champSeries = "";
        if (_playoffs.Finals is not null)
        {
            _champOpp    = _playoffs.Finals.HighSeedTeam == _playoffs.Champion ? _playoffs.Finals.LowSeedTeam : _playoffs.Finals.HighSeedTeam;
            _champSeries = _playoffs.Finals.SeriesScore;
        }
        <div style="text-align:center;margin-bottom:1.5rem;padding:0.75rem;background:#0d0900;border:1px solid #2a1800;border-radius:6px;">
            <div style="font-size:0.72rem;color:#665;letter-spacing:3px;margin-bottom:2px;">NBA CHAMPION</div>
            <div style="font-size:1.6rem;font-weight:800;color:#fca;letter-spacing:2px;">@_playoffs.Champion</div>
            @if (_champOpp.Length > 0)
            {
                <div style="font-size:0.82rem;color:#554;margin-top:2px;">def. @_champOpp — @_champSeries</div>
            }
        </div>
    }

    <!-- ═══ STANDINGS ═══ -->
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:1.25rem;margin-bottom:1.5rem;">
        @foreach (var conf in new[] { "Eastern", "Western" })
        {
            var confTeams = _season.TeamStats
                .Where(t => t.Conference == conf)
                .OrderByDescending(t => t.Wins).ThenBy(t => t.Losses)
                .ToList();
            var leader = confTeams.FirstOrDefault();

            <div>
                <div class="section-title">@conf.ToUpper() CONFERENCE</div>
                <div class="scroll-x">
                <table>
                    <thead>
                        <tr>
                            <th style="width:18px;"></th>
                            <th style="text-align:left;">TEAM</th>
                            <th style="text-align:left;color:#3a3a3a;font-size: 0.8rem;">DIV</th>
                            <th style="text-align:center;width:28px;">W</th>
                            <th style="text-align:center;width:28px;">L</th>
                            <th style="text-align:center;width:44px;">PCT</th>
                            <th style="text-align:center;width:34px;">GB</th>
                            <th style="text-align:center;width:52px;">CONF</th>
                            <th style="text-align:center;width:44px;">HOME</th>
                            <th style="text-align:center;width:44px;">AWAY</th>
                            <th style="text-align:center;width:38px;">PPG</th>
                            <th style="text-align:center;width:38px;">OPP</th>
                            <th style="text-align:center;width:38px;">DIFF</th>
                        </tr>
                    </thead>
                    <tbody>
                        @for (int rank = 0; rank < confTeams.Count; rank++)
                        {
                            var t = confTeams[rank];
                            double gb = leader is null ? 0 : ((leader.Wins - t.Wins) + (t.Losses - leader.Losses)) / 2.0;
                            double diff = t.Ppg - t.Papg;
                            string rowBg = rank < 6 ? "#0d1a0d" : rank < 10 ? "#0d0d1a" : "#111";
                            <tr class="clickable-row" style="background:@rowBg;" @onclick="() => OpenGameLog(t)">
                                <td style="color:#3a3a3a;font-size: 0.8rem;text-align:right;">@(rank+1)</td>
                                <td>
                                    <span style="display:inline-block;width:7px;height:7px;border-radius:50%;background:@t.PrimaryColor;margin-right:4px;vertical-align:middle;"></span>
                                    <span style="font-weight:@(rank<3?"700":"400");color:@(rank==0?"#e8e8e8":"#c0c0c0");">@t.Abbreviation</span>
                                </td>
                                <td style="color:#3a3a3a;font-size: 0.8rem;">@(t.Division.Length >= 3 ? t.Division[..3].ToUpper() : t.Division.ToUpper())</td>
                                <td style="text-align:center;color:#4af080;font-weight:@(rank==0?"700":"400");">@t.Wins</td>
                                <td style="text-align:center;color:#f06060;">@t.Losses</td>
                                <td style="text-align:center;">@t.Pct.ToString("F3")</td>
                                <td style="text-align:center;color:#444;font-size: 0.85rem;">@(rank==0?"—":gb.ToString("F1"))</td>
                                <td style="text-align:center;color:#777;font-size: 0.85rem;">@t.ConfWins-@t.ConfLosses</td>
                                <td style="text-align:center;color:#777;font-size: 0.85rem;">@t.HomeWins-@t.HomeLosses</td>
                                <td style="text-align:center;color:#777;font-size: 0.85rem;">@t.AwayWins-@t.AwayLosses</td>
                                <td style="text-align:center;">@t.Ppg.ToString("F1")</td>
                                <td style="text-align:center;color:#888;">@t.Papg.ToString("F1")</td>
                                <td style="text-align:center;color:@(diff>=0?"#4af080":"#f06060");">@diff.ToString("+0.0;-0.0;0.0")</td>
                            </tr>
                        }
                    </tbody>
                </table>
                </div>
                <div style="font-size: 0.78rem;color:#2a2a2a;margin-top:3px;display:flex;gap:8px;">
                    <span style="background:#0d1a0d;padding:1px 6px;border-radius:2px;">■ playoff (1-6)</span>
                    <span style="background:#0d0d1a;padding:1px 6px;border-radius:2px;">■ play-in (7-10)</span>
                </div>
            </div>
        }
    </div>

    <div style="display:flex;gap:0;border-bottom:1px solid #1e1e1e;margin:1.25rem 0 0.75rem;">
        <button class="pdlg-tab @(_statsTab=="players"?"active":"")" @onclick='()=>_statsTab="players"'>PLAYER STATS</button>
        <button class="pdlg-tab @(_statsTab=="teams"?"active":"")"   @onclick='()=>_statsTab="teams"'>TEAM STATS</button>
        @if (_playoffs is not null)
        {
            <button class="pdlg-tab @(_statsTab=="playoffs"?"active":"")" @onclick='()=>_statsTab="playoffs"'
                    style="@(_statsTab=="playoffs"?"color:#fca;border-bottom-color:#fca;":"")">PLAYOFFS</button>
        }
    </div>

    @if (_statsTab == "players")
    {
    <!-- ═══ LEAGUE LEADERS ═══ -->
